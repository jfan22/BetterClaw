function showApproval(idOrFragment) {
  console.log();
  console.log("  " + ui.kicker("BetterClaw · Approval detail"));
  console.log("  " + ui.hr());
  const { events, pending: pendingMap } = loadPendingApprovals();
  let entry = pendingMap.get(idOrFragment);
  if (!entry) {
    for (const [id, e] of pendingMap) {
      if (id.startsWith(idOrFragment)) { entry = e; break; }
    }
  }
  let resolution = null;
  if (!entry) {
    for (const e of events) {
      if (e.type === "approval_pending" && (e.id === idOrFragment || e.id.startsWith(idOrFragment))) {
        entry = e;
      }
      if (e.type === "approval_resolved" && entry && e.id === entry.id) {
        resolution = e;
      }
    }
  }
  if (!entry) {
    console.log(`  ${deny("✗")}  No approval with id ${bold(idOrFragment)}`);
    console.log();
    process.exit(1);
  }
  const ts = (entry.ts || "").replace("T", " ").slice(0, 19);
  console.log(`  ${dim("id       ")} ${ui.chip(entry.id, "pending")}`);
  console.log(`  ${dim("tool     ")} ${bold(entry.tool)}`);
  console.log(`  ${dim("node     ")} ${entry.node}`);
  console.log(`  ${dim("requested")} ${gray(ts)}`);
  if (resolution) {
    const resTs = (resolution.ts || "").replace("T", " ").slice(0, 19);
    const verb = resolution.decision === "approved" ? allow("APPROVED") : deny("DENIED");
    console.log(`  ${dim("resolved ")} ${verb} ${gray("at " + resTs)}`);
  } else if (pendingMap.has(entry.id)) {
    console.log(`  ${dim("resolved ")} ${pending("still waiting")}`);
  } else {
    console.log(`  ${dim("resolved ")} ${dim("(unknown)")}`);
  }
  console.log();
  console.log("  " + bold("Parameters"));
  const pretty = JSON.stringify(entry.params ?? {}, null, 2);
  for (const line of pretty.split("\n")) {
    console.log("    " + line);
  }
  console.log();
  if (!resolution && pendingMap.has(entry.id)) {
    console.log("  " + dim("Resolve: ") + accent(`betterclaw approve ${entry.id}`) + dim("  or  ") + accent(`betterclaw deny ${entry.id}`));
    console.log();
  }
}

async function resolveApproval(id, decision) {
  if (!/^[a-z0-9-]+$/i.test(id)) {
    console.error("  " + deny("✗") + "  invalid id " + gray(id));
    process.exit(1);
  }
  fs.mkdirSync(APPROVALS_DIR, { recursive: true });
  const filename = decision === "approve" ? `${id}.approved` : `${id}.denied`;
  fs.writeFileSync(path.join(APPROVALS_DIR, filename), String(Date.now()));

  // Look up the pending record so we can do the out-of-band dispatch if approved.
  const { pending } = loadPendingApprovals();
  const record = pending.get(id) || findPendingByPrefix(id);

  if (!record) {
    // No pending record — still write the sentinel in case the plugin is
    // polling for it (legacy in-band wait path). Just report and exit.
    const verb = decision === "approve" ? allow("Approved") : deny("Denied");
    console.log();
    console.log(`  ${verb} ${ui.chip(id)} ${dim("— no matching pending record found (sentinel written).")}`);
    console.log();
    return;
  }

  if (decision === "deny") {
    const ts = new Date().toISOString();
    appendRunEvent({
      ts,
      type: "approval_resolved",
      id: record.id,
      decision: "denied",
    });
    appendHistory({
      ts,
      type: "async_dispatch",
      id: record.id,
      tool: record.tool,
      vertical: record.vertical,
      decision: "denied",
      status: "not_dispatched",
      summary_hint: summarizeParamsForHistory(record),
    });
    console.log();
    console.log(`  ${deny("Denied")} ${ui.chip(record.id)} ${dim("— tool will not be dispatched.")}`);
    console.log();
    return;
  }

  // APPROVE: dispatch the tool call out-of-band against the real backend.
  await dispatchApprovedTool(record);
}

function findPendingByPrefix(idPrefix) {
  const { pending } = loadPendingApprovals();
  for (const [id, record] of pending) {
    if (id.startsWith(idPrefix)) return record;
  }
  return null;
}

function appendRunEvent(event) {
  if (!fs.existsSync(RUN_LOG_PATH)) return;
  try {
    fs.appendFileSync(RUN_LOG_PATH, JSON.stringify(event) + "\n");
  } catch {}
}

async function dispatchApprovedTool(record) {
  console.log();
  console.log(`  ${allow("Approved")} ${ui.chip(record.id)} ${dim("— dispatching " + record.tool + "…")}`);

  const approvedTs = new Date().toISOString();
  appendRunEvent({
    ts: approvedTs,
    type: "approval_resolved",
    id: record.id,
    decision: "approved",
  });

  const result = await callBackend(record);
  const endTs = new Date().toISOString();

  if (result.ok) {
    appendRunEvent({
      ts: endTs,
      type: "async_dispatch",
      id: record.id,
      tool: record.tool,
      status: "success",
      result_summary: result.summary,
    });
    appendHistory({
      ts: endTs,
      type: "async_dispatch",
      id: record.id,
      tool: record.tool,
      vertical: record.vertical,
      decision: "approved",
      status: "success",
      result_summary: result.summary,
      summary_hint: summarizeParamsForHistory(record),
    });
    console.log(`  ${allow("✓")}  ${bold(record.tool)} ${dim("dispatched:")}`);
    if (result.summary) {
      for (const line of result.summary.split("\n")) {
        console.log("     " + gray(line));
      }
    }
    if (result.next_hint) {
      console.log();
      console.log("  " + dim(result.next_hint));
    }
  } else {
    appendRunEvent({
      ts: endTs,
      type: "async_dispatch",
      id: record.id,
      tool: record.tool,
      status: "error",
      error: result.error,
    });
    appendHistory({
      ts: endTs,
      type: "async_dispatch",
      id: record.id,
      tool: record.tool,
      vertical: record.vertical,
      decision: "approved",
      status: "error",
      error: result.error,
      summary_hint: summarizeParamsForHistory(record),
    });
    console.log(`  ${deny("✗")}  ${bold(record.tool)} ${dim("dispatch failed:")}`);
    console.log("     " + deny(result.error));
  }
  console.log();
}

// One-liner describing the params, shape-appropriate for each tool. Used in
// the history log so the plugin can surface a human-readable hint back to
// the agent on the next turn ("draft re: Quick question about BetterClaw to
// clawtester58@gmail.com").
function summarizeParamsForHistory(record) {
  const p = record.params || {};
  if (record.tool === "gmail_draft") {
    const to = Array.isArray(p.to) ? p.to.join(", ") : p.to;
    return `to=${to} subject=${JSON.stringify(p.subject ?? "")}`;
  }
  if (record.tool === "sales_draft_outreach") {
    return `leadId=${p.leadId} subject=${JSON.stringify(p.subject ?? "")}`;
  }
  // Fallback — truncated JSON of first 3 keys
  const keys = Object.keys(p).slice(0, 3);
  const brief = {};
  for (const k of keys) brief[k] = p[k];
  return JSON.stringify(brief);
}

// Backend router: which dispatch strategy for which tool. Reads the tool
// name from the pending record and picks the right one. Expandable without
// touching the plugin (tool contracts stay the same).
async function callBackend(record) {
  if (record.tool === "gmail_draft") {
    return await dispatchToGmailMcp("draft_email", record.params);
  }
  // Stub-backed tools (sales, travel) don't need a real remote call — the
  // original plugin dispatch would've just returned stubbed content. We
  // simulate by reporting "approved without external side effect." The
  // agent can't see this (its turn is over), but the run log captures it.
  return {
    ok: true,
    summary: `Approved (stub-backed tool — no external side effect). Params recorded in run.jsonl.`,
    next_hint: `See: betterclaw show ${record.id}`,
  };
}

async function dispatchToGmailMcp(toolName, params) {
  // One-shot Gmail MCP call. Spawns a fresh child, performs initialize +
  // tools/call, captures the response, shuts down cleanly.
  return new Promise((resolve) => {
    const child = spawn("npx", ["-y", "@gongrzhe/server-gmail-autoauth-mcp"], {
      stdio: ["pipe", "pipe", "pipe"],
      env: { ...process.env },
    });

    let buffer = "";
    let finished = false;
    const pending = new Map();
    let nextId = 1;

    const finish = (result) => {
      if (finished) return;
      finished = true;
      try { child.stdin.end(); } catch {}
      try { child.kill("SIGTERM"); } catch {}
      resolve(result);
    };

    const send = (method, params, isNotification = false) => {
      const id = isNotification ? undefined : nextId++;
      const payload = { jsonrpc: "2.0", method };
      if (id !== undefined) payload.id = id;
      if (params !== undefined) payload.params = params;
      const line = JSON.stringify(payload) + "\n";
      return new Promise((res, rej) => {
        if (!isNotification) pending.set(id, { resolve: res, reject: rej });
        child.stdin.write(line, (err) => {
          if (err) {
            if (!isNotification) pending.delete(id);
            rej(err);
          }
          if (isNotification) res();
        });
      });
    };

    child.stdout.setEncoding("utf8");
    child.stdout.on("data", (chunk) => {
      buffer += chunk;
      let idx;
      while ((idx = buffer.indexOf("\n")) !== -1) {
        const line = buffer.slice(0, idx).trim();
        buffer = buffer.slice(idx + 1);
        if (!line) continue;
        let msg;
        try { msg = JSON.parse(line); } catch { continue; }
        if (msg.id !== undefined && pending.has(msg.id)) {
          const { resolve: res, reject: rej } = pending.get(msg.id);
          pending.delete(msg.id);
          if (msg.error) rej(new Error(`MCP error: ${JSON.stringify(msg.error)}`));
          else res(msg.result);
        }
      }
    });

    child.stderr.on("data", (chunk) => {
      // Gmail MCP logs to stderr; don't pollute our output.
      void chunk;
    });

    child.on("error", (err) => finish({ ok: false, error: `spawn error: ${err.message}` }));
    child.on("exit", (code, signal) => {
      if (!finished) {
        finish({ ok: false, error: `gmail MCP exited early (code=${code} signal=${signal})` });
      }
    });

    (async () => {
      try {
        await send("initialize", {
          protocolVersion: "2024-11-05",
          capabilities: {},
          clientInfo: { name: "betterclaw-cli", version: "0.1.0" },
        });
        await send("notifications/initialized", {}, true);
        const result = await send("tools/call", { name: toolName, arguments: params ?? {} });
        // Extract the Gmail MCP's human-readable summary from the content blocks.
        const textParts = (result?.content ?? [])
          .filter((c) => c.type === "text")
          .map((c) => c.text)
          .join("\n");
        finish({
          ok: !result?.isError,
          summary: textParts || "(no content returned)",
          next_hint: toolName === "draft_email"
            ? "Open your Gmail Drafts folder to review."
            : null,
          error: result?.isError ? textParts : undefined,
        });
      } catch (err) {
        finish({ ok: false, error: err.message || String(err) });
      }
    })();
  });
}

function viewLastRun() {
  if (!fs.existsSync(GRAPH_PATH)) {
    console.error(`error: no graph compiled yet. Run \`betterclaw "<paragraph>"\` first.`);
    process.exit(1);
  }
  if (!fs.existsSync(RUN_LOG_PATH) || fs.statSync(RUN_LOG_PATH).size === 0) {
    console.error(
      `error: no run log at ${RUN_LOG_PATH}\n` +
        `       Run the agent once: \`openclaw agent --local --agent main -m "<task>"\``,
    );
    process.exit(1);
  }

  const graph = JSON.parse(fs.readFileSync(GRAPH_PATH, "utf8"));
  const events = fs
    .readFileSync(RUN_LOG_PATH, "utf8")
    .split("\n")
    .filter((l) => l.trim().length > 0)
    .map((l) => {
      try {
        return JSON.parse(l);
      } catch {
        return null;
      }
    })
    .filter(Boolean);

  const allowEvents = events.filter((e) => e.type === "allow");
  const deviationEvents = events.filter((e) => e.type === "deviation");
  const visitedNodes = new Set(
    allowEvents.flatMap((e) => [e.from_node, e.to_node]).filter(Boolean),
  );
  const traversedEdges = new Set();
  for (const e of allowEvents) {
    if (e.transitioned) traversedEdges.add(`${e.from_node}→${e.to_node}`);
  }

  const mermaid = buildReplayMermaid(graph, visitedNodes, traversedEdges, deviationEvents);
  const htmlPath = writeReplayHtml(graph, events, mermaid, {
    allowCount: allowEvents.length,
    deviationCount: deviationEvents.length,
  });
  console.log();
  console.log(`  ${bold("Replay")}  ${ui.chip(allowEvents.length + " allowed", "allow")} ${ui.chip(deviationEvents.length + " deviation" + (deviationEvents.length === 1 ? "" : "s"), deviationEvents.length > 0 ? "deny" : null)}`);
  console.log(`  ${accent("→")} ${gray(htmlPath)}`);
  console.log();
  const opener = process.platform === "darwin" ? "open" : "xdg-open";
  spawn(opener, [htmlPath], { stdio: "ignore", detached: true }).unref();
}

async function startWatchServer() {
  if (!fs.existsSync(GRAPH_PATH)) {
    console.error(`error: no graph compiled yet. Run \`betterclaw "<paragraph>"\` first.`);
    process.exit(1);
  }

  const server = http.createServer((req, res) => {
    const url = new URL(req.url, "http://localhost");
    if (url.pathname === "/" || url.pathname === "/index.html") {
      res.writeHead(200, { "content-type": "text/html; charset=utf-8" });
      res.end(buildWatchPageHtml());
      return;
    }
    if (url.pathname === "/state.json") {
      const state = readCurrentState();
      res.writeHead(200, { "content-type": "application/json" });
      res.end(JSON.stringify(state));
      return;
    }
    if (url.pathname === "/resolve" && req.method === "POST") {
      let body = "";
      req.on("data", (chunk) => (body += chunk));
      req.on("end", async () => {
        try {
          const { id, decision } = JSON.parse(body);
          if (!id || (decision !== "approve" && decision !== "deny")) {
            res.writeHead(400, { "content-type": "application/json" });
            res.end(JSON.stringify({ error: "need { id, decision: 'approve' | 'deny' }" }));
            return;
          }
          await resolveApproval(id, decision);
          res.writeHead(200, { "content-type": "application/json" });
          res.end(JSON.stringify({ ok: true, id, decision }));
        } catch (err) {
          res.writeHead(400, { "content-type": "application/json" });
          res.end(JSON.stringify({ error: String(err) }));
        }
      });
      return;
    }
    res.writeHead(404, { "content-type": "text/plain" });
    res.end("not found");
  });

  await new Promise((resolve) => server.listen(0, "127.0.0.1", resolve));
  const { port } = server.address();
  const url = `http://127.0.0.1:${port}/`;
  console.log();
  console.log("  " + ui.kicker("BetterClaw · Live view"));
  console.log("  " + ui.hr());
  console.log(`  ${bold("Serving at")} ${accent(url)}`);
  console.log();
  console.log("  " + dim("Leave this running. In another terminal:"));
  console.log("    " + accent(`openclaw agent --local --agent main -m "<your task>"`));
  console.log();
  console.log("  " + dim("Ctrl+C here to stop."));
  console.log();
  const opener = process.platform === "darwin" ? "open" : "xdg-open";
  spawn(opener, [url], { stdio: "ignore", detached: true }).unref();

  await new Promise(() => {});
}

function readCurrentState() {
  const graph = JSON.parse(fs.readFileSync(GRAPH_PATH, "utf8"));
  let events = [];
  if (fs.existsSync(RUN_LOG_PATH)) {
    events = fs
      .readFileSync(RUN_LOG_PATH, "utf8")
      .split("\n")
      .filter((l) => l.trim().length > 0)
      .map((l) => {
        try { return JSON.parse(l); } catch { return null; }
      })
      .filter(Boolean);
  }
  return { graph, events, ts: Date.now() };
}

function buildWatchPageHtml() {
  return `<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>BetterClaw — Live run</title>
  <style>${SHARED_CSS}</style>
  <script src="https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.min.js"></script>
</head>
<body>
  <p class="kicker">BetterClaw · Live run</p>
  <h1 class="page-title">
    Agent at work
    <span class="chip live" style="vertical-align: middle; margin-left: 0.5rem;" id="live-chip">live</span>
  </h1>
  <p class="label" style="margin: 0 0 1.25rem;">Polling <span class="mono" style="text-transform: none; color: var(--ink-soft);">/state.json</span> every 500ms · green = visited · bold edge = traversed · dashed rust = attempted deviation</p>
  <hr class="rule"/>

  <div class="summary">
    <span class="chip allow"   id="allowChip">0 allowed</span>
    <span class="chip deny"    id="devChip">0 deviations</span>
    <span class="chip pending" id="pendingChip" style="display:none;">0 pending</span>
    <span class="meta" id="graphMeta"></span>
  </div>

  <div id="approvals"></div>

  <div class="layout">
    <div>
      <h2 class="section">Workflow graph</h2>
      <p class="label" style="margin-bottom:0.5rem;">Live state</p>
      <div class="mermaid-wrap" id="diagram"></div>
    </div>
    <div>
      <h2 class="section">Timeline</h2>
      <p class="label" style="margin-bottom:0.5rem;">Most recent at bottom</p>
      <table>
        <thead><tr><th>time</th><th>node</th><th>tool</th><th>detail</th></tr></thead>
        <tbody id="timeline"></tbody>
      </table>
    </div>
  </div>

  <p class="footer" id="lastUpdate">awaiting first event</p>

<script>
  ${MERMAID_INIT_JS}

  let lastEventCount = -1;
  let lastDiagramSig = "";
  let renderSeq = 0;

  async function tick() {
    try {
      const res = await fetch("/state.json", { cache: "no-store" });
      if (!res.ok) return;
      const state = await res.json();
      await render(state);
    } catch (err) { /* server may be starting; silently retry */ }
  }

  function escapeHtml(s) {
    return String(s).replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;").replace(/"/g,"&quot;");
  }

  function shortTools(ts) {
    if (!ts || ts.length === 0) return "—";
    return ts.map(t => t.replace(/^[a-z]+_/,"")).join(" / ");
  }

  async function render(state) {
    const { graph, events } = state;
    const allow = events.filter(e => e.type === "allow");
    const dev = events.filter(e => e.type === "deviation");

    // Pending approvals
    const pendingMap = new Map();
    for (const e of events) {
      if (e.type === "approval_pending") pendingMap.set(e.id, e);
      if (e.type === "approval_resolved") pendingMap.delete(e.id);
    }
    const pending = [...pendingMap.values()];

    document.getElementById("allowChip").textContent = allow.length + " allowed";
    document.getElementById("devChip").textContent = dev.length + " deviation" + (dev.length === 1 ? "" : "s");
    const pendingChip = document.getElementById("pendingChip");
    if (pending.length > 0) {
      pendingChip.style.display = "inline-flex";
      pendingChip.textContent = pending.length + " pending";
    } else {
      pendingChip.style.display = "none";
    }
    document.getElementById("graphMeta").innerHTML = "entry " + escapeHtml(graph.entry) + " · " + graph.nodes.length + " nodes · " + graph.edges.length + " edges · vertical " + escapeHtml(graph.vertical || "email");

    renderApprovals(pending);

    // Mermaid re-render only on change
    const visited = new Set(allow.flatMap(e => [e.from_node, e.to_node]).filter(Boolean));
    const traversed = new Set();
    for (const e of allow) if (e.transitioned) traversed.add(e.from_node + "→" + e.to_node);
    const sig = JSON.stringify({ g: graph, v: [...visited].sort(), t: [...traversed].sort(),
      d: dev.map(d => ({ n: d.from_node, t: d.attempted_tool })) });
    if (sig !== lastDiagramSig) {
      lastDiagramSig = sig;
      const wrap = document.getElementById("diagram");
      wrap.classList.add("refreshing");
      const src = buildMermaidSource(graph, visited, traversed, dev);
      const id = "diagram-svg-" + (++renderSeq);
      try {
        const out = await mermaid.render(id, src);
        wrap.innerHTML = out.svg;
      } catch (err) {
        wrap.textContent = "mermaid render error: " + err.message;
      }
      requestAnimationFrame(() => wrap.classList.remove("refreshing"));
    }

    // Timeline
    const tbody = document.getElementById("timeline");
    const rowsHtml = events
      .filter(e => e.type === "allow" || e.type === "deviation")
      .map((e, i) => {
        const ts = e.ts ? e.ts.split("T")[1].slice(0, 12) : "";
        const fresh = (i >= lastEventCount && lastEventCount >= 0) ? " fresh" : "";
        if (e.type === "deviation") {
          return "<tr class=\\"dev" + fresh + "\\"><td>" + ts + "</td><td>" + escapeHtml(e.from_node ?? "") + "</td><td>✕ " + escapeHtml(e.attempted_tool ?? "") + "</td><td>retry " + e.retry + "/" + e.retry_limit + "</td></tr>";
        }
        const arrow = e.transitioned
          ? escapeHtml(e.from_node) + " → " + escapeHtml(e.to_node)
          : "— " + escapeHtml(e.from_node);
        return "<tr class=\\"" + fresh.trim() + "\\"><td>" + ts + "</td><td>" + escapeHtml(e.to_node ?? e.from_node ?? "") + "</td><td>✓ " + escapeHtml(e.tool ?? "") + "</td><td>" + arrow + "</td></tr>";
      })
      .join("");
    tbody.innerHTML = rowsHtml || "<tr><td colspan=\\"4\\" style=\\"color: var(--muted); font-style: italic; padding: 1.5rem;\\">waiting for first tool call…</td></tr>";
    lastEventCount = allow.length + dev.length;

    document.getElementById("lastUpdate").textContent = "last poll " + new Date().toLocaleTimeString();
  }

  function buildMermaidSource(graph, visitedNodes, traversedEdges, deviationEvents) {
    const devsByNode = new Map();
    for (const d of deviationEvents) {
      if (!devsByNode.has(d.from_node)) devsByNode.set(d.from_node, []);
      devsByNode.get(d.from_node).push(d.attempted_tool);
    }
    const lines = ["flowchart TD"];
    for (const n of graph.nodes) {
      const purpose = (n.purpose || "").replace(/"/g,"&quot;").replace(/\\n/g," ");
      const devs = devsByNode.get(n.id);
      const devSuffix = devs ? "<br/><b style='color:#7a2418;'>deviations: " + devs.length + "</b>" : "";
      const label = "<b>" + n.id + "</b><br/>" + purpose + "<br/><i>tools: " + shortTools(n.allowed_tools) + "</i>" + devSuffix;
      lines.push("  " + n.id + "[\\"" + label + "\\"]");
    }
    lines.push("  start((entry))");
    lines.push("  start --> " + graph.entry);
    for (const e of graph.edges) {
      const key = e.from + "→" + e.to;
      lines.push("  " + e.from + (traversedEdges.has(key) ? " ==> " : " --> ") + e.to);
    }
    let p = 0;
    for (const d of deviationEvents) {
      const tool = (d.attempted_tool || "unknown").replace(/^[a-z]+_/,"");
      lines.push("  devghost" + p + "([\\"✕ " + tool + "<br/>deviation\\"]):::devbox");
      lines.push("  " + d.from_node + " -.-> devghost" + p);
      p++;
    }
    lines.push("  classDef visited fill:#c5e3d1,stroke:#27613f,stroke-width:2px;");
    lines.push("  classDef devbox fill:#eec6bc,stroke:#7a2418,stroke-width:1.5px,stroke-dasharray:5 3;");
    lines.push("  classDef entryBadge fill:#eeeada,stroke:#1c3b5a,stroke-width:2px;");
    lines.push("  class start entryBadge;");
    const visitedList = [...visitedNodes].filter(n => graph.nodes.some(gn => gn.id === n));
    if (visitedList.length > 0) lines.push("  class " + visitedList.join(",") + " visited;");
    return lines.join("\\n");
  }

  function renderApprovals(pending) {
    const host = document.getElementById("approvals");
    if (pending.length === 0) { host.innerHTML = ""; return; }
    host.innerHTML = pending.map(p => {
      const paramsStr = p.params ? JSON.stringify(p.params, null, 2) : "(no params)";
      return "<div class=\\"approval-card\\" data-id=\\"" + escapeHtml(p.id) + "\\">" +
        "<h3>Awaiting approval · " + escapeHtml(p.tool) + "</h3>" +
        "<div class=\\"meta-row\\">node <span class=\\"mono\\">" + escapeHtml(p.node) + "</span> &nbsp;·&nbsp; id <span class=\\"mono\\">" + escapeHtml(p.id) + "</span></div>" +
        "<div class=\\"params\\">" + escapeHtml(paramsStr) + "</div>" +
        "<div class=\\"buttons\\">" +
          "<button class=\\"btn approve\\" onclick=\\"resolveApproval('" + p.id + "','approve',this)\\">Approve</button>" +
          "<button class=\\"btn deny\\" onclick=\\"resolveApproval('" + p.id + "','deny',this)\\">Deny</button>" +
        "</div>" +
      "</div>";
    }).join("");
  }

  async function resolveApproval(id, decision, btn) {
    const card = btn.closest(".approval-card");
    card.querySelectorAll("button").forEach(b => b.disabled = true);
    try {
      const res = await fetch("/resolve", {
        method: "POST",
        headers: { "content-type": "application/json" },
        body: JSON.stringify({ id, decision }),
      });
      if (!res.ok) {
        card.querySelectorAll("button").forEach(b => b.disabled = false);
        alert("Resolve failed: " + res.status);
      }
    } catch (err) {
      card.querySelectorAll("button").forEach(b => b.disabled = false);
      alert("Resolve failed: " + err.message);
    }
  }
  window.resolveApproval = resolveApproval;

  tick();
  setInterval(tick, 500);
</script>
</body>
</html>`;
}

function buildReplayMermaid(graph, visitedNodes, traversedEdges, deviationEvents) {
  const shortTools = (tools) =>
    tools.length > 0 ? tools.map((t) => t.replace(/^[a-z]+_/, "")).join(" / ") : "—";
  const deviationsByNode = new Map();
  for (const d of deviationEvents) {
    if (!deviationsByNode.has(d.from_node)) deviationsByNode.set(d.from_node, []);
    deviationsByNode.get(d.from_node).push(d.attempted_tool);
  }

  const lines = ["flowchart TD"];
  for (const n of graph.nodes) {
    const purpose = n.purpose.replace(/"/g, "&quot;").replace(/\n/g, " ");
    const devs = deviationsByNode.get(n.id);
    const devSuffix = devs
      ? `<br/><b style='color:#7a2418;'>deviations: ${devs.length}</b>`
      : "";
    const label = `<b>${n.id}</b><br/>${purpose}<br/><i>tools: ${shortTools(n.allowed_tools)}</i>${devSuffix}`;
    lines.push(`  ${n.id}["${label}"]`);
  }
  lines.push(`  start((entry))`);
  lines.push(`  start --> ${graph.entry}`);

  for (const e of graph.edges) {
    const key = `${e.from}→${e.to}`;
    if (traversedEdges.has(key)) {
      lines.push(`  ${e.from} ==> ${e.to}`);
    } else {
      lines.push(`  ${e.from} --> ${e.to}`);
    }
  }

  let phantomIdx = 0;
  for (const d of deviationEvents) {
    const phantom = `devghost${phantomIdx++}`;
    const tool = (d.attempted_tool || "unknown").replace(/^[a-z]+_/, "");
    lines.push(`  ${phantom}(["✕ ${tool}<br/>deviation"]):::devbox`);
    lines.push(`  ${d.from_node} -.-> ${phantom}`);
  }

  lines.push(`  classDef visited fill:#c5e3d1,stroke:#27613f,stroke-width:2px;`);
  lines.push(`  classDef devbox fill:#eec6bc,stroke:#7a2418,stroke-width:1.5px,stroke-dasharray:5 3;`);
  lines.push(`  classDef entryBadge fill:#eeeada,stroke:#1c3b5a,stroke-width:2px;`);
  lines.push(`  class start entryBadge;`);
  const visitedList = [...visitedNodes].filter((n) => graph.nodes.some((gn) => gn.id === n));
  if (visitedList.length > 0) {
    lines.push(`  class ${visitedList.join(",")} visited;`);
  }
  return lines.join("\n");
}

