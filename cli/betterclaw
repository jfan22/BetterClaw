    .pane h2 { margin: 0 0 0.25rem; font-size: 1.1rem; }
    .pane .meta { color: #666; font-size: 0.85rem; margin: 0 0 0.75rem; }
    .mermaid { overflow: auto; padding: 0.5rem 0; }
    code { background: #f0f0f0; padding: 0 0.25em; border-radius: 3px; font-family: ui-monospace, monospace; }
  </style>
  <script src="https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.min.js"></script>
</head>
<body>
  <h1>Graph diff: ${escapeHtml(nameA)} ↔ ${escapeHtml(nameB)}</h1>
  <p class="sub">Structural diff. Additions are green. Edited tool allowlists are yellow. New edges get a 🆕 label.</p>

  <div class="legend">
    <span>🟢 Added node</span>
    <span>🟡 Changed allowed_tools</span>
    <span>⚫ Unchanged</span>
    <span>🆕 New edge</span>
  </div>

  <div class="panes">
    <div class="pane">
      <h2>${escapeHtml(nameA)}</h2>
      <p class="meta">${summarize(graphA)}</p>
      <pre class="mermaid">${mermaidA}</pre>
    </div>
    <div class="pane">
      <h2>${escapeHtml(nameB)}</h2>
      <p class="meta">${summarize(graphB)}</p>
      <pre class="mermaid">${mermaidB}</pre>
    </div>
  </div>

  <script>
    mermaid.initialize({ startOnLoad: true, theme: "default", flowchart: { useMaxWidth: false, curve: "basis" } });
  </script>
</body>
</html>`;
}

async function publishToRemote(name, dest) {
  validateLibraryName(name);
  const dir = libraryEntryDir(name);
  if (!fs.existsSync(dir)) {
    console.error(`error: "${name}" not in library. Save it first with: betterclaw save ${name}`);
    process.exit(1);
  }
  if (dest !== "gist") {
    console.error(`error: only --to gist is supported right now`);
    process.exit(1);
  }
  const ghCheck = spawnSync("gh", ["--version"], { encoding: "utf8" });
  if (ghCheck.status !== 0) {
    console.error(`error: \`gh\` CLI not found. Install it: https://cli.github.com/`);
    process.exit(2);
  }

  const graphPath = path.join(dir, "graph.json");
  const paraPath = path.join(dir, "paragraph.md");
  const metaPath = path.join(dir, "meta.json");
  const meta = JSON.parse(fs.readFileSync(metaPath, "utf8"));

  // Write a BetterClaw.md readme that explains what the gist contains.
  const readmePath = path.join(dir, "BetterClaw.md");
  const readme = `# BetterClaw workflow: ${name}

Compiled by [BetterClaw](https://github.com/) on ${meta.saved_at}.

- **${meta.nodes} nodes, ${meta.edges} edges**
- Entry: \`${meta.entry}\`
- Requires approval: ${meta.requires_approval?.join(", ") || "(none)"}

## Install

\`\`\`bash
betterclaw fork <this-gist-url> ${name}
betterclaw load ${name}
openclaw agent --local --agent main -m "<your task>"
\`\`\`

## Source paragraph

See \`paragraph.md\` in this gist.
`;
  fs.writeFileSync(readmePath, readme);

  const filesToUpload = [graphPath];
  if (fs.existsSync(paraPath)) filesToUpload.push(paraPath);
  filesToUpload.push(metaPath, readmePath);

  console.log(`Publishing "${name}" to a public gist…`);
  const ghArgs = [
    "gist",
    "create",
    "--public",
    "--desc",
    `BetterClaw workflow: ${name}`,
    ...filesToUpload,
  ];
  const result = spawnSync("gh", ghArgs, { encoding: "utf8", stdio: ["inherit", "pipe", "pipe"] });
  if (result.status !== 0) {
    console.error(`error: gh gist create failed:`);
    console.error(result.stderr);
    process.exit(3);
  }
  const gistUrl = result.stdout.trim();
  console.log(`Published: ${gistUrl}`);
  console.log(`\nShare this URL. Recipients can install with:`);
  console.log(`  betterclaw fork ${gistUrl} ${name}`);
}

