function detectVertical(paragraph) {
  const p = paragraph.toLowerCase();
  // Explicit override: "vertical: shopping" anywhere in the paragraph.
  const explicit = p.match(/vertical[:=]\s*(email|shopping|sales|travel)/);
  if (explicit) return explicit[1];

  const hit = (...terms) => terms.some((t) => p.includes(t));
  // Check specific verticals first; "email" is the catch-all fallback because
  // "email" as a bare keyword is too common (e.g. "cold email" is sales).
  if (hit("lead", "prospect", "outreach", "crm", "cold email", "sdr", "cold outreach", " sales "))
    return "sales";
  if (hit("flight", "hotel", "travel ", "trip ", "airfare", "booking", "itinerary", "airport"))
    return "travel";
  // Shopping — match explicit retail verbs, price-comparison intent, product
  // categories from the dummyjson vocabulary, and gift-shopping patterns.
  // "shipping" isn't here because it's ambiguous (email with shipping-update
  // context). Use other signals.
  if (
    hit(
      // retail verbs + patterns
      "shop ", "shop for", "shopping for", "buy ", "purchase", "add to cart",
      "price compare", "online store", "electronics store",
      // generic product intent
      "product", "catalog", "recommend a ", "good ", "best ",
      // gift-shopping patterns (Mother's Day, Father's Day, birthday, etc.)
      "gift", "mother's day", "father's day", "birthday present", "anniversary gift",
      // dummyjson category vocabulary
      "smartphone", "laptop", "tablet", "wireless mouse", "headphones", "smartwatch",
      "jewellery", "jewelry", "fragrance", "perfume", "sunglasses",
      "skin-care", "skin care", "beauty product", "makeup",
      "home-decoration", "home decor", "kitchen-accessories",
      "mens-shirt", "mens-shoes", "mens-watches",
      "womens-bag", "womens-dress", "womens-jewellery", "womens-shoes", "womens-watches",
    )
  )
    return "shopping";
  if (hit("inbox", "gmail", "draft reply", "triage my inbox", "newsletters", "my email", "my inbox", "emails from"))
    return "email";
  // Last-resort default: warn rather than silently picking a vertical.
  // The caller will see it and either add --vertical=X or rewrite the paragraph.
  return "email";
}

