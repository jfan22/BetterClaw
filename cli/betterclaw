    body { font: 14px/1.5 -apple-system, system-ui, "Segoe UI", sans-serif; margin: 0; padding: 2rem; background: #fafafa; color: #222; }
    h1 { margin: 0 0 0.25rem; font-size: 1.4rem; }
    .sub { color: #666; margin: 0 0 1.5rem; font-size: 0.95rem; }
    .summary { background: #fff; border: 1px solid #ddd; padding: 0.9rem 1.1rem; margin: 0 0 1.5rem; border-radius: 4px; display: flex; gap: 2rem; align-items: center; }
