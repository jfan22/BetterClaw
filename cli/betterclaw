function resolveApproval(id, decision) {
  if (!/^[a-z0-9-]+$/i.test(id)) {
    console.error(`error: invalid id ${id}`);
    process.exit(1);
  }
  fs.mkdirSync(APPROVALS_DIR, { recursive: true });
  const filename = decision === "approve" ? `${id}.approved` : `${id}.denied`;
  const target = path.join(APPROVALS_DIR, filename);
  fs.writeFileSync(target, String(Date.now()));
  console.log(`${decision === "approve" ? "Approved" : "Denied"} ${id}. Agent will resume shortly.`);
}

// ---- library / marketplace ----

function validateLibraryName(name) {
  if (!/^[a-z0-9][a-z0-9-_]{0,63}$/i.test(name)) {
    console.error(`error: invalid library name "${name}". Use letters, digits, dashes, underscores; 1-64 chars.`);
    process.exit(1);
  }
}

function libraryEntryDir(name) {
  return path.join(LIBRARY_DIR, name);
}

function readActiveGraph() {
  if (!fs.existsSync(GRAPH_PATH)) {
    console.error(`error: no active graph at ${GRAPH_PATH}`);
    console.error(`       Compile one first: betterclaw "<paragraph>"`);
    process.exit(1);
  }
  return fs.readFileSync(GRAPH_PATH, "utf8");
}

function readActiveParagraph() {
  if (fs.existsSync(PARAGRAPH_PATH)) return fs.readFileSync(PARAGRAPH_PATH, "utf8");
  return "(paragraph not recorded — this graph was compiled before paragraph persistence shipped)\n";
}

function saveToLibrary(name) {
  validateLibraryName(name);
  const graphText = readActiveGraph();
  const paragraphText = readActiveParagraph();
  const dir = libraryEntryDir(name);
  fs.mkdirSync(dir, { recursive: true });
  fs.writeFileSync(path.join(dir, "graph.json"), graphText);
  fs.writeFileSync(path.join(dir, "paragraph.md"), paragraphText);
  const graph = JSON.parse(graphText);
  const meta = {
    name,
    saved_at: new Date().toISOString(),
    source: "active",
    nodes: graph.nodes?.length ?? 0,
    edges: graph.edges?.length ?? 0,
    entry: graph.entry ?? null,
    requires_approval: graph.requires_approval ?? [],
  };
  fs.writeFileSync(path.join(dir, "meta.json"), JSON.stringify(meta, null, 2) + "\n");
  console.log(`Saved to library: ${dir}`);
  console.log(`  ${meta.nodes} nodes, ${meta.edges} edges, entry=${meta.entry}`);
  if (meta.requires_approval.length > 0) {
    console.log(`  approval required for: ${meta.requires_approval.join(", ")}`);
  }
}

function loadFromLibrary(name) {
  validateLibraryName(name);
  const dir = libraryEntryDir(name);
  const graphPath = path.join(dir, "graph.json");
  if (!fs.existsSync(graphPath)) {
    console.error(`error: library entry "${name}" not found at ${dir}`);
    process.exit(1);
  }
  fs.copyFileSync(graphPath, GRAPH_PATH);
  const paraPath = path.join(dir, "paragraph.md");
  if (fs.existsSync(paraPath)) fs.copyFileSync(paraPath, PARAGRAPH_PATH);
  const meta = JSON.parse(fs.readFileSync(path.join(dir, "meta.json"), "utf8"));
  console.log(`Loaded "${name}" as active graph.`);
  console.log(`  ${meta.nodes} nodes, ${meta.edges} edges, entry=${meta.entry}`);
  if (meta.forked_from) console.log(`  forked from: ${meta.forked_from}`);
  console.log(`\nNext: run \`openclaw agent --local --agent main -m "<task>"\`.`);
}

function listLibrary() {
  if (!fs.existsSync(LIBRARY_DIR)) {
    console.log(`No saved graphs. Library dir: ${LIBRARY_DIR}`);
    return;
  }
  const entries = fs
    .readdirSync(LIBRARY_DIR)
    .filter((e) => fs.statSync(path.join(LIBRARY_DIR, e)).isDirectory())
    .sort();
  if (entries.length === 0) {
    console.log(`No saved graphs. Library dir: ${LIBRARY_DIR}`);
    return;
  }
  const rows = [];
  for (const name of entries) {
    const metaPath = path.join(LIBRARY_DIR, name, "meta.json");
    if (!fs.existsSync(metaPath)) continue;
    const meta = JSON.parse(fs.readFileSync(metaPath, "utf8"));
    rows.push(meta);
  }
  console.log(`Library (${rows.length} saved graphs at ${LIBRARY_DIR}):\n`);
  const nameW = Math.max(4, ...rows.map((r) => r.name.length));
  console.log(`  ${"name".padEnd(nameW)}  nodes  edges  approvals  saved`);
  console.log(`  ${"-".repeat(nameW)}  -----  -----  ---------  ------------------------`);
  for (const r of rows) {
    const approvals = (r.requires_approval ?? []).length;
    const saved = (r.saved_at || "").replace("T", " ").slice(0, 19);
    console.log(
      `  ${r.name.padEnd(nameW)}  ${String(r.nodes).padStart(5)}  ` +
        `${String(r.edges).padStart(5)}  ${String(approvals).padStart(9)}  ${saved}`,
    );
  }
}

async function forkFromUrl(source, newName) {
  validateLibraryName(newName);
  const dir = libraryEntryDir(newName);
  if (fs.existsSync(dir)) {
    console.error(`error: library entry "${newName}" already exists at ${dir}`);
    process.exit(1);
  }

  let graphText = null;
  let paragraphText = null;
  let originDescription = source;

  // Path 1: it's already a local file.
  if (fs.existsSync(source)) {
    graphText = fs.readFileSync(source, "utf8");
    const companionPara = source.replace(/\.json$/, ".md").replace(/graph\.json$/, "paragraph.md");
    if (fs.existsSync(companionPara)) paragraphText = fs.readFileSync(companionPara, "utf8");
  } else if (/^https?:\/\//.test(source)) {
    // Path 2: HTTP(S) URL. Fetch it directly. Must be a graph.json or a
    // gist page — if it's a gist page, we try to follow the raw URL.
    graphText = await fetchUrl(source);
    try {
      JSON.parse(graphText);
    } catch {
      // Maybe a gist HTML page — scrape the raw URL.
      const rawMatch = graphText.match(/https:\/\/gist\.githubusercontent\.com\/[^"']+\/graph\.json/);
      if (rawMatch) {
        console.log(`Following raw URL: ${rawMatch[0]}`);
        graphText = await fetchUrl(rawMatch[0]);
      } else {
        console.error(`error: URL did not return JSON and no raw graph.json found in HTML`);
        process.exit(1);
      }
    }
  } else if (/^gist:/.test(source)) {
    // Path 3: gist:<id>. Use the gh CLI if available.
    const id = source.replace(/^gist:/, "");
    const result = spawnSync("gh", ["gist", "view", id, "--filename", "graph.json"], {
      encoding: "utf8",
    });
    if (result.status !== 0) {
      console.error(`error: gh gist view failed. stderr:`);
      console.error(result.stderr);
      process.exit(1);
    }
    graphText = result.stdout;
    originDescription = `gist:${id}`;
  } else {
    console.error(`error: don't know how to fork from "${source}"`);
    console.error(`       supported: local path, http(s) URL to graph.json, gist:<id>`);
    process.exit(1);
  }

  let graph;
  try {
    graph = JSON.parse(graphText);
  } catch (err) {
    console.error(`error: fetched content isn't valid JSON: ${err.message}`);
    process.exit(2);
  }
  validateGraph(graph); // reuse the compile-time validator

  fs.mkdirSync(dir, { recursive: true });
  fs.writeFileSync(path.join(dir, "graph.json"), JSON.stringify(graph, null, 2) + "\n");
  if (paragraphText) fs.writeFileSync(path.join(dir, "paragraph.md"), paragraphText);
  const meta = {
    name: newName,
    saved_at: new Date().toISOString(),
    source: "fork",
    forked_from: originDescription,
    nodes: graph.nodes.length,
    edges: graph.edges.length,
    entry: graph.entry,
    requires_approval: graph.requires_approval ?? [],
  };
  fs.writeFileSync(path.join(dir, "meta.json"), JSON.stringify(meta, null, 2) + "\n");
  console.log(`Forked "${newName}" from ${originDescription}`);
  console.log(`  ${meta.nodes} nodes, ${meta.edges} edges, entry=${meta.entry}`);
  console.log(`  Load it: betterclaw load ${newName}`);
}

function fetchUrl(url) {
  return fetch(url).then((res) => {
    if (!res.ok) throw new Error(`HTTP ${res.status} fetching ${url}`);
    return res.text();
  });
}

function loadGraphByName(name) {
  if (name === "active") return JSON.parse(readActiveGraph());
  validateLibraryName(name);
  const graphPath = path.join(libraryEntryDir(name), "graph.json");
  if (!fs.existsSync(graphPath)) {
    console.error(`error: "${name}" not found in library`);
    process.exit(1);
  }
  return JSON.parse(fs.readFileSync(graphPath, "utf8"));
}

function diffGraphs(nameA, nameB) {
  const graphA = loadGraphByName(nameA);
  const graphB = loadGraphByName(nameB);
  const mermaidA = buildDiffMermaid(graphA, graphB, "left");
  const mermaidB = buildDiffMermaid(graphB, graphA, "right");
  const htmlPath = path.join(os.tmpdir(), `betterclaw-diff-${Date.now()}.html`);
  fs.writeFileSync(htmlPath, buildDiffHtml(nameA, nameB, graphA, graphB, mermaidA, mermaidB));
  console.log(`Diff: ${nameA} ↔ ${nameB}`);
  console.log(`Opening: ${htmlPath}`);
  const opener = process.platform === "darwin" ? "open" : "xdg-open";
  spawn(opener, [htmlPath], { stdio: "ignore", detached: true }).unref();
}

function buildDiffMermaid(graph, other, side) {
  // "side" not currently used but kept for future asymmetric highlighting.
  void side;
  const shortTools = (tools) =>
    tools && tools.length > 0 ? tools.map((t) => t.replace(/^gmail_/, "")).join(" / ") : "—";
  const otherNodeIds = new Set((other.nodes ?? []).map((n) => n.id));
  const otherEdges = new Set((other.edges ?? []).map((e) => `${e.from}→${e.to}`));
  const otherNodeMap = new Map((other.nodes ?? []).map((n) => [n.id, n]));

  const lines = ["flowchart TD"];
  for (const n of graph.nodes) {
    const tagsAdded = !otherNodeIds.has(n.id);
    const otherNode = otherNodeMap.get(n.id);
    const toolsChanged =
      otherNode && JSON.stringify(otherNode.allowed_tools) !== JSON.stringify(n.allowed_tools);
    const diffLabel = tagsAdded
      ? " 🆕"
      : toolsChanged
        ? " ✏️"
        : "";
    const purpose = (n.purpose || "").replace(/"/g, "&quot;").replace(/\n/g, " ");
    const label = `<b>${n.id}${diffLabel}</b><br/>${purpose}<br/><i>tools: ${shortTools(n.allowed_tools)}</i>`;
    lines.push(`  ${n.id}["${label}"]:::${tagsAdded ? "added" : toolsChanged ? "changed" : "same"}`);
  }
  lines.push(`  start((entry))`);
  lines.push(`  start --> ${graph.entry}`);
  for (const e of graph.edges) {
    const key = `${e.from}→${e.to}`;
    if (!otherEdges.has(key)) {
      lines.push(`  ${e.from} ==>|🆕| ${e.to}`);
    } else {
      lines.push(`  ${e.from} --> ${e.to}`);
    }
  }
  lines.push(`  classDef same fill:#f5f5f5,stroke:#aaa;`);
  lines.push(`  classDef added fill:#cfe7c7,stroke:#2a7d2a,stroke-width:2px;`);
  lines.push(`  classDef changed fill:#fff3cd,stroke:#d4a700,stroke-width:2px;`);
  lines.push(`  classDef entryBadge fill:#eef,stroke:#36f,stroke-width:2px;`);
  lines.push(`  class start entryBadge;`);
  return lines.join("\n");
}

function buildDiffHtml(nameA, nameB, graphA, graphB, mermaidA, mermaidB) {
  const summarize = (g) => {
    const approvals = (g.requires_approval ?? []).join(", ") || "(none)";
    return `${g.nodes.length} nodes · ${g.edges.length} edges · entry=<code>${escapeHtml(g.entry)}</code> · approvals: ${escapeHtml(approvals)}`;
  };
  return `<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>BetterClaw — Graph diff: ${escapeHtml(nameA)} ↔ ${escapeHtml(nameB)}</title>
  <style>
