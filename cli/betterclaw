function detectVertical(paragraph) {
  const p = paragraph.toLowerCase();
  // Explicit override: "vertical: shopping" anywhere in the paragraph.
  const explicit = p.match(/vertical[:=]\s*(email|shopping|sales|travel)/);
  if (explicit) return explicit[1];

  const hit = (...terms) => terms.some((t) => p.includes(t));
  // Check specific verticals first; "email" is the catch-all fallback because
  // "email" as a bare keyword is too common (e.g. "cold email" is sales).
  if (hit("lead", "prospect", "outreach", "crm", "cold email", "sdr", "cold outreach", " sales "))
    return "sales";
  if (hit("flight", "hotel", "travel ", "trip ", "airfare", "booking", "itinerary", "airport"))
    return "travel";
  if (hit("wireless mouse", "headphones", "shop ", "buy ", "purchase", "product", "catalog", "price compare", "electronics store", "online store", "smartwatch", "add to cart"))
    return "shopping";
  if (hit("inbox", "gmail", "draft reply", "triage my inbox", "newsletters", "my email", "my inbox", "emails from"))
    return "email";
  // default catch-all: email is our most mature vertical
  return "email";
}

