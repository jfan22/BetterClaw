function compileWithClaude(prompt) {
  console.log("Compiling with Claude (claude-cli, opus)...");
  const result = spawnSync("claude", ["-p", prompt, "--output-format", "text"], {
    encoding: "utf8",
    maxBuffer: 10 * 1024 * 1024,
  });
  if (result.status !== 0) {
    console.error("claude CLI failed:");
    console.error(result.stderr);
    process.exit(3);
  }
  const raw = result.stdout;
  // Extract the first JSON object from the output (Claude sometimes adds
  // explanation despite instructions).
  const jsonMatch = raw.match(/\{[\s\S]*\}/);
  if (!jsonMatch) {
    console.error("No JSON found in Claude response:");
    console.error(raw);
    process.exit(4);
  }
  try {
    return JSON.parse(jsonMatch[0]);
  } catch (err) {
    console.error(`Invalid JSON from compiler: ${err.message}`);
    console.error("\nRaw:");
    console.error(jsonMatch[0]);
    process.exit(5);
  }
}

async function renderAndConfirm(graph, paragraph) {
  const mermaid = buildMermaid(graph);
  const headless = !process.env.DISPLAY && !process.env.BROWSER;

  if (headless) {
    console.log("  " + dim("headless — Mermaid source:"));
    console.log(mermaid.split("\n").map((l) => "    " + gray(l)).join("\n"));
  } else {
    const htmlPath = writeHtml(graph, paragraph, mermaid);
    console.log(`  ${accent("→")} ${bold("Opened in browser:")} ${gray(htmlPath)}`);
    const opener = process.platform === "darwin" ? "open" : "xdg-open";
    spawn(opener, [htmlPath], { stdio: "ignore", detached: true }).unref();
  }

  const rl = readline.createInterface({ input: process.stdin, output: process.stdout });
  const answer = await new Promise((resolve) =>
    rl.question("\n  " + bold("Approve this workflow?") + dim(" (y/N) "), (a) => {
      rl.close();
      resolve(a.trim().toLowerCase());
    }),
  );
  return answer === "y" || answer === "yes";
}

function buildMermaid(graph) {
  const lines = ["flowchart TD"];
  const shortTools = (tools) =>
    tools.length > 0 ? tools.map((t) => t.replace(/^gmail_/, "")).join(" / ") : "—";

  // Nodes: "id[purpose<br/>tools]"
  for (const n of graph.nodes) {
    const purpose = n.purpose.replace(/"/g, "&quot;").replace(/\n/g, " ");
    const label = `<b>${n.id}</b><br/>${purpose}<br/><i>tools: ${shortTools(n.allowed_tools)}</i>`;
    lines.push(`  ${n.id}["${label}"]`);
  }
  // Entry marker
  lines.push(`  start((entry))`);
  lines.push(`  start --> ${graph.entry}`);
  // Edges
  for (const e of graph.edges) {
    lines.push(`  ${e.from} --> ${e.to}`);
  }
  // Style entry node
  lines.push(`  classDef entryBadge fill:#eef,stroke:#36f,stroke-width:2px;`);
  lines.push(`  class start entryBadge;`);
  return lines.join("\n");
}

