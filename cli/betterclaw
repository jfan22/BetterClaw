#!/usr/bin/env node
// betterclaw CLI — compile an English paragraph into a BetterClaw workflow
// graph and write it to the plugin's active-graph.json.
//
// Usage:
//   betterclaw "triage my inbox: flag investors, draft replies for customers"
//   betterclaw --show           # print current graph
//   betterclaw --help

import fs from "node:fs";
import http from "node:http";
import os from "node:os";
import path from "node:path";
import readline from "node:readline";
import { spawnSync, spawn } from "node:child_process";
import { fileURLToPath } from "node:url";

const __filename = fileURLToPath(import.meta.url);
const __dirname = path.dirname(__filename);
const PLUGIN_ROOT = path.resolve(__dirname, "../plugins/betterclaw");
const GRAPH_PATH = path.join(PLUGIN_ROOT, "active-graph.json");
const PARAGRAPH_PATH = path.join(PLUGIN_ROOT, "active-paragraph.md");
const RUN_LOG_PATH = path.join(PLUGIN_ROOT, "run.jsonl");
const APPROVALS_DIR = path.join(PLUGIN_ROOT, "approvals");
const LIBRARY_DIR = path.join(os.homedir(), ".betterclaw", "library");

const VERTICAL_GUIDANCE = {
  email: {
    description: "Gmail triage — search, read, draft replies.",
    tools: ["gmail_search", "gmail_read", "gmail_draft"],
    rules: [
      `The entry node's allowed_tools MUST include "gmail_search".`,
      `Reading ("gmail_read") must come after searching.`,
      `Drafting ("gmail_draft") must come after reading.`,
    ],
    tool_descriptions: `- gmail_search: search/list emails (Gmail query syntax: "in:inbox", "from:x@y", "is:unread")
- gmail_read: read one email's full content by message ID
- gmail_draft: create a draft reply (never sends)`,
  },
  shopping: {
    description: "Online shopping — search product catalog, inspect details, compare options.",
    tools: ["shop_search", "shop_details", "shop_compare"],
    rules: [
      `The entry node's allowed_tools MUST include "shop_search".`,
      `Fetching details ("shop_details") must come after searching.`,
      `Comparing ("shop_compare") must come after you have at least two candidates.`,
    ],
    tool_descriptions: `- shop_search: search catalog by keywords; optional max price + category filter
- shop_details: fetch full record for one product by id
- shop_compare: side-by-side of two products`,
  },
  sales: {
    description: "Sales — find leads, enrich, draft personalized outreach.",
    tools: ["sales_find_leads", "sales_enrich", "sales_draft_outreach"],
    rules: [
      `The entry node's allowed_tools MUST include "sales_find_leads".`,
      `Enriching ("sales_enrich") must come after finding leads.`,
      `Drafting outreach ("sales_draft_outreach") must come after enriching — never blind-spam.`,
    ],
    tool_descriptions: `- sales_find_leads: filter lead catalog by industry / size / keyword
- sales_enrich: fetch full detail for one lead
- sales_draft_outreach: compose personalized outreach email for one lead`,
  },
  travel: {
    description: "Travel — flight + hotel search, comparison.",
    tools: ["travel_search_flights", "travel_search_hotels", "travel_compare_flights"],
    rules: [
      `The entry node's allowed_tools MUST include one of "travel_search_flights" or "travel_search_hotels".`,
      `Comparing ("travel_compare_flights") must come after searching has returned candidates.`,
    ],
    tool_descriptions: `- travel_search_flights: find flights between two airports (3-letter codes), optional max price
- travel_search_hotels: find hotels in a city, optional max price/night and min rating
- travel_compare_flights: side-by-side comparison of two flight ids`,
  },
};

const args = process.argv.slice(2);

if (args[0] === "--version" || args[0] === "-v") {
  const pkgPath = path.resolve(__dirname, "..", "package.json");
  try {
    const v = JSON.parse(fs.readFileSync(pkgPath, "utf8")).version;
    console.log(`betterclaw ${v}`);
  } catch {
    console.log(`betterclaw (version unknown)`);
  }
  process.exit(0);
}

if (args.length === 0 || args[0] === "--help" || args[0] === "-h") {
  printHelp();
  process.exit(0);
}

if (args[0] === "--show") {
  if (!fs.existsSync(GRAPH_PATH)) {
    console.log(`No graph at ${GRAPH_PATH}`);
    process.exit(1);
  }
  console.log(fs.readFileSync(GRAPH_PATH, "utf8"));
  process.exit(0);
}

if (args[0] === "view" || args[0] === "--view") {
  const watch = args.includes("--watch") || args.includes("-w");
  if (watch) {
    await startWatchServer();
  } else {
    viewLastRun();
  }
  process.exit(0);
}

if (args[0] === "approve" || args[0] === "deny") {
  const decision = args[0];
  const id = args[1];
  if (!id) {
    console.error(`Usage: betterclaw ${decision} <id>`);
    process.exit(1);
  }
  resolveApproval(id, decision);
  process.exit(0);
}

if (args[0] === "pending") {
  listPending();
  process.exit(0);
}

if (args[0] === "doctor") {
  runDoctor();
  process.exit(0);
}

if (args[0] === "save") {
  if (!args[1]) {
    console.error("Usage: betterclaw save <name>");
    process.exit(1);
  }
  saveToLibrary(args[1]);
  process.exit(0);
}

if (args[0] === "load") {
  if (!args[1]) {
    console.error("Usage: betterclaw load <name>");
    process.exit(1);
  }
  loadFromLibrary(args[1]);
  process.exit(0);
}

if (args[0] === "list") {
  listLibrary();
  process.exit(0);
}

if (args[0] === "fork") {
  if (!args[1] || !args[2]) {
    console.error("Usage: betterclaw fork <url-or-gist-id> <new-name>");
    process.exit(1);
  }
  await forkFromUrl(args[1], args[2]);
  process.exit(0);
}

if (args[0] === "diff") {
  if (!args[1] || !args[2]) {
    console.error("Usage: betterclaw diff <a> <b>  (names from the library, or 'active')");
    process.exit(1);
  }
  diffGraphs(args[1], args[2]);
  process.exit(0);
}

if (args[0] === "publish") {
  if (!args[1]) {
    console.error("Usage: betterclaw publish <name>  [--to gist]");
    process.exit(1);
  }
  const dest = args[args.indexOf("--to") + 1] === "gist" ? "gist" : null;
  await publishToRemote(args[1], dest);
  process.exit(0);
}

const paragraph = args.join(" ").trim();
if (!paragraph) {
  console.error("Usage: betterclaw \"<paragraph>\"");
  process.exit(1);
}

preflightCheck();

const verticalId = detectVertical(paragraph);
console.log(`Detected vertical: ${verticalId}`);
const prompt = buildCompilePrompt(paragraph, verticalId);
const graph = compileWithClaude(prompt);
if (!graph.vertical) graph.vertical = verticalId; // belt + suspenders
validateGraph(graph);

console.log(`\nCompiled workflow graph:`);
console.log(`  vertical: ${graph.vertical}`);
console.log(`  entry: ${graph.entry}`);
console.log(`  nodes: ${graph.nodes.length} (${graph.nodes.map((n) => n.id).join(", ")})`);
console.log(`  edges: ${graph.edges.length}`);
console.log(`  max_reconsider_retries: ${graph.max_reconsider_retries ?? 3}`);
const approvals = Array.isArray(graph.requires_approval) ? graph.requires_approval : [];
console.log(
  `  requires_approval: ${approvals.length > 0 ? approvals.join(", ") : "(none — all tool calls autorun)"}`,
);

const approved = await renderAndConfirm(graph, paragraph);
if (!approved) {
  console.log("\nAborted — graph not written. Re-run with a different paragraph to try again.");
  process.exit(0);
}

fs.writeFileSync(GRAPH_PATH, JSON.stringify(graph, null, 2) + "\n");
fs.writeFileSync(PARAGRAPH_PATH, paragraph + "\n");
console.log(`\nWritten to: ${GRAPH_PATH}`);
console.log(
  `\nNext: run \`openclaw agent --local --agent main -m "<your task>"\` — the plugin will load the new graph on the next agent turn.`,
);

// ---- helpers ----

function runDoctor() {
  const checks = [];

  // Node version
  const [maj] = process.versions.node.split(".").map(Number);
  checks.push({
    name: "Node >= 22",
    ok: maj >= 22,
    detail: `current: v${process.versions.node}`,
    fix: "nvm install 22 && nvm use 22 && nvm alias default 22",
  });

  // openclaw CLI on PATH
  const oc = spawnSync("openclaw", ["--version"], { encoding: "utf8" });
  checks.push({
    name: "openclaw CLI installed",
    ok: oc.status === 0,
    detail: oc.status === 0 ? oc.stdout.split("\n")[0] : "not found",
    fix: "npm install -g openclaw@latest",
  });

  // BetterClaw plugin loaded
  const inspect = spawnSync("openclaw", ["plugins", "inspect", "betterclaw"], { encoding: "utf8" });
  const pluginOk = inspect.status === 0 && /Status:\s*loaded/.test(inspect.stdout);
  checks.push({
    name: "BetterClaw plugin loaded",
    ok: pluginOk,
    detail: pluginOk
      ? "loaded"
      : inspect.status === 0
        ? "installed but not loaded — run `openclaw config set plugins.allow '[\"betterclaw\"]'`"
        : "not installed",
    fix: `openclaw plugins install ${PLUGIN_ROOT} --link --dangerously-force-unsafe-install && openclaw config set plugins.allow '["betterclaw"]'`,
  });

  // Claude CLI auth profile
  const profilesPath = path.join(os.homedir(), ".openclaw", "agents", "main", "agent", "auth-profiles.json");
  let authOk = false;
  try {
    const profiles = JSON.parse(fs.readFileSync(profilesPath, "utf8"));
    authOk = JSON.stringify(profiles).includes("claude");
  } catch {}
  checks.push({
    name: "Claude CLI auth profile registered",
    ok: authOk,
    detail: authOk ? "present" : `missing ${profilesPath}`,
    fix: "openclaw models auth login --provider anthropic --method cli --set-default",
  });

  // Active graph
  const graphOk = fs.existsSync(GRAPH_PATH) && fs.statSync(GRAPH_PATH).size > 0;
  let vertical = null;
  if (graphOk) {
    try {
      vertical = JSON.parse(fs.readFileSync(GRAPH_PATH, "utf8")).vertical ?? "(none)";
    } catch {}
  }
  checks.push({
    name: "active-graph.json present",
    ok: graphOk,
    detail: graphOk ? `vertical=${vertical}` : "no graph compiled yet",
    fix: `betterclaw "<your task>"`,
  });

  // Email-specific checks (only warn — email is optional)
  const gmailCredOk = fs.existsSync(path.join(os.homedir(), ".gmail-mcp", "credentials.json"));
  checks.push({
    name: "Gmail OAuth credentials (optional)",
    ok: gmailCredOk,
    detail: gmailCredOk ? "~/.gmail-mcp/credentials.json present" : "missing (only needed for email vertical)",
    fix: "See QUICKSTART.md §3 for Gmail setup.",
    optional: !gmailCredOk,
  });

  // Stale day-1 gmail-mcp bundle — warn if both present (old conflict)
  const bundlePath = path.join(os.homedir(), ".openclaw", "extensions", "gmail-mcp");
  const bundlePresent = fs.existsSync(bundlePath);
  if (bundlePresent) {
    const bundleStatus = spawnSync("openclaw", ["plugins", "inspect", "gmail-mcp"], { encoding: "utf8" });
    const bundleLoaded = /Status:\s*loaded/.test(bundleStatus.stdout);
    checks.push({
      name: "Day-1 gmail-mcp bundle (should be disabled)",
      ok: !bundleLoaded,
      detail: bundleLoaded
        ? "LOADED — this will shadow BetterClaw's email enforcement!"
        : "disabled (good)",
      fix: "openclaw plugins disable gmail-mcp",
    });
  }

  // Report
  const pad = Math.max(...checks.map((c) => c.name.length));
  let allGreen = true;
  for (const c of checks) {
    const mark = c.ok ? "✓" : c.optional ? "·" : "✗";
    if (!c.ok && !c.optional) allGreen = false;
    console.log(`${mark} ${c.name.padEnd(pad)}  ${c.detail}`);
    if (!c.ok) console.log(`    fix: ${c.fix}`);
  }

  console.log("");
  if (allGreen) {
    console.log("All checks passed.");
  } else {
    console.log("Some required checks failed. See `fix:` hints above.");
    process.exit(1);
  }
}

