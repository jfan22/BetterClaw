function escapeHtml(s) {
  return String(s)
    .replace(/&/g, "&amp;")
    .replace(/</g, "&lt;")
    .replace(/>/g, "&gt;")
    .replace(/"/g, "&quot;");
}

function validateGraph(graph) {
  const errors = [];

  if (typeof graph.entry !== "string") errors.push("entry must be a string");
  if (!Array.isArray(graph.nodes) || graph.nodes.length === 0)
    errors.push("nodes must be a non-empty array");
  if (!Array.isArray(graph.edges)) errors.push("edges must be an array");

  if (errors.length > 0) {
    console.error("Graph validation failed:");
    for (const e of errors) console.error("  -", e);
    process.exit(6);
  }

  const nodeIds = new Set(graph.nodes.map((n) => n.id));

  // Allowed tools depend on the graph's declared vertical. Default to email
  // for back-compat with older graphs that predate the vertical field.
  const vId = graph.vertical ?? "email";
  const vGuidance = VERTICAL_GUIDANCE[vId];
  if (!vGuidance) errors.push(`unknown vertical "${vId}"`);
  const allowedTools = new Set(vGuidance ? vGuidance.tools : []);

  for (const n of graph.nodes) {
    if (typeof n.id !== "string") errors.push(`node missing id: ${JSON.stringify(n)}`);
    if (typeof n.purpose !== "string") errors.push(`node "${n.id}" missing purpose`);
    if (!Array.isArray(n.allowed_tools) || n.allowed_tools.length === 0)
      errors.push(`node "${n.id}" has empty allowed_tools`);
    for (const t of n.allowed_tools ?? []) {
      if (!allowedTools.has(t))
        errors.push(`node "${n.id}" references unknown tool "${t}" (allowed: ${[...allowedTools].join(", ")})`);
    }
  }

  if (!nodeIds.has(graph.entry)) errors.push(`entry "${graph.entry}" is not a node id`);

  for (const e of graph.edges) {
    if (!nodeIds.has(e.from)) errors.push(`edge from unknown node "${e.from}"`);
    if (!nodeIds.has(e.to)) errors.push(`edge to unknown node "${e.to}"`);
  }

  if (graph.requires_approval !== undefined) {
    if (!Array.isArray(graph.requires_approval)) {
      errors.push("requires_approval must be an array of tool names");
    } else {
      for (const t of graph.requires_approval) {
        if (!allowedTools.has(t))
          errors.push(`requires_approval references unknown tool "${t}"`);
      }
    }
  }

  if (errors.length > 0) {
    console.error("Graph validation failed:");
    for (const e of errors) console.error("  -", e);
    console.error("\nGraph:");
    console.error(JSON.stringify(graph, null, 2));
    process.exit(7);
  }
}
