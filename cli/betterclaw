    @keyframes pulse { 50% { opacity: 0.4; } }
    .approval-banner { background: #fff3cd; border: 1px solid #d4a700; border-left: 4px solid #d4a700; padding: 1rem 1.2rem; margin: 0 0 1.5rem; border-radius: 4px; }
    .approval-banner h3 { margin: 0 0 0.5rem; font-size: 1rem; color: #664d03; }
    .approval-banner .params { background: #fff; padding: 0.5rem 0.75rem; border-radius: 3px; font-family: ui-monospace, monospace; font-size: 0.8rem; white-space: pre-wrap; max-height: 150px; overflow: auto; margin: 0.5rem 0; }
    .approval-banner .buttons { display: flex; gap: 0.5rem; margin-top: 0.5rem; }
    .approval-banner button { padding: 0.4rem 1rem; border: 0; border-radius: 4px; font-weight: 600; cursor: pointer; font-size: 0.9rem; }
    .approval-banner button.approve { background: #2a7d2a; color: #fff; }
    .approval-banner button.deny { background: #8a0000; color: #fff; }
    .approval-banner button:disabled { opacity: 0.5; cursor: not-allowed; }
    .layout { display: grid; grid-template-columns: 1.3fr 1fr; gap: 1.5rem; }
    .mermaid-wrap { background: #fff; border: 1px solid #ddd; padding: 1.5rem; border-radius: 4px; overflow: auto; min-height: 360px; }
    table { width: 100%; border-collapse: collapse; background: #fff; border: 1px solid #ddd; border-radius: 4px; overflow: hidden; }
    th, td { padding: 0.5rem 0.75rem; text-align: left; border-bottom: 1px solid #eee; font-size: 0.85rem; vertical-align: top; }
    th { background: #f5f5f5; font-weight: 600; color: #444; }
    tr.dev td { background: #fff7f7; }
    tr.fresh td { background: #ffffd0; transition: background 2s; }
    code { background: #f0f0f0; padding: 0 0.25em; border-radius: 3px; font-family: ui-monospace, monospace; }
    .meta { color: #666; font-size: 0.85rem; margin-top: 1.5rem; text-align: center; }
  </style>
  <script src="https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.min.js"></script>
</head>
<body>
  <h1>BetterClaw — Live run <span class="chip live" id="live-chip">LIVE</span></h1>
  <p class="sub">Green = visited · bold edge = traversed · dashed red = attempted deviation.<br>Polling <code>/state.json</code> every 500ms.</p>

  <div class="summary">
    <span class="chip allow" id="allowChip">0 allowed</span>
    <span class="chip dev" id="devChip">0 deviations</span>
    <span id="graphMeta" style="color:#666;"></span>
  </div>

  <div id="approvals"></div>

  <div class="layout">
    <div class="mermaid-wrap" id="diagram"></div>
    <div>
      <table>
        <thead><tr><th>time</th><th>node</th><th>tool</th><th>detail</th></tr></thead>
        <tbody id="timeline"></tbody>
      </table>
    </div>
  </div>

  <p class="meta" id="lastUpdate">—</p>

<script>
  mermaid.initialize({ startOnLoad: false, theme: "default", flowchart: { useMaxWidth: false, curve: "basis" } });

  let lastEventCount = -1;
  let lastDiagramSig = "";
  let renderSeq = 0;

  async function tick() {
    try {
      const res = await fetch("/state.json", { cache: "no-store" });
      if (!res.ok) return;
      const state = await res.json();
      await render(state);
    } catch (err) {
      // server might be starting up or restarting — retry silently
    }
  }

  function escapeHtml(s) {
    return String(s).replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;").replace(/"/g,"&quot;");
  }

  function shortTools(ts) {
    if (!ts || ts.length === 0) return "—";
    return ts.map(t => t.replace(/^gmail_/,"")).join(" / ");
  }

  async function render(state) {
    const { graph, events } = state;
    const allow = events.filter(e => e.type === "allow");
    const dev = events.filter(e => e.type === "deviation");

    document.getElementById("allowChip").textContent = allow.length + " allowed";
    document.getElementById("devChip").textContent = dev.length + " deviation" + (dev.length === 1 ? "" : "s");
    document.getElementById("graphMeta").innerHTML = "entry: <code>" + escapeHtml(graph.entry) + "</code> · " + graph.nodes.length + " nodes · " + graph.edges.length + " edges";

    // Collect pending approvals (pending minus resolved).
    const pendingMap = new Map();
    for (const e of events) {
      if (e.type === "approval_pending") pendingMap.set(e.id, e);
      if (e.type === "approval_resolved") pendingMap.delete(e.id);
    }
    renderApprovals([...pendingMap.values()]);

    // Mermaid signature — only re-render when it changes (avoid flicker)
    const visited = new Set(allow.flatMap(e => [e.from_node, e.to_node]).filter(Boolean));
    const traversed = new Set();
    for (const e of allow) if (e.transitioned) traversed.add(e.from_node + "→" + e.to_node);
    const sig = JSON.stringify({
      g: graph,
      v: [...visited].sort(),
      t: [...traversed].sort(),
      d: dev.map(d => ({ n: d.from_node, t: d.attempted_tool }))
    });
    if (sig !== lastDiagramSig) {
      lastDiagramSig = sig;
      const mermaid_src = buildMermaidSource(graph, visited, traversed, dev);
      const id = "diagram-svg-" + (++renderSeq);
      try {
        const out = await mermaid.render(id, mermaid_src);
        document.getElementById("diagram").innerHTML = out.svg;
      } catch (err) {
        document.getElementById("diagram").textContent = "mermaid render error: " + err.message;
      }
    }

    // Timeline — highlight new rows briefly
    const tbody = document.getElementById("timeline");
    const rowsHtml = events
      .filter(e => e.type === "allow" || e.type === "deviation")
      .map((e, i) => {
        const ts = e.ts ? e.ts.split("T")[1].slice(0, 12) : "";
        const fresh = (i >= lastEventCount && lastEventCount >= 0) ? " fresh" : "";
        if (e.type === "deviation") {
          return "<tr class=\\"dev" + fresh + "\\"><td>" + ts + "</td><td><code>" + escapeHtml(e.from_node ?? "") + "</code></td><td>❌ <code>" + escapeHtml(e.attempted_tool ?? "") + "</code></td><td>retry " + e.retry + "/" + e.retry_limit + " — " + escapeHtml(String(e.reason ?? "").slice(0, 120)) + "…</td></tr>";
        }
        const arrow = e.transitioned
          ? escapeHtml(e.from_node) + " → " + escapeHtml(e.to_node)
          : "(stay in " + escapeHtml(e.from_node) + ")";
        return "<tr class=\\"" + fresh.trim() + "\\"><td>" + ts + "</td><td><code>" + escapeHtml(e.to_node ?? e.from_node ?? "") + "</code></td><td>✓ <code>" + escapeHtml(e.tool ?? "") + "</code></td><td>" + arrow + "</td></tr>";
      })
      .join("");
    tbody.innerHTML = rowsHtml;
    lastEventCount = allow.length + dev.length;

    document.getElementById("lastUpdate").textContent = "Last poll: " + new Date().toLocaleTimeString();
  }

  function buildMermaidSource(graph, visitedNodes, traversedEdges, deviationEvents) {
    const devsByNode = new Map();
    for (const d of deviationEvents) {
      if (!devsByNode.has(d.from_node)) devsByNode.set(d.from_node, []);
      devsByNode.get(d.from_node).push(d.attempted_tool);
    }
    const lines = ["flowchart TD"];
    for (const n of graph.nodes) {
      const purpose = (n.purpose || "").replace(/"/g,"&quot;").replace(/\\n/g," ");
      const devs = devsByNode.get(n.id);
      const devSuffix = devs ? "<br/><b style='color:#c00;'>deviations: " + devs.length + "</b>" : "";
      const label = "<b>" + n.id + "</b><br/>" + purpose + "<br/><i>tools: " + shortTools(n.allowed_tools) + "</i>" + devSuffix;
      lines.push("  " + n.id + "[\\"" + label + "\\"]");
    }
    lines.push("  start((entry))");
    lines.push("  start --> " + graph.entry);
    for (const e of graph.edges) {
      const key = e.from + "→" + e.to;
      lines.push("  " + e.from + (traversedEdges.has(key) ? " ==> " : " --> ") + e.to);
    }
    let p = 0;
    for (const d of deviationEvents) {
      const tool = (d.attempted_tool || "unknown").replace(/^gmail_/,"");
      lines.push("  devghost" + p + "([\\"❌ " + tool + "<br/>(deviation)\\"]):::devbox");
      lines.push("  " + d.from_node + " -.-> devghost" + p);
      p++;
    }
    lines.push("  classDef visited fill:#cfe7c7,stroke:#2a7d2a,stroke-width:2px;");
    lines.push("  classDef devbox fill:#fde0e0,stroke:#c00,stroke-width:1px,stroke-dasharray:4 2;");
    lines.push("  classDef entryBadge fill:#eef,stroke:#36f,stroke-width:2px;");
    lines.push("  class start entryBadge;");
    const visitedList = [...visitedNodes].filter(n => graph.nodes.some(gn => gn.id === n));
    if (visitedList.length > 0) lines.push("  class " + visitedList.join(",") + " visited;");
    return lines.join("\\n");
  }

  function renderApprovals(pending) {
    const host = document.getElementById("approvals");
    if (pending.length === 0) { host.innerHTML = ""; return; }
    host.innerHTML = pending.map(p => {
      const paramsStr = p.params ? JSON.stringify(p.params, null, 2) : "(no params)";
      return "<div class=\\"approval-banner\\" data-id=\\"" + escapeHtml(p.id) + "\\">" +
        "<h3>⏸ Waiting for approval: <code>" + escapeHtml(p.tool) + "</code> at <code>" + escapeHtml(p.node) + "</code></h3>" +
        "<div>id: <code>" + escapeHtml(p.id) + "</code></div>" +
        "<div class=\\"params\\">" + escapeHtml(paramsStr) + "</div>" +
        "<div class=\\"buttons\\">" +
          "<button class=\\"approve\\" onclick=\\"resolveApproval('" + p.id + "','approve',this)\\">Approve</button>" +
          "<button class=\\"deny\\" onclick=\\"resolveApproval('" + p.id + "','deny',this)\\">Deny</button>" +
        "</div>" +
      "</div>";
    }).join("");
  }

  async function resolveApproval(id, decision, btn) {
    const card = btn.closest(".approval-banner");
    card.querySelectorAll("button").forEach(b => b.disabled = true);
    try {
      const res = await fetch("/resolve", {
        method: "POST",
        headers: { "content-type": "application/json" },
        body: JSON.stringify({ id, decision }),
      });
      if (!res.ok) {
        card.querySelectorAll("button").forEach(b => b.disabled = false);
        alert("Resolve failed: " + res.status);
      }
      // The agent will pick it up on its next 200ms poll; the next tick() here
      // removes this banner from the UI when the resolved event arrives.
    } catch (err) {
      card.querySelectorAll("button").forEach(b => b.disabled = false);
      alert("Resolve failed: " + err.message);
    }
  }
  window.resolveApproval = resolveApproval;

  tick();
  setInterval(tick, 500);
</script>
</body>
</html>`;
}

function buildReplayMermaid(graph, visitedNodes, traversedEdges, deviationEvents) {
  const shortTools = (tools) =>
    tools.length > 0 ? tools.map((t) => t.replace(/^gmail_/, "")).join(" / ") : "—";
  const deviationsByNode = new Map();
  for (const d of deviationEvents) {
    if (!deviationsByNode.has(d.from_node)) deviationsByNode.set(d.from_node, []);
    deviationsByNode.get(d.from_node).push(d.attempted_tool);
  }

  const lines = ["flowchart TD"];
  for (const n of graph.nodes) {
    const purpose = n.purpose.replace(/"/g, "&quot;").replace(/\n/g, " ");
    const devs = deviationsByNode.get(n.id);
    const devSuffix = devs
      ? `<br/><b style='color:#c00;'>deviations: ${devs.length}</b>`
      : "";
    const label = `<b>${n.id}</b><br/>${purpose}<br/><i>tools: ${shortTools(n.allowed_tools)}</i>${devSuffix}`;
    lines.push(`  ${n.id}["${label}"]`);
  }
  lines.push(`  start((entry))`);
  lines.push(`  start --> ${graph.entry}`);

  // Edges: bold if traversed, else normal
  for (const e of graph.edges) {
    const key = `${e.from}→${e.to}`;
    if (traversedEdges.has(key)) {
      lines.push(`  ${e.from} ==> ${e.to}`);
    } else {
      lines.push(`  ${e.from} --> ${e.to}`);
    }
  }

  // Deviation ghost arrows — dashed red from the current node to a phantom.
  let phantomIdx = 0;
  for (const d of deviationEvents) {
    const phantom = `devghost${phantomIdx++}`;
    const tool = (d.attempted_tool || "unknown").replace(/^gmail_/, "");
    lines.push(
      `  ${phantom}(["❌ ${tool}<br/>(deviation)"]):::devbox`,
    );
    lines.push(`  ${d.from_node} -.-> ${phantom}`);
  }

  // Styling
  lines.push(`  classDef visited fill:#cfe7c7,stroke:#2a7d2a,stroke-width:2px;`);
  lines.push(`  classDef devbox fill:#fde0e0,stroke:#c00,stroke-width:1px,stroke-dasharray:4 2;`);
  lines.push(`  classDef entryBadge fill:#eef,stroke:#36f,stroke-width:2px;`);
  lines.push(`  class start entryBadge;`);
  const visitedList = [...visitedNodes].filter((n) => graph.nodes.some((gn) => gn.id === n));
  if (visitedList.length > 0) {
    lines.push(`  class ${visitedList.join(",")} visited;`);
  }
  return lines.join("\n");
}

