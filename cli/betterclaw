// Cross-turn history log. Unlike run.jsonl (per-turn, truncated on each
// plugin boot), this is append-only and survives across agent turns. The
// plugin's before_prompt_build hook reads from it to surface recent
// approvals back to the agent, so it can avoid re-drafting things the user
// already handled.
const HISTORY_PATH = path.join(os.homedir(), ".betterclaw", "history.jsonl");
function appendHistory(event) {
  try {
    fs.mkdirSync(path.dirname(HISTORY_PATH), { recursive: true });
    fs.appendFileSync(HISTORY_PATH, JSON.stringify(event) + "\n");
  } catch {}
}

// Terminal styling. Matches the HTML design language: dim for secondary,
// green=allow, red=deny, yellow=pending, cyan=accent/meta, bold for command
// names and page titles. Respects NO_COLOR and non-TTY (pipes get plain text).
const ANSI = {
  reset:   "\x1b[0m",
  bold:    "\x1b[1m",
  dim:     "\x1b[2m",
  italic:  "\x1b[3m",
  ink:     "\x1b[0m",
  dimgray: "\x1b[90m",
  accent:  "\x1b[36m",
  allow:   "\x1b[32m",
  deny:    "\x1b[31m",
  pending: "\x1b[33m",
};
const NO_COLOR = !process.stdout.isTTY || process.env.NO_COLOR;
const wrap = (code) => (text) => (NO_COLOR ? text : `${code}${text}${ANSI.reset}`);
const bold    = wrap(ANSI.bold);
const dim     = wrap(ANSI.dim);
const italic  = wrap(ANSI.italic);
const accent  = wrap(ANSI.accent);
const allow   = wrap(ANSI.allow);
const deny    = wrap(ANSI.deny);
const pending = wrap(ANSI.pending);
const gray    = wrap(ANSI.dimgray);

const ui = {
  // Small-caps-like kicker (dim uppercase) — matches HTML kicker line.
  kicker(text) { return dim(text.toUpperCase()); },
  // Big title: bold.
  title(text) { return bold(text); },
  // Section label: dim uppercase with a bit of space before it.
  section(text) { return "\n" + dim(text.toUpperCase()); },
  // Subtle hairline rule.
  hr(width = 56) { return dim("─".repeat(width)); },
  // Inline chip in [brackets] with optional color.
  chip(text, color) {
    const label = `[${text}]`;
    if (color === "allow")   return allow(label);
    if (color === "deny")    return deny(label);
    if (color === "pending") return pending(label);
    if (color === "accent")  return accent(label);
    return dim(label);
  },
};

