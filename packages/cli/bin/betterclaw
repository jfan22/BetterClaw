// ---- library / marketplace ----

function validateLibraryName(name) {
  if (!/^[a-z0-9][a-z0-9-_]{0,63}$/i.test(name)) {
    console.error(`error: invalid library name "${name}". Use letters, digits, dashes, underscores; 1-64 chars.`);
    process.exit(1);
  }
}

function libraryEntryDir(name) {
  return path.join(LIBRARY_DIR, name);
}

function readActiveGraph() {
  if (!fs.existsSync(GRAPH_PATH)) {
    console.error(`error: no active graph at ${GRAPH_PATH}`);
    console.error(`       Compile one first: betterclaw "<paragraph>"`);
    process.exit(1);
  }
  return fs.readFileSync(GRAPH_PATH, "utf8");
}

function readActiveParagraph() {
  if (fs.existsSync(PARAGRAPH_PATH)) return fs.readFileSync(PARAGRAPH_PATH, "utf8");
  return "(paragraph not recorded — this graph was compiled before paragraph persistence shipped)\n";
}

function saveToLibrary(name) {
  validateLibraryName(name);
  const graphText = readActiveGraph();
  const paragraphText = readActiveParagraph();
  const dir = libraryEntryDir(name);
  fs.mkdirSync(dir, { recursive: true });
  fs.writeFileSync(path.join(dir, "graph.json"), graphText);
  fs.writeFileSync(path.join(dir, "paragraph.md"), paragraphText);
  const graph = JSON.parse(graphText);
  const meta = {
    name,
    saved_at: new Date().toISOString(),
    source: "active",
    nodes: graph.nodes?.length ?? 0,
    edges: graph.edges?.length ?? 0,
    entry: graph.entry ?? null,
    requires_approval: graph.requires_approval ?? [],
  };
  fs.writeFileSync(path.join(dir, "meta.json"), JSON.stringify(meta, null, 2) + "\n");
  console.log();
  console.log(`  ${allow("✓")} ${bold("Saved to library")}  ${gray(dir)}`);
  console.log(`    ${dim("summary:")} ${meta.nodes} nodes, ${meta.edges} edges, entry=${meta.entry}`);
  if (meta.requires_approval.length > 0) {
    console.log(`    ${dim("approvals:")} ${meta.requires_approval.map((t) => ui.chip(t, "pending")).join(" ")}`);
  }
  console.log();
}

function loadFromLibrary(name) {
  validateLibraryName(name);
  const dir = libraryEntryDir(name);
  const graphPath = path.join(dir, "graph.json");
  if (!fs.existsSync(graphPath)) {
    console.error("  " + deny("✗") + "  library entry " + bold(name) + " not found");
    console.error("    " + gray(dir));
    process.exit(1);
  }
  fs.copyFileSync(graphPath, GRAPH_PATH);
  const paraPath = path.join(dir, "paragraph.md");
  if (fs.existsSync(paraPath)) fs.copyFileSync(paraPath, PARAGRAPH_PATH);
  const meta = JSON.parse(fs.readFileSync(path.join(dir, "meta.json"), "utf8"));
  console.log();
  console.log(`  ${allow("✓")} ${bold("Loaded")} ${accent(name)} ${dim("as active graph.")}`);
  console.log(`    ${dim("summary:")} ${meta.nodes} nodes, ${meta.edges} edges, entry=${meta.entry}`);
  if (meta.forked_from) console.log(`    ${dim("forked from:")} ${gray(meta.forked_from)}`);
  console.log();
  console.log("  " + dim("Next:"));
  console.log("    " + accent(`betterclaw run "<task>"`));
  console.log();
}

function listLibrary() {
  console.log();
  console.log("  " + ui.kicker("BetterClaw · Library"));
  console.log("  " + ui.hr());
  if (!fs.existsSync(LIBRARY_DIR)) {
    console.log("  " + dim("No saved graphs yet."));
    console.log("  " + dim("Library dir: ") + gray(LIBRARY_DIR));
    console.log();
    return;
  }
  const entries = fs
    .readdirSync(LIBRARY_DIR)
    .filter((e) => fs.statSync(path.join(LIBRARY_DIR, e)).isDirectory())
    .sort();
  if (entries.length === 0) {
    console.log("  " + dim("No saved graphs yet."));
    console.log("  " + dim("Try: ") + accent("betterclaw presets"));
    console.log();
    return;
  }
  const rows = [];
  for (const name of entries) {
    const metaPath = path.join(LIBRARY_DIR, name, "meta.json");
    if (!fs.existsSync(metaPath)) continue;
    rows.push(JSON.parse(fs.readFileSync(metaPath, "utf8")));
  }
  const nameW = Math.max(4, ...rows.map((r) => r.name.length));
  console.log(
    "  " +
      dim("name".padEnd(nameW)) +
      "  " + dim("vert".padEnd(8)) +
      "  " + dim("nodes") +
      "  " + dim("edges") +
      "  " + dim("approve") +
      "  " + dim("saved"),
  );
  for (const r of rows) {
    const approvals = (r.requires_approval ?? []).length;
    const saved = (r.saved_at || "").replace("T", " ").slice(0, 16);
    const approvalStr = approvals > 0 ? pending(String(approvals).padStart(7)) : gray("0".padStart(7));
    console.log(
      "  " +
        bold(r.name.padEnd(nameW)) +
        "  " + gray((r.vertical || "email").padEnd(8)) +
        "  " + String(r.nodes).padStart(5) +
        "  " + String(r.edges).padStart(5) +
        "  " + approvalStr +
        "  " + gray(saved),
    );
  }
  console.log();
}

async function forkFromUrl(source, newName) {
  validateLibraryName(newName);
  const dir = libraryEntryDir(newName);
  if (fs.existsSync(dir)) {
    console.error(`error: library entry "${newName}" already exists at ${dir}`);
    process.exit(1);
  }

  let graphText = null;
  let paragraphText = null;
  let originDescription = source;

  // Path 1: it's already a local file.
  if (fs.existsSync(source)) {
    graphText = fs.readFileSync(source, "utf8");
    const companionPara = source.replace(/\.json$/, ".md").replace(/graph\.json$/, "paragraph.md");
    if (fs.existsSync(companionPara)) paragraphText = fs.readFileSync(companionPara, "utf8");
  } else if (/^https?:\/\//.test(source)) {
    // Path 2: HTTP(S) URL. Fetch it directly. Must be a graph.json or a
    // gist page — if it's a gist page, we try to follow the raw URL.
    graphText = await fetchUrl(source);
    try {
      JSON.parse(graphText);
    } catch {
      // Maybe a gist HTML page — scrape the raw URL.
      const rawMatch = graphText.match(/https:\/\/gist\.githubusercontent\.com\/[^"']+\/graph\.json/);
      if (rawMatch) {
        console.log(`Following raw URL: ${rawMatch[0]}`);
        graphText = await fetchUrl(rawMatch[0]);
      } else {
        console.error(`error: URL did not return JSON and no raw graph.json found in HTML`);
        process.exit(1);
      }
    }
  } else if (/^gist:/.test(source)) {
    // Path 3: gist:<id>. Use the gh CLI if available.
    const id = source.replace(/^gist:/, "");
    const result = spawnSync("gh", ["gist", "view", id, "--filename", "graph.json"], winSpawnOpts({
      encoding: "utf8",
    }));
    if (result.status !== 0) {
      console.error(`error: gh gist view failed. stderr:`);
      console.error(result.stderr);
      process.exit(1);
    }
    graphText = result.stdout;
    originDescription = `gist:${id}`;
  } else {
    console.error(`error: don't know how to fork from "${source}"`);
    console.error(`       supported: local path, http(s) URL to graph.json, gist:<id>`);
    process.exit(1);
  }

  let graph;
  try {
    graph = JSON.parse(graphText);
  } catch (err) {
    console.error(`error: fetched content isn't valid JSON: ${err.message}`);
    process.exit(2);
  }
  validateGraph(graph); // reuse the compile-time validator

  fs.mkdirSync(dir, { recursive: true });
  fs.writeFileSync(path.join(dir, "graph.json"), JSON.stringify(graph, null, 2) + "\n");
  if (paragraphText) fs.writeFileSync(path.join(dir, "paragraph.md"), paragraphText);
  const meta = {
    name: newName,
    saved_at: new Date().toISOString(),
    source: "fork",
    forked_from: originDescription,
    nodes: graph.nodes.length,
    edges: graph.edges.length,
    entry: graph.entry,
    requires_approval: graph.requires_approval ?? [],
  };
  fs.writeFileSync(path.join(dir, "meta.json"), JSON.stringify(meta, null, 2) + "\n");
  console.log();
  console.log(`  ${allow("✓")} ${bold("Forked")} ${accent(newName)} ${dim("from")} ${gray(originDescription)}`);
  console.log(`    ${dim("summary:")} ${meta.nodes} nodes, ${meta.edges} edges, entry=${meta.entry}`);
  console.log();
  console.log("  " + dim("Load it: ") + accent(`betterclaw load ${newName}`));
  console.log();
}

function fetchUrl(url) {
  return fetch(url).then((res) => {
    if (!res.ok) throw new Error(`HTTP ${res.status} fetching ${url}`);
    return res.text();
  });
}

function loadGraphByName(name) {
  if (name === "active") return JSON.parse(readActiveGraph());
  validateLibraryName(name);
  const graphPath = path.join(libraryEntryDir(name), "graph.json");
  if (!fs.existsSync(graphPath)) {
    console.error(`error: "${name}" not found in library`);
    process.exit(1);
  }
  return JSON.parse(fs.readFileSync(graphPath, "utf8"));
}

function diffGraphs(nameA, nameB) {
  const graphA = loadGraphByName(nameA);
  const graphB = loadGraphByName(nameB);
  const mermaidA = buildDiffMermaid(graphA, graphB, "left");
  const mermaidB = buildDiffMermaid(graphB, graphA, "right");
  const htmlPath = path.join(os.tmpdir(), `betterclaw-diff-${Date.now()}.html`);
  fs.writeFileSync(htmlPath, buildDiffHtml(nameA, nameB, graphA, graphB, mermaidA, mermaidB));
  console.log();
  console.log(`  ${bold("Diff:")} ${accent(nameA)} ${dim("↔")} ${accent(nameB)}`);
  console.log(`  ${accent("→")} ${gray(htmlPath)}`);
  console.log();
  openInBrowser(htmlPath);
}

function buildDiffMermaid(graph, other, side) {
  // "side" not currently used but kept for future asymmetric highlighting.
  void side;
  const shortTools = (tools) =>
    tools && tools.length > 0 ? tools.map((t) => t.replace(/^gmail_/, "")).join(" / ") : "—";
  const otherNodeIds = new Set((other.nodes ?? []).map((n) => n.id));
  const otherEdges = new Set((other.edges ?? []).map((e) => `${e.from}→${e.to}`));
  const otherNodeMap = new Map((other.nodes ?? []).map((n) => [n.id, n]));

  const lines = ["flowchart TD"];
  for (const n of graph.nodes) {
    const tagsAdded = !otherNodeIds.has(n.id);
    const otherNode = otherNodeMap.get(n.id);
    const toolsChanged =
      otherNode && JSON.stringify(otherNode.allowed_tools) !== JSON.stringify(n.allowed_tools);
    const diffLabel = tagsAdded
      ? " 🆕"
      : toolsChanged
        ? " ✏️"
        : "";
    const purpose = (n.purpose || "").replace(/"/g, "&quot;").replace(/\n/g, " ");
    const label = `<b>${n.id}${diffLabel}</b><br/>${purpose}<br/><i>tools: ${shortTools(n.allowed_tools)}</i>`;
    lines.push(`  ${n.id}["${label}"]:::${tagsAdded ? "added" : toolsChanged ? "changed" : "same"}`);
  }
  lines.push(`  start((entry))`);
  lines.push(`  start --> ${graph.entry}`);
  for (const e of graph.edges) {
    const key = `${e.from}→${e.to}`;
    if (!otherEdges.has(key)) {
      lines.push(`  ${e.from} ==>|🆕| ${e.to}`);
    } else {
      lines.push(`  ${e.from} --> ${e.to}`);
    }
  }
  lines.push(`  classDef same fill:#eeeada,stroke:#6b6860,stroke-width:1px;`);
  lines.push(`  classDef added fill:#c5e3d1,stroke:#27613f,stroke-width:2px;`);
  lines.push(`  classDef changed fill:#f5e3ba,stroke:#8f5a18,stroke-width:2px;`);
  lines.push(`  classDef entryBadge fill:#eeeada,stroke:#1c3b5a,stroke-width:2px;`);
  lines.push(`  class start entryBadge;`);
  return lines.join("\n");
}

function buildDiffHtml(nameA, nameB, graphA, graphB, mermaidA, mermaidB) {
  const summarize = (g) => {
    const approvals = (g.requires_approval ?? []).join(", ") || "(none)";
    return `${g.nodes.length} nodes · ${g.edges.length} edges · entry=<code>${escapeHtml(g.entry)}</code> · approvals: ${escapeHtml(approvals)}`;
  };
  return `<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>BetterClaw — Graph diff: ${escapeHtml(nameA)} ↔ ${escapeHtml(nameB)}</title>
  <style>${SHARED_CSS}</style>
  <script src="https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.min.js"></script>
</head>
<body>
  <p class="kicker">BetterClaw · Graph diff</p>
  <h1 class="page-title">${escapeHtml(nameA)} <em>↔</em> ${escapeHtml(nameB)}</h1>
  <p class="label" style="margin: 0 0 1.25rem;">Structural differences · node id + allowed_tools + edges</p>
  <hr class="rule"/>

  <div class="legend">
    <span><span class="swatch allow"></span>added</span>
    <span><span class="swatch change"></span>changed allowed_tools</span>
    <span><span class="swatch"></span>unchanged</span>
    <span class="mono">🆕 new edge</span>
  </div>

  <div class="panes">
    <div class="pane">
      <h2 class="section">${escapeHtml(nameA)}</h2>
      <p class="meta">${summarize(graphA)}</p>
      <pre class="mermaid">${mermaidA}</pre>
    </div>
    <div class="pane">
      <h2 class="section">${escapeHtml(nameB)}</h2>
      <p class="meta">${summarize(graphB)}</p>
      <pre class="mermaid">${mermaidB}</pre>
    </div>
  </div>

  <p class="footer">generated ${new Date().toISOString()}</p>

  <script>
    ${MERMAID_INIT_JS}
    mermaid.run();
  </script>
</body>
</html>`;
}

async function publishToRemote(name, dest) {
  validateLibraryName(name);
  const dir = libraryEntryDir(name);
  if (!fs.existsSync(dir)) {
    console.error(`error: "${name}" not in library. Save it first with: betterclaw save ${name}`);
    process.exit(1);
  }
  if (dest !== "gist") {
    console.error(`error: only --to gist is supported right now`);
    process.exit(1);
  }
  const ghCheck = spawnSync("gh", ["--version"], winSpawnOpts({ encoding: "utf8" }));
  if (ghCheck.status !== 0) {
    console.error(`error: \`gh\` CLI not found. Install it: https://cli.github.com/`);
    process.exit(2);
  }

  const graphPath = path.join(dir, "graph.json");
  const paraPath = path.join(dir, "paragraph.md");
  const metaPath = path.join(dir, "meta.json");
  const meta = JSON.parse(fs.readFileSync(metaPath, "utf8"));

  // Write a BetterClaw.md readme that explains what the gist contains.
  const readmePath = path.join(dir, "BetterClaw.md");
  const readme = `# BetterClaw workflow: ${name}

Compiled by [BetterClaw](https://github.com/) on ${meta.saved_at}.

- **${meta.nodes} nodes, ${meta.edges} edges**
- Entry: \`${meta.entry}\`
- Requires approval: ${meta.requires_approval?.join(", ") || "(none)"}

## Install

\`\`\`bash
betterclaw fork <this-gist-url> ${name}
betterclaw load ${name}
betterclaw run "<your task>"
\`\`\`

## Source paragraph

See \`paragraph.md\` in this gist.
`;
  fs.writeFileSync(readmePath, readme);

  const filesToUpload = [graphPath];
  if (fs.existsSync(paraPath)) filesToUpload.push(paraPath);
  filesToUpload.push(metaPath, readmePath);

  console.log(`Publishing "${name}" to a public gist…`);
  const ghArgs = [
    "gist",
    "create",
    "--public",
    "--desc",
    `BetterClaw workflow: ${name}`,
    ...filesToUpload,
  ];
  const result = spawnSync("gh", ghArgs, winSpawnOpts({ encoding: "utf8", stdio: ["inherit", "pipe", "pipe"] }));
  if (result.status !== 0) {
    console.error(`error: gh gist create failed:`);
    console.error(result.stderr);
    process.exit(3);
  }
  const gistUrl = result.stdout.trim();
  console.log(`Published: ${gistUrl}`);
  console.log(`\nShare this URL. Recipients can install with:`);
  console.log(`  betterclaw fork ${gistUrl} ${name}`);
}

// ---- existing helpers below ----

function loadPendingApprovals() {
  if (!fs.existsSync(RUN_LOG_PATH)) return { events: [], pending: new Map() };
  const events = fs
    .readFileSync(RUN_LOG_PATH, "utf8")
    .split("\n")
    .filter((l) => l.trim())
    .map((l) => { try { return JSON.parse(l); } catch { return null; } })
    .filter(Boolean);
  const pending = new Map();
  for (const e of events) {
    if (e.type === "approval_pending") pending.set(e.id, e);
    if (e.type === "approval_resolved") pending.delete(e.id);
  }
  return { events, pending };
}

function listPending() {
  console.log();
  console.log("  " + ui.kicker("BetterClaw · Pending approvals"));
  console.log("  " + ui.hr());
  if (!fs.existsSync(RUN_LOG_PATH)) {
    console.log("  " + dim("No active run."));
    console.log();
    return;
  }
  const { pending } = loadPendingApprovals();
  if (pending.size === 0) {
    console.log("  " + dim("No pending approvals."));
    console.log();
    return;
  }
  for (const [id, e] of pending) {
    const ts = (e.ts || "").slice(11, 19);
    // Compact summary: most important param keys only
    const paramKeys = e.params ? Object.keys(e.params) : [];
    const hint = paramKeys.length > 0
      ? dim("params: ") + gray("{ " + paramKeys.slice(0, 4).join(", ") + (paramKeys.length > 4 ? ", …" : "") + " }")
      : dim("(no params)");
    console.log(`  ${ui.chip(id, "pending")}  ${bold(e.tool)}  ${dim("at")} ${e.node}  ${gray(ts)}`);
    console.log(`    ${hint}`);
  }
  console.log();
  console.log("  " + dim("Inspect:  ") + accent("betterclaw show <id>"));
  console.log("  " + dim("Resolve:  ") + accent("betterclaw approve <id>") + dim("  or  ") + accent("betterclaw deny <id>"));
  console.log();
}

function showApproval(idOrFragment) {
  console.log();
  console.log("  " + ui.kicker("BetterClaw · Approval detail"));
  console.log("  " + ui.hr());
  const { events, pending: pendingMap } = loadPendingApprovals();
  let entry = pendingMap.get(idOrFragment);
  if (!entry) {
    for (const [id, e] of pendingMap) {
      if (id.startsWith(idOrFragment)) { entry = e; break; }
    }
  }
  let resolution = null;
  if (!entry) {
    for (const e of events) {
      if (e.type === "approval_pending" && (e.id === idOrFragment || e.id.startsWith(idOrFragment))) {
        entry = e;
      }
      if (e.type === "approval_resolved" && entry && e.id === entry.id) {
        resolution = e;
      }
    }
  }
  if (!entry) {
    console.log(`  ${deny("✗")}  No approval with id ${bold(idOrFragment)}`);
    console.log();
    process.exit(1);
  }
  const ts = (entry.ts || "").replace("T", " ").slice(0, 19);
  console.log(`  ${dim("id       ")} ${ui.chip(entry.id, "pending")}`);
  console.log(`  ${dim("tool     ")} ${bold(entry.tool)}`);
  console.log(`  ${dim("node     ")} ${entry.node}`);
  console.log(`  ${dim("requested")} ${gray(ts)}`);
  if (resolution) {
    const resTs = (resolution.ts || "").replace("T", " ").slice(0, 19);
    const verb = resolution.decision === "approved" ? allow("APPROVED") : deny("DENIED");
    console.log(`  ${dim("resolved ")} ${verb} ${gray("at " + resTs)}`);
  } else if (pendingMap.has(entry.id)) {
    console.log(`  ${dim("resolved ")} ${pending("still waiting")}`);
  } else {
    console.log(`  ${dim("resolved ")} ${dim("(unknown)")}`);
  }
  console.log();
  console.log("  " + bold("Parameters"));
  const pretty = JSON.stringify(entry.params ?? {}, null, 2);
  for (const line of pretty.split("\n")) {
    console.log("    " + line);
  }
  console.log();
  if (!resolution && pendingMap.has(entry.id)) {
    console.log("  " + dim("Resolve: ") + accent(`betterclaw approve ${entry.id}`) + dim("  or  ") + accent(`betterclaw deny ${entry.id}`));
    console.log();
  }
}

async function resolveApproval(id, decision) {
  if (!/^[a-z0-9-]+$/i.test(id)) {
    console.error("  " + deny("✗") + "  invalid id " + gray(id));
    process.exit(1);
  }
  fs.mkdirSync(APPROVALS_DIR, { recursive: true });
  const filename = decision === "approve" ? `${id}.approved` : `${id}.denied`;
  fs.writeFileSync(path.join(APPROVALS_DIR, filename), String(Date.now()));

  // Look up the pending record so we can do the out-of-band dispatch if approved.
  const { pending } = loadPendingApprovals();
  const record = pending.get(id) || findPendingByPrefix(id);

  if (!record) {
    // No pending record — still write the sentinel in case the plugin is
    // polling for it (legacy in-band wait path). Just report and exit.
    const verb = decision === "approve" ? allow("Approved") : deny("Denied");
    console.log();
    console.log(`  ${verb} ${ui.chip(id)} ${dim("— no matching pending record found (sentinel written).")}`);
    console.log();
    return;
  }

  if (decision === "deny") {
    const ts = new Date().toISOString();
    appendRunEvent({
      ts,
      type: "approval_resolved",
      id: record.id,
      decision: "denied",
    });
    appendHistory({
      ts,
      type: "async_dispatch",
      id: record.id,
      tool: record.tool,
      vertical: record.vertical,
      decision: "denied",
      status: "not_dispatched",
      summary_hint: summarizeParamsForHistory(record),
    });
    emitTelemetry("deny", {
      vertical: record.vertical,
      tool_name: record.tool,
      elapsed_since_queued_ms: record.queued_at_ms ? Date.now() - record.queued_at_ms : null,
    });
    console.log();
    console.log(`  ${deny("Denied")} ${ui.chip(record.id)} ${dim("— tool will not be dispatched.")}`);
    console.log();
    return;
  }

  // APPROVE: dispatch the tool call out-of-band against the real backend.
  emitTelemetry("approve", {
    vertical: record.vertical,
    tool_name: record.tool,
    elapsed_since_queued_ms: record.queued_at_ms ? Date.now() - record.queued_at_ms : null,
  });
  await dispatchApprovedTool(record);
}

function findPendingByPrefix(idPrefix) {
  const { pending } = loadPendingApprovals();
  for (const [id, record] of pending) {
    if (id.startsWith(idPrefix)) return record;
  }
  return null;
}

function appendRunEvent(event) {
  if (!fs.existsSync(RUN_LOG_PATH)) return;
  try {
    fs.appendFileSync(RUN_LOG_PATH, JSON.stringify(event) + "\n");
  } catch {}
}

async function dispatchApprovedTool(record) {
  console.log();
  console.log(`  ${allow("Approved")} ${ui.chip(record.id)} ${dim("— dispatching " + record.tool + "…")}`);

  const approvedTs = new Date().toISOString();
  appendRunEvent({
    ts: approvedTs,
    type: "approval_resolved",
    id: record.id,
    decision: "approved",
  });

  const _dispatchStartMs = Date.now();
  const result = await callBackend(record);
  const _dispatchDurationMs = Date.now() - _dispatchStartMs;
  const endTs = new Date().toISOString();

  emitTelemetry(result.ok ? "dispatch_ok" : "dispatch_error", {
    vertical: record.vertical,
    tool_name: record.tool,
    duration_ms: _dispatchDurationMs,
    // Classify the error into a broad bucket without leaking the raw message.
    // Don't log the error string itself — it may contain user data (email body,
    // OAuth fragments, etc.) in Gmail MCP dispatch failures.
    error_class: result.ok
      ? undefined
      : /daemon/i.test(result.error)
        ? "daemon_unreachable"
        : /timeout/i.test(result.error)
          ? "timeout"
          : /auth|unauthor/i.test(result.error)
            ? "auth"
            : /network|ENOTFOUND|ECONN/i.test(result.error)
              ? "network"
              : "other",
  });

  if (result.ok) {
    appendRunEvent({
      ts: endTs,
      type: "async_dispatch",
      id: record.id,
      tool: record.tool,
      status: "success",
      result_summary: result.summary,
    });
    appendHistory({
      ts: endTs,
      type: "async_dispatch",
      id: record.id,
      tool: record.tool,
      vertical: record.vertical,
      decision: "approved",
      status: "success",
      result_summary: result.summary,
      summary_hint: summarizeParamsForHistory(record),
    });
    console.log(`  ${allow("✓")}  ${bold(record.tool)} ${dim("dispatched:")}`);
    if (result.summary) {
      for (const line of result.summary.split("\n")) {
        console.log("     " + gray(line));
      }
    }
    if (result.next_hint) {
      console.log();
      console.log("  " + dim(result.next_hint));
    }
  } else {
    appendRunEvent({
      ts: endTs,
      type: "async_dispatch",
      id: record.id,
      tool: record.tool,
      status: "error",
      error: result.error,
    });
    appendHistory({
      ts: endTs,
      type: "async_dispatch",
      id: record.id,
      tool: record.tool,
      vertical: record.vertical,
      decision: "approved",
      status: "error",
      error: result.error,
      summary_hint: summarizeParamsForHistory(record),
    });
    console.log(`  ${deny("✗")}  ${bold(record.tool)} ${dim("dispatch failed:")}`);
    console.log("     " + deny(result.error));
  }
  console.log();
}

// One-liner describing the params, shape-appropriate for each tool. Used in
// the history log so the plugin can surface a human-readable hint back to
// the agent on the next turn ("draft re: Quick question about BetterClaw to
// clawtester58@gmail.com").
function summarizeParamsForHistory(record) {
  const p = record.params || {};
  if (record.tool === "gmail_draft") {
    const to = Array.isArray(p.to) ? p.to.join(", ") : p.to;
    return `to=${to} subject=${JSON.stringify(p.subject ?? "")}`;
  }
  if (record.tool === "sales_draft_outreach") {
    return `leadId=${p.leadId} subject=${JSON.stringify(p.subject ?? "")}`;
  }
  // Fallback — truncated JSON of first 3 keys
  const keys = Object.keys(p).slice(0, 3);
  const brief = {};
  for (const k of keys) brief[k] = p[k];
  return JSON.stringify(brief);
}

// Backend router: which dispatch strategy for which tool. Reads the tool
// name from the pending record and picks the right one. Expandable without
// touching the plugin (tool contracts stay the same).
async function callBackend(record) {
  if (record.tool === "gmail_draft") {
    return await dispatchToGmailMcp("draft_email", record.params);
  }
  // Stub-backed tools (sales, travel) don't need a real remote call — the
  // original plugin dispatch would've just returned stubbed content. We
  // simulate by reporting "approved without external side effect." The
  // agent can't see this (its turn is over), but the run log captures it.
  return {
    ok: true,
    summary: `Approved (stub-backed tool — no external side effect). Params recorded in run.jsonl.`,
    next_hint: `See: betterclaw show ${record.id}`,
  };
}

// ---- Workflow enforcement (vendored for `betterclaw hook`) ----
//
// The plugin-openclaw package has an identical copy in workflow.mjs. This copy
// lives in the CLI so the CLI package is self-contained for npm publish AND so
// the `betterclaw hook` subcommand (used by the Cowork plugin shim) can enforce
// a workflow graph without cross-package imports. If you change the enforcement
// rules, update both copies — there's a CI check planned for drift.

function loadWorkflowGraph(graphPath) {
  const raw = fs.readFileSync(graphPath, "utf8");
  const graph = JSON.parse(raw);
  graph.edges = [...graph.edges].sort((a, b) =>
    a.from === b.from ? a.to.localeCompare(b.to) : a.from.localeCompare(b.from),
  );
  graph.max_reconsider_retries = graph.max_reconsider_retries ?? 3;
  const byId = new Map(graph.nodes.map((n) => [n.id, n]));
  const outgoing = new Map();
  for (const e of graph.edges) {
    if (!outgoing.has(e.from)) outgoing.set(e.from, []);
    outgoing.get(e.from).push(e.to);
  }
  graph._byId = byId;
  graph._outgoing = outgoing;
  return graph;
}

function enforceWorkflow(graph, state, toolName, params) {
  const currentNode = graph._byId.get(state.currentNode);
  if (!currentNode) {
    return {
      decision: "block",
      reason: `WORKFLOW CORRUPTED: current node '${state.currentNode}' missing from graph.`,
      retry: 0,
    };
  }
  if (currentNode.allowed_tools.includes(toolName)) {
    state.reconsiderCounter = 0;
    return { decision: "allow", params };
  }
  const outgoing = graph._outgoing.get(state.currentNode) ?? [];
  const reachable = outgoing
    .filter((id) => graph._byId.get(id)?.allowed_tools.includes(toolName))
    .sort();
  if (reachable.length > 0) {
    state.currentNode = reachable[0];
    state.reconsiderCounter = 0;
    return { decision: "allow", params };
  }
  state.reconsiderCounter += 1;
  const allowedHere = currentNode.allowed_tools.join(", ") || "(none)";
  const nextNodes =
    outgoing
      .map((id) => {
        const n = graph._byId.get(id);
        if (!n) return `${id} (unknown)`;
        const t = n.allowed_tools.join(", ") || "(none)";
        return `${id} [${t}]`;
      })
      .join("; ") || "(none)";
  const reason =
    `DEVIATION: tool '${toolName}' not allowed in node '${currentNode.id}' ` +
    `(${currentNode.purpose}). Allowed here: [${allowedHere}]. ` +
    `Next nodes: [${nextNodes}]. Pick a tool from those lists.`;
  if (state.reconsiderCounter > graph.max_reconsider_retries) {
    return {
      decision: "block",
      reason:
        `WORKFLOW TERMINATED: exceeded reconsider budget (${graph.max_reconsider_retries}) ` +
        `at node '${currentNode.id}'. Stop trying; no valid move exists.`,
      retry: state.reconsiderCounter,
    };
  }
  return { decision: "block", reason, retry: state.reconsiderCounter };
}

function freshWorkflowState(graph) {
  return { currentNode: graph.entry, reconsiderCounter: 0 };
}

function loadCoworkSessions() {
  if (!fs.existsSync(COWORK_SESSIONS_PATH)) return {};
  try {
    const raw = fs.readFileSync(COWORK_SESSIONS_PATH, "utf8");
    const parsed = JSON.parse(raw);
    return parsed.sessions || {};
  } catch {
    return {};
  }
}

function saveCoworkSessions(sessions) {
  try {
    fs.mkdirSync(path.dirname(COWORK_SESSIONS_PATH), { recursive: true });
    // Prune old sessions before writing.
    const now = Date.now();
    const pruned = {};
    for (const [id, s] of Object.entries(sessions)) {
      const lastSeen = new Date(s.last_seen || 0).getTime();
      if (now - lastSeen < COWORK_SESSION_TTL_MS) pruned[id] = s;
    }
    fs.writeFileSync(
      COWORK_SESSIONS_PATH,
      JSON.stringify({ sessions: pruned }, null, 2) + "\n",
      { mode: 0o600 },
    );
  } catch {
    // Fire-and-forget: if state write fails, enforcement still runs — just
    // starts from entry node on next call. Visible behavior: the agent can
    // re-traverse the graph. Not a silent-failure risk.
  }
}

function getOrCreateCoworkSessionState(sessionId, graph) {
  const sessions = loadCoworkSessions();
  const existing = sessions[sessionId];
  if (existing && existing.currentNode && graph._byId.has(existing.currentNode)) {
    existing.last_seen = new Date().toISOString();
    return { state: existing, sessions };
  }
  const fresh = {
    ...freshWorkflowState(graph),
    last_seen: new Date().toISOString(),
  };
  sessions[sessionId] = fresh;
  return { state: fresh, sessions };
}

// Read recent approval history from ~/.betterclaw/history.jsonl. Mirrors the
// plugin's readRecentHistory(). Cowork's UserPromptSubmit hook surfaces this
// to the model so it doesn't re-attempt already-handled tool calls.
function readRecentApprovalHistoryForHook() {
  try {
    if (!fs.existsSync(HISTORY_PATH)) return [];
    const cutoffMs = Date.now() - HOOK_HISTORY_MAX_AGE_HOURS * 3600 * 1000;
    const lines = fs
      .readFileSync(HISTORY_PATH, "utf8")
      .split("\n")
      .filter((l) => l.trim());
    const events = [];
    for (const line of lines) {
      try {
        const e = JSON.parse(line);
        if (e.type !== "async_dispatch") continue;
        const t = new Date(e.ts).getTime();
        if (t < cutoffMs) continue;
        events.push(e);
      } catch {}
    }
    return events.slice(-HOOK_HISTORY_MAX_ENTRIES);
  } catch {
    return [];
  }
}

function formatApprovalHistoryForAgent(events) {
  if (events.length === 0) return null;
  const lines = [
    `## Recent approvals — past ${HOOK_HISTORY_MAX_AGE_HOURS}h`,
    "",
    "These tool calls were already dispatched or denied out-of-band (by the user via `betterclaw approve`/`deny`). You do NOT need to re-attempt them.",
    "",
  ];
  for (const e of events) {
    const when = e.ts.replace("T", " ").slice(0, 16);
    const verdict =
      e.status === "success"
        ? "APPROVED · success"
        : e.status === "error"
          ? "APPROVED · backend error"
          : e.status === "not_dispatched"
            ? "DENIED"
            : "UNKNOWN";
    const detail =
      e.status === "success" && e.result_summary
        ? e.result_summary
        : e.status === "error" && e.error
          ? `error: ${e.error}`
          : "";
    const hint = e.summary_hint ? ` (${e.summary_hint})` : "";
    lines.push(
      `- ${when} · ${e.tool} · ${verdict}${hint}${detail ? " — " + detail : ""}`,
    );
  }
  return lines.join("\n");
}

// ---- Cowork hook subcommand handlers ----

async function readAllStdin() {
  const chunks = [];
  for await (const chunk of process.stdin) chunks.push(chunk);
  return Buffer.concat(chunks).toString("utf8");
}

async function runHookCommand(event) {
  const raw = (await readAllStdin()).trim();
  let payload;
  if (!raw) {
    // Empty stdin: print allow-by-default and exit. Defensive — hooks should
    // never be invoked without a payload, but we never want to break the agent.
    process.stdout.write("{}\n");
    return;
  }
  try {
    payload = JSON.parse(raw);
  } catch (err) {
    process.stderr.write(`[betterclaw-hook] invalid JSON on stdin: ${err.message}\n`);
    process.stdout.write("{}\n");
    return;
  }
  let response;
  try {
    if (event === "pre-tool-call") {
      response = handlePreToolCallHook(payload);
    } else if (event === "user-prompt-submit") {
      response = handleUserPromptSubmitHook(payload);
    } else if (event === "post-tool-call") {
      response = handlePostToolCallHook(payload);
    } else {
      process.stderr.write(`[betterclaw-hook] unknown event: ${event}\n`);
      response = {};
    }
  } catch (err) {
    // Handler errors must never block the agent. Default to allow + log.
    process.stderr.write(`[betterclaw-hook] handler error: ${err.message}\n`);
    response = {};
  }
  process.stdout.write(JSON.stringify(response) + "\n");
}

function handlePreToolCallHook(payload) {
  // Payload from Cowork PreToolUse:
  //   { session_id, tool_name, tool_input, hook_event_name, ... }
  const toolName = payload.tool_name;
  const toolInput = payload.tool_input ?? {};
  const sessionId = payload.session_id || "default";

  // No active graph = no enforcement. Allow. (This happens when the user has
  // installed the Cowork plugin but hasn't compiled a workflow yet.)
  if (!fs.existsSync(GRAPH_PATH)) return {};

  let graph;
  try {
    graph = loadWorkflowGraph(GRAPH_PATH);
  } catch (err) {
    process.stderr.write(`[betterclaw-hook] graph load failed: ${err.message}\n`);
    return {}; // allow by default on internal error
  }

  // Scope check: Cowork is still early research-preview territory. The CLI's
  // hook subcommand only enforces graphs against tools that match the active
  // vertical's tool surface. Built-in Cowork tools like "Bash", "Write",
  // "Read" are out of scope — allow them through without enforcement for V1.
  // (V2: consider per-vertical allowlists for built-in tools too.)
  const verticalToolName = toolName;

  const { state, sessions } = getOrCreateCoworkSessionState(sessionId, graph);
  const result = enforceWorkflow(graph, state, verticalToolName, toolInput);
  sessions[sessionId] = { ...state, last_seen: new Date().toISOString() };
  saveCoworkSessions(sessions);

  if (result.decision === "allow") {
    // Check approval gate.
    const requiresApproval =
      Array.isArray(graph.requires_approval) &&
      graph.requires_approval.includes(verticalToolName);

    if (requiresApproval) {
      const approvalId = crypto.randomUUID().slice(0, 8);
      // Write the pending approval record into the shared queue so
      // `betterclaw pending` / `betterclaw approve` see it alongside
      // approvals generated by the OpenClaw plugin path.
      const approvalRecord = {
        id: approvalId,
        node: state.currentNode,
        tool: verticalToolName,
        vertical: graph.vertical,
        params: toolInput,
        queued_at_ms: Date.now(),
        source: "cowork",
        session_id: sessionId,
      };
      try {
        fs.mkdirSync(APPROVALS_DIR, { recursive: true });
        fs.writeFileSync(
          path.join(APPROVALS_DIR, `${approvalId}.pending`),
          JSON.stringify(approvalRecord, null, 2),
        );
      } catch (err) {
        process.stderr.write(
          `[betterclaw-hook] approval write failed: ${err.message}\n`,
        );
        // Fail-closed: don't let the tool run if we couldn't queue the gate.
        return {
          hookSpecificOutput: {
            hookEventName: "PreToolUse",
            permissionDecision: "deny",
            permissionDecisionReason:
              `Approval gate queueing failed (${err.message}). Tool blocked.`,
          },
        };
      }

      emitTelemetry("approve_queued", {
        vertical: graph.vertical,
        tool_name: verticalToolName,
        source: "cowork",
      });
      return {
        hookSpecificOutput: {
          hookEventName: "PreToolUse",
          permissionDecision: "deny",
          permissionDecisionReason:
            `Approval required · id=${approvalId} · tool=${verticalToolName}\n` +
            `This call is queued for out-of-band approval. Ask the user to:\n` +
            `  betterclaw show ${approvalId}      (inspect the pending call)\n` +
            `  betterclaw approve ${approvalId}   (dispatch it)\n` +
            `  betterclaw deny ${approvalId}      (cancel it)\n` +
            `If approved, the CLI will call the real backend; the result lands ` +
            `in the user's real state (e.g. Gmail Drafts folder). The agent ` +
            `turn can continue without waiting.`,
        },
      };
    }

    // Allow the tool call to proceed.
    emitTelemetry("auto_allow", {
      vertical: graph.vertical,
      tool_name: verticalToolName,
      source: "cowork",
    });
    return {};
  }

  // Blocked by workflow enforcement.
  emitTelemetry("deviation_blocked", {
    vertical: graph.vertical,
    attempted_tool: verticalToolName,
    from_node: state.currentNode,
    retry: result.retry,
    source: "cowork",
  });
  return {
    hookSpecificOutput: {
      hookEventName: "PreToolUse",
      permissionDecision: "deny",
      permissionDecisionReason: result.reason,
    },
  };
}

function handleUserPromptSubmitHook(_payload) {
  // Surface recent approvals (past 24h, last 8) so the agent sees them in
  // context and doesn't re-attempt handled tool calls. Same behavior as the
  // OpenClaw plugin's MEMORY.md sync but delivered via the proper hook path.
  const events = readRecentApprovalHistoryForHook();
  const block = formatApprovalHistoryForAgent(events);
  if (!block) return {};
  return { systemMessage: block };
}

function handlePostToolCallHook(_payload) {
  // For V1, PostToolCall is just informational. No enforcement after the fact.
  // Telemetry for tool-completion timing is handled CLI-side on the approval
  // dispatch path. Return empty to avoid any conversation-side effect.
  return {};
}

// ---- MCP daemon ----

// Runs the Gmail MCP proxy in the foreground. The daemon binds a Unix socket,
// spawns @gongrzhe/server-gmail-autoauth-mcp as a single persistent child,
// and multiplexes JSON-RPC messages between any number of connected clients
// and that child. Each client's ID space is isolated via an upstream ID map.
//
// Returns a Promise that resolves when the daemon has shut down cleanly.
function runMcpDaemonForeground({ quiet = false } = {}) {
  return new Promise((resolve, reject) => {
    _runMcpDaemonImpl({ quiet, resolve, reject });
  });
}

function _runMcpDaemonImpl({ quiet, resolve, reject }) {
  const log = (msg) => {
    if (!quiet) process.stderr.write(`[mcp-daemon] ${msg}\n`);
  };

  // Clean up stale socket from a previous crashed daemon.
  try {
    fs.unlinkSync(MCP_SOCKET_PATH);
  } catch (err) {
    if (err.code !== "ENOENT") {
      reject(new Error(`failed to clear stale socket at ${MCP_SOCKET_PATH}: ${err.message}`));
      return;
    }
  }
  try {
    fs.mkdirSync(path.dirname(MCP_SOCKET_PATH), { recursive: true });
  } catch {}

  // --- Gmail MCP child management ---
  let child = null;
  let childBuffer = "";
  let childAlive = false;
  const respawns = []; // timestamps of recent respawn attempts
  const pendingByUpstreamId = new Map(); // upstreamId -> { clientConn, clientId }
  let nextUpstreamId = 1;

  const spawnChild = () => {
    const now = Date.now();
    // Reap respawn timestamps older than 10 minutes.
    while (respawns.length && now - respawns[0] > 10 * 60 * 1000) respawns.shift();
    if (respawns.length >= 3) {
      log(`child has crashed ${respawns.length} times in 10 min; not respawning`);
      childAlive = false;
      return;
    }
    respawns.push(now);

    const c = spawn("npx", ["-y", "@gongrzhe/server-gmail-autoauth-mcp"], {
      stdio: ["pipe", "pipe", "pipe"],
      env: { ...process.env },
    });
    child = c;
    childBuffer = "";
    childAlive = true;
    log(`child spawned (pid=${c.pid})`);

    c.stdout.setEncoding("utf8");
    c.stdout.on("data", (chunk) => {
      childBuffer += chunk;
      let idx;
      while ((idx = childBuffer.indexOf("\n")) !== -1) {
        const line = childBuffer.slice(0, idx).trim();
        childBuffer = childBuffer.slice(idx + 1);
        if (!line) continue;
        routeChildMessageToClient(line);
      }
    });

    c.stderr.on("data", (chunk) => {
      // Gmail MCP stderr is noisy (OAuth prompts, etc.); log only if not quiet.
      if (!quiet) process.stderr.write(`[gmail-child] ${chunk}`);
    });

    c.on("exit", (code, signal) => {
      log(`child exited code=${code} signal=${signal}`);
      child = null;
      childAlive = false;
      // Fail any pending requests; clients see an error.
      for (const entry of pendingByUpstreamId.values()) {
        try {
          entry.clientConn.write(
            JSON.stringify({
              jsonrpc: "2.0",
              id: entry.clientId,
              error: { code: -32000, message: `gmail MCP child exited (code=${code} signal=${signal})` },
            }) + "\n",
          );
        } catch {}
      }
      pendingByUpstreamId.clear();
      // Respawn if we haven't hit the crash-loop limit.
      if (!shuttingDown) spawnChild();
    });

    c.on("error", (err) => log(`child spawn error: ${err.message}`));
  };

  const sendToChild = (msg) => {
    if (!child || !childAlive) {
      return false;
    }
    try {
      child.stdin.write(JSON.stringify(msg) + "\n");
      return true;
    } catch (err) {
      log(`child stdin write error: ${err.message}`);
      return false;
    }
  };

  const routeChildMessageToClient = (line) => {
    let msg;
    try {
      msg = JSON.parse(line);
    } catch {
      log(`non-JSON from child: ${line.slice(0, 120)}`);
      return;
    }
    if (msg.id === undefined) {
      // Notification from child — broadcast to all clients? For BetterClaw's
      // V1 usage we don't need it. Drop.
      return;
    }
    const entry = pendingByUpstreamId.get(msg.id);
    if (!entry) {
      log(`response for unknown upstream id=${msg.id}; dropping`);
      return;
    }
    pendingByUpstreamId.delete(msg.id);
    const rewritten = { ...msg, id: entry.clientId };
    try {
      entry.clientConn.write(JSON.stringify(rewritten) + "\n");
    } catch (err) {
      log(`client write error (client disconnected mid-flight): ${err.message}`);
    }
  };

  // --- socket server ---
  const server = net.createServer((clientConn) => {
    log(`client connected`);
    let clientBuffer = "";
    clientConn.setEncoding("utf8");

    clientConn.on("data", (chunk) => {
      clientBuffer += chunk;
      let idx;
      while ((idx = clientBuffer.indexOf("\n")) !== -1) {
        const line = clientBuffer.slice(0, idx).trim();
        clientBuffer = clientBuffer.slice(idx + 1);
        if (!line) continue;
        handleClientMessage(clientConn, line);
      }
    });

    clientConn.on("close", () => {
      log(`client disconnected`);
      // Drop any pending upstream requests owned by this client so their
      // responses don't try to write to a closed socket.
      for (const [uid, entry] of pendingByUpstreamId) {
        if (entry.clientConn === clientConn) pendingByUpstreamId.delete(uid);
      }
    });

    clientConn.on("error", (err) => {
      log(`client socket error: ${err.message}`);
    });
  });

  const handleClientMessage = (clientConn, line) => {
    let msg;
    try {
      msg = JSON.parse(line);
    } catch {
      log(`non-JSON from client: ${line.slice(0, 120)}`);
      return;
    }
    // Handle initialize locally so multiple clients can coexist without
    // re-initializing the shared child. The daemon synthesizes a success
    // response with the child's (assumed) capabilities.
    if (msg.method === "initialize") {
      const reply = {
        jsonrpc: "2.0",
        id: msg.id,
        result: {
          protocolVersion: "2024-11-05",
          capabilities: { tools: {} },
          serverInfo: { name: "betterclaw-mcp-proxy", version: "0.1.0" },
        },
      };
      clientConn.write(JSON.stringify(reply) + "\n");
      return;
    }
    if (msg.method === "notifications/initialized") {
      // Client signals readiness. Nothing to do.
      return;
    }
    // Everything else gets proxied to the child with ID rewriting.
    if (msg.id !== undefined) {
      if (!childAlive) {
        clientConn.write(
          JSON.stringify({
            jsonrpc: "2.0",
            id: msg.id,
            error: { code: -32000, message: "gmail MCP child not running (crash-loop or not yet started)" },
          }) + "\n",
        );
        return;
      }
      const upstreamId = nextUpstreamId++;
      pendingByUpstreamId.set(upstreamId, { clientConn, clientId: msg.id });
      const forwarded = { ...msg, id: upstreamId };
      if (!sendToChild(forwarded)) {
        pendingByUpstreamId.delete(upstreamId);
        clientConn.write(
          JSON.stringify({
            jsonrpc: "2.0",
            id: msg.id,
            error: { code: -32000, message: "failed to forward to gmail MCP child" },
          }) + "\n",
        );
      }
    } else {
      // Notification — forward, no tracking.
      sendToChild(msg);
    }
  };

  // --- shutdown ---
  let shuttingDown = false;
  const shutdown = (signal) => {
    if (shuttingDown) return;
    shuttingDown = true;
    log(`shutting down (${signal})`);
    try {
      server.close();
    } catch {}
    try {
      fs.unlinkSync(MCP_SOCKET_PATH);
    } catch {}
    try {
      fs.unlinkSync(MCP_PID_PATH);
    } catch {}
    if (child) {
      try {
        child.stdin.end();
      } catch {}
      try {
        child.kill("SIGTERM");
      } catch {}
    }
    resolve();
    // Give the socket a moment to close before exiting.
    setTimeout(() => process.exit(0), 100).unref();
  };
  process.on("SIGTERM", () => shutdown("SIGTERM"));
  process.on("SIGINT", () => shutdown("SIGINT"));

  // --- start ---
  server.on("error", (err) => {
    if (err.code === "EADDRINUSE") {
      reject(
        new Error(
          `socket ${MCP_SOCKET_PATH} is already in use — another daemon running? Try \`betterclaw stop\` first.`,
        ),
      );
      return;
    }
    reject(err);
  });

  server.listen(MCP_SOCKET_PATH, () => {
    try {
      fs.chmodSync(MCP_SOCKET_PATH, 0o600);
    } catch {}
    // Write our PID so `betterclaw stop` can find us.
    try {
      fs.writeFileSync(MCP_PID_PATH, String(process.pid) + "\n");
    } catch {}
    log(`listening on ${MCP_SOCKET_PATH} (pid=${process.pid})`);
    spawnChild();
  });
}

function startDetachedDaemon() {
  maybeShowFirstRunNotice();
  // Idempotent: if a live daemon is already running, do nothing.
  const status = readDaemonStatus();
  if (status.running) {
    console.log(`  ${allow("✓")}  Daemon already running (pid=${status.pid})`);
    return;
  }
  // Clear any stale PID file.
  if (status.staleFile) {
    try {
      fs.unlinkSync(MCP_PID_PATH);
    } catch {}
  }

  // Open the log file for the detached daemon's stderr.
  try {
    fs.mkdirSync(path.dirname(MCP_LOG_PATH), { recursive: true });
  } catch {}
  const logFd = fs.openSync(MCP_LOG_PATH, "a");
  const cliPath = process.argv[1];
  const child = spawn(process.execPath, [cliPath, "mcp-daemon", "--foreground", "--quiet"], {
    detached: true,
    stdio: ["ignore", logFd, logFd],
    env: process.env,
  });
  child.unref();

  const identityWasNew = !fs.existsSync(IDENTITY_PATH);
  if (identityWasNew) {
    emitTelemetry("install", { first_time: true });
  }
  emitTelemetry("daemon_start", { pid: child.pid });
  maybeShowFeedbackCTA();

  // Wait briefly for the daemon to come up (socket visible). spawnSync a
  // short sleep so we don't busy-loop; this runs from a user-initiated CLI
  // command so blocking briefly is fine.
  const startedAt = Date.now();
  while (Date.now() - startedAt < 3000) {
    if (fs.existsSync(MCP_SOCKET_PATH) && fs.existsSync(MCP_PID_PATH)) {
      console.log(`  ${allow("✓")}  Daemon started (pid=${child.pid}, log=${MCP_LOG_PATH})`);
      return;
    }
    spawnSync("sleep", ["0.05"]);
  }
  console.error(`  ${deny("✗")}  Daemon failed to come up within 3s — see ${MCP_LOG_PATH}`);
  process.exitCode = 1;
}

function stopDaemon() {
  const status = readDaemonStatus();
  if (!status.running) {
    if (status.staleFile) {
      try {
        fs.unlinkSync(MCP_PID_PATH);
      } catch {}
    }
    console.log(`  ${dim("—")}  No daemon running`);
    return;
  }
  try {
    process.kill(status.pid, "SIGTERM");
    console.log(`  ${allow("✓")}  Sent SIGTERM to pid=${status.pid}`);
  } catch (err) {
    console.error(`  ${deny("✗")}  Failed to stop pid=${status.pid}: ${err.message}`);
    process.exitCode = 1;
  }
}

// Enable the Gmail MCP fallback. Writes the marker file so subsequent
// `betterclaw run` invocations auto-start the daemon, and the OpenClaw plugin
// (when it boots and sees the marker) registers vertical-email's tools.
//
// Per ADR 0002 (v0.3+), this is the OpenClaw-without-Cowork path. Cowork users
// should NOT run this — their Gmail comes from Anthropic's verified connector.
function connectGmail() {
  const host = detectHost();
  console.log();
  console.log("  " + ui.kicker("BetterClaw · Connect Gmail (OpenClaw fallback)"));
  console.log("  " + ui.hr());

  if (host === "cowork") {
    console.log(`  ${dim("Note:")}  You're running under Cowork. Anthropic ships a verified Gmail`);
    console.log(`         connector — enable it in Claude.ai instead of using this fallback.`);
    console.log(`         This BetterClaw fallback is for OpenClaw users without Cowork.`);
    console.log();
    console.log(`         If you really want the BetterClaw fallback anyway, continue.`);
    console.log();
  }

  if (isGmailFallbackEnabled()) {
    console.log(`  ${allow("✓")}  Gmail fallback is already enabled.`);
    console.log(`     Marker: ${GMAIL_FALLBACK_MARKER_PATH}`);
    console.log();
    console.log(`     Next steps:`);
    console.log(`       • Authenticate with Google: ${accent("npx @gongrzhe/server-gmail-autoauth-mcp auth")}`);
    console.log(`       • Start the daemon:        ${accent("betterclaw start")}`);
    console.log(`       • Verify it's running:     ${accent("betterclaw status")}`);
    console.log(`       • Disable later:           ${accent("betterclaw disconnect gmail")}`);
    return;
  }

  try {
    fs.mkdirSync(path.dirname(GMAIL_FALLBACK_MARKER_PATH), { recursive: true });
    fs.writeFileSync(
      GMAIL_FALLBACK_MARKER_PATH,
      JSON.stringify({ enabled_at: new Date().toISOString(), host }) + "\n",
    );
  } catch (err) {
    console.error(`  ${deny("✗")}  Failed to write marker: ${err.message}`);
    process.exit(1);
  }

  console.log(`  ${allow("✓")}  Gmail fallback enabled.`);
  console.log(`     Marker: ${GMAIL_FALLBACK_MARKER_PATH}`);
  console.log();
  console.log(`     ${bold("Next steps:")}`);
  console.log();
  console.log(`     1. Set up a Google Cloud project + OAuth credentials:`);
  console.log(`        See https://github.com/gongrzhe/server-gmail-autoauth-mcp#setup`);
  console.log(`        (this requires a GCP account; if that's a wall, use Cowork instead)`);
  console.log();
  console.log(`     2. Authenticate (one-time, opens a browser):`);
  console.log(`        ${accent("npx @gongrzhe/server-gmail-autoauth-mcp auth")}`);
  console.log();
  console.log(`     3. Start the daemon:`);
  console.log(`        ${accent("betterclaw start")}`);
  console.log();
  console.log(`     4. Verify it's running:`);
  console.log(`        ${accent("betterclaw status")}`);
  console.log();
  console.log(`     5. To disable later:`);
  console.log(`        ${accent("betterclaw disconnect gmail")}`);
}

function disconnectGmail() {
  console.log();
  console.log("  " + ui.kicker("BetterClaw · Disconnect Gmail"));
  console.log("  " + ui.hr());
  if (!isGmailFallbackEnabled()) {
    console.log(`  ${dim("(no-op)")}  Gmail fallback was not enabled.`);
    return;
  }
  try {
    fs.unlinkSync(GMAIL_FALLBACK_MARKER_PATH);
  } catch (err) {
    console.error(`  ${deny("✗")}  Failed to remove marker: ${err.message}`);
    process.exit(1);
  }
  console.log(`  ${allow("✓")}  Gmail fallback disabled. Marker removed.`);
  // Best-effort: stop the daemon if it's running. Don't error if it's already
  // stopped or never started.
  const status = readDaemonStatus();
  if (status.running) {
    console.log(`  ${dim("…")}  Stopping the running daemon`);
    try { process.kill(status.pid, "SIGTERM"); } catch {}
  }
}

function printDaemonStatus() {
  const status = readDaemonStatus();
  console.log();
  console.log("  " + ui.kicker("BetterClaw · Daemon status"));
  console.log("  " + ui.hr());
  if (status.running) {
    console.log(`  ${allow("✓")}  Running   ${gray("pid=" + status.pid)}`);
    console.log(`  ${dim("socket  ")}  ${MCP_SOCKET_PATH}`);
    console.log(`  ${dim("log     ")}  ${MCP_LOG_PATH}`);
  } else if (status.staleFile) {
    console.log(`  ${deny("✗")}  Stale PID file (pid=${status.pid} not alive). Run \`betterclaw start\`.`);
  } else {
    console.log(`  ${dim("—")}  Not running. Run \`betterclaw start\` to launch.`);
  }
  console.log();
}

function readDaemonStatus() {
  if (!fs.existsSync(MCP_PID_PATH)) {
    return { running: false, staleFile: false, pid: null };
  }
  const raw = (() => {
    try {
      return fs.readFileSync(MCP_PID_PATH, "utf8").trim();
    } catch {
      return "";
    }
  })();
  const pid = parseInt(raw, 10);
  if (!pid || Number.isNaN(pid)) {
    return { running: false, staleFile: true, pid: null };
  }
  try {
    // kill(pid, 0) probes liveness without signaling.
    process.kill(pid, 0);
    return { running: true, staleFile: false, pid };
  } catch {
    return { running: false, staleFile: true, pid };
  }
}

function ensureDaemonRunning() {
  // Per ADR 0002 (v0.3+), the Gmail MCP daemon is opt-in. It only starts when
  // the user has explicitly run `betterclaw connect gmail`, which writes the
  // GMAIL_FALLBACK_MARKER_PATH file. Without the marker, the daemon stays
  // dormant — the host environment (Cowork connectors or user MCP servers)
  // is expected to provide tools.
  if (!isGmailFallbackEnabled()) return;
  const status = readDaemonStatus();
  if (status.running) return;
  console.log(`  ${dim("…")}  Gmail fallback daemon not running; starting it now`);
  startDetachedDaemon();
}

// ---- dispatch to the daemon (replaces the old per-call-spawn function) ----

async function dispatchToGmailMcp(toolName, params) {
  // Connect to the running daemon, send a single tools/call, close.
  // If the daemon isn't up, return a structured error explaining how to fix it.
  return new Promise((resolve) => {
    const socket = net.createConnection(MCP_SOCKET_PATH);
    let buffer = "";
    let finished = false;
    const CONNECT_TIMEOUT_MS = 3000;
    const CALL_TIMEOUT_MS = 30000;

    const connectTimer = setTimeout(() => {
      if (finished) return;
      try { socket.destroy(); } catch {}
      finish({
        ok: false,
        error: `daemon connect timeout at ${MCP_SOCKET_PATH} — run \`betterclaw start\``,
      });
    }, CONNECT_TIMEOUT_MS);

    const callTimer = setTimeout(() => {
      if (finished) return;
      try { socket.destroy(); } catch {}
      finish({ ok: false, error: `daemon call timeout after ${CALL_TIMEOUT_MS}ms` });
    }, CALL_TIMEOUT_MS);

    const finish = (result) => {
      if (finished) return;
      finished = true;
      clearTimeout(connectTimer);
      clearTimeout(callTimer);
      try { socket.end(); } catch {}
      resolve(result);
    };

    const send = (msg) => {
      socket.write(JSON.stringify(msg) + "\n");
    };

    socket.setEncoding("utf8");

    socket.on("connect", () => {
      clearTimeout(connectTimer);
      // Initialize, then tools/call. ID 1 = initialize, ID 2 = tools/call.
      send({
        jsonrpc: "2.0",
        id: 1,
        method: "initialize",
        params: {
          protocolVersion: "2024-11-05",
          capabilities: {},
          clientInfo: { name: "betterclaw-cli", version: "0.1.0" },
        },
      });
      send({ jsonrpc: "2.0", method: "notifications/initialized" });
      send({
        jsonrpc: "2.0",
        id: 2,
        method: "tools/call",
        params: { name: toolName, arguments: params ?? {} },
      });
    });

    socket.on("data", (chunk) => {
      buffer += chunk;
      let idx;
      while ((idx = buffer.indexOf("\n")) !== -1) {
        const line = buffer.slice(0, idx).trim();
        buffer = buffer.slice(idx + 1);
        if (!line) continue;
        let msg;
        try { msg = JSON.parse(line); } catch { continue; }
        if (msg.id === 2) {
          // The tools/call response.
          if (msg.error) {
            finish({ ok: false, error: `MCP error: ${JSON.stringify(msg.error)}` });
            return;
          }
          const result = msg.result;
          const textParts = (result?.content ?? [])
            .filter((c) => c.type === "text")
            .map((c) => c.text)
            .join("\n");
          finish({
            ok: !result?.isError,
            summary: textParts || "(no content returned)",
            next_hint: toolName === "draft_email"
              ? "Open your Gmail Drafts folder to review."
              : null,
            error: result?.isError ? textParts : undefined,
          });
        }
      }
    });

    socket.on("error", (err) => {
      if (err.code === "ENOENT") {
        finish({
          ok: false,
          error: `daemon not running (no socket at ${MCP_SOCKET_PATH}). Run \`betterclaw start\` first.`,
        });
      } else {
        finish({ ok: false, error: `daemon socket error: ${err.message}` });
      }
    });

    socket.on("close", () => {
      if (!finished) finish({ ok: false, error: "daemon closed connection before responding" });
    });
  });
}

function viewLastRun() {
  if (!fs.existsSync(GRAPH_PATH)) {
    console.error(`error: no graph compiled yet. Run \`betterclaw "<paragraph>"\` first.`);
    process.exit(1);
  }
  if (!fs.existsSync(RUN_LOG_PATH) || fs.statSync(RUN_LOG_PATH).size === 0) {
    console.error(
      `error: no run log at ${RUN_LOG_PATH}\n` +
        `       Run the agent once: \`betterclaw run "<task>"\``,
    );
    process.exit(1);
  }

  const graph = JSON.parse(fs.readFileSync(GRAPH_PATH, "utf8"));
  const events = fs
    .readFileSync(RUN_LOG_PATH, "utf8")
    .split("\n")
    .filter((l) => l.trim().length > 0)
    .map((l) => {
      try {
        return JSON.parse(l);
      } catch {
        return null;
      }
    })
    .filter(Boolean);

  const allowEvents = events.filter((e) => e.type === "allow");
  const deviationEvents = events.filter((e) => e.type === "deviation");
  const visitedNodes = new Set(
    allowEvents.flatMap((e) => [e.from_node, e.to_node]).filter(Boolean),
  );
  const traversedEdges = new Set();
  for (const e of allowEvents) {
    if (e.transitioned) traversedEdges.add(`${e.from_node}→${e.to_node}`);
  }

  const mermaid = buildReplayMermaid(graph, visitedNodes, traversedEdges, deviationEvents);
  const htmlPath = writeReplayHtml(graph, events, mermaid, {
    allowCount: allowEvents.length,
    deviationCount: deviationEvents.length,
  });
  console.log();
  console.log(`  ${bold("Replay")}  ${ui.chip(allowEvents.length + " allowed", "allow")} ${ui.chip(deviationEvents.length + " deviation" + (deviationEvents.length === 1 ? "" : "s"), deviationEvents.length > 0 ? "deny" : null)}`);
  console.log(`  ${accent("→")} ${gray(htmlPath)}`);
  console.log();
  openInBrowser(htmlPath);
}

async function startWatchServer() {
  if (!fs.existsSync(GRAPH_PATH)) {
    console.error(`error: no graph compiled yet. Run \`betterclaw "<paragraph>"\` first.`);
    process.exit(1);
  }

  const server = http.createServer((req, res) => {
    const url = new URL(req.url, "http://localhost");
    if (url.pathname === "/" || url.pathname === "/index.html") {
      res.writeHead(200, { "content-type": "text/html; charset=utf-8" });
      res.end(buildWatchPageHtml());
      return;
    }
    if (url.pathname === "/state.json") {
      const state = readCurrentState();
      res.writeHead(200, { "content-type": "application/json" });
      res.end(JSON.stringify(state));
      return;
    }
    if (url.pathname === "/resolve" && req.method === "POST") {
      let body = "";
      req.on("data", (chunk) => (body += chunk));
      req.on("end", async () => {
        try {
          const { id, decision } = JSON.parse(body);
          if (!id || (decision !== "approve" && decision !== "deny")) {
            res.writeHead(400, { "content-type": "application/json" });
            res.end(JSON.stringify({ error: "need { id, decision: 'approve' | 'deny' }" }));
            return;
          }
          await resolveApproval(id, decision);
          res.writeHead(200, { "content-type": "application/json" });
          res.end(JSON.stringify({ ok: true, id, decision }));
        } catch (err) {
          res.writeHead(400, { "content-type": "application/json" });
          res.end(JSON.stringify({ error: String(err) }));
        }
      });
      return;
    }
    res.writeHead(404, { "content-type": "text/plain" });
    res.end("not found");
  });

  await new Promise((resolve) => server.listen(0, "127.0.0.1", resolve));
  const { port } = server.address();
  const url = `http://127.0.0.1:${port}/`;
  console.log();
  console.log("  " + ui.kicker("BetterClaw · Live view"));
  console.log("  " + ui.hr());
  console.log(`  ${bold("Serving at")} ${accent(url)}`);
  console.log();
  console.log("  " + dim("Leave this running. In another terminal:"));
  console.log("    " + accent(`betterclaw run "<your task>"`));
  console.log();
  console.log("  " + dim("Ctrl+C here to stop."));
  console.log();
  openInBrowser(url);

  await new Promise(() => {});
}

function readCurrentState() {
  const graph = JSON.parse(fs.readFileSync(GRAPH_PATH, "utf8"));
  let events = [];
  if (fs.existsSync(RUN_LOG_PATH)) {
    events = fs
      .readFileSync(RUN_LOG_PATH, "utf8")
      .split("\n")
      .filter((l) => l.trim().length > 0)
      .map((l) => {
        try { return JSON.parse(l); } catch { return null; }
      })
      .filter(Boolean);
  }
  return { graph, events, ts: Date.now() };
}

function buildWatchPageHtml() {
  return `<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>BetterClaw — Live run</title>
  <style>${SHARED_CSS}</style>
  <script src="https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.min.js"></script>
</head>
<body>
  <p class="kicker">BetterClaw · Live run</p>
  <h1 class="page-title">
    Agent at work
    <span class="chip live" style="vertical-align: middle; margin-left: 0.5rem;" id="live-chip">live</span>
  </h1>
  <p class="label" style="margin: 0 0 1.25rem;">Polling <span class="mono" style="text-transform: none; color: var(--ink-soft);">/state.json</span> every 500ms · green = visited · bold edge = traversed · dashed rust = attempted deviation</p>
  <hr class="rule"/>

  <div class="summary">
    <span class="chip allow"   id="allowChip">0 allowed</span>
    <span class="chip deny"    id="devChip">0 deviations</span>
    <span class="chip pending" id="pendingChip" style="display:none;">0 pending</span>
    <span class="meta" id="graphMeta"></span>
  </div>

  <div id="approvals"></div>

  <div class="layout">
    <div>
      <h2 class="section">Workflow graph</h2>
      <p class="label" style="margin-bottom:0.5rem;">Live state</p>
      <div class="mermaid-wrap" id="diagram"></div>
    </div>
    <div>
      <h2 class="section">Timeline</h2>
      <p class="label" style="margin-bottom:0.5rem;">Most recent at bottom</p>
      <table>
        <thead><tr><th>time</th><th>node</th><th>tool</th><th>detail</th></tr></thead>
        <tbody id="timeline"></tbody>
      </table>
    </div>
  </div>

  <p class="footer" id="lastUpdate">awaiting first event</p>

<script>
  ${MERMAID_INIT_JS}

  let lastEventCount = -1;
  let lastDiagramSig = "";
  let renderSeq = 0;

  async function tick() {
    try {
      const res = await fetch("/state.json", { cache: "no-store" });
      if (!res.ok) return;
      const state = await res.json();
      await render(state);
    } catch (err) { /* server may be starting; silently retry */ }
  }

  function escapeHtml(s) {
    return String(s).replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;").replace(/"/g,"&quot;");
  }

  function shortTools(ts) {
    if (!ts || ts.length === 0) return "—";
    return ts.map(t => t.replace(/^[a-z]+_/,"")).join(" / ");
  }

  async function render(state) {
    const { graph, events } = state;
    const allow = events.filter(e => e.type === "allow");
    const dev = events.filter(e => e.type === "deviation");

    // Pending approvals
    const pendingMap = new Map();
    for (const e of events) {
      if (e.type === "approval_pending") pendingMap.set(e.id, e);
      if (e.type === "approval_resolved") pendingMap.delete(e.id);
    }
    const pending = [...pendingMap.values()];

    document.getElementById("allowChip").textContent = allow.length + " allowed";
    document.getElementById("devChip").textContent = dev.length + " deviation" + (dev.length === 1 ? "" : "s");
    const pendingChip = document.getElementById("pendingChip");
    if (pending.length > 0) {
      pendingChip.style.display = "inline-flex";
      pendingChip.textContent = pending.length + " pending";
    } else {
      pendingChip.style.display = "none";
    }
    document.getElementById("graphMeta").innerHTML = "entry " + escapeHtml(graph.entry) + " · " + graph.nodes.length + " nodes · " + graph.edges.length + " edges · vertical " + escapeHtml(graph.vertical || "email");

    renderApprovals(pending);

    // Mermaid re-render only on change
    const visited = new Set(allow.flatMap(e => [e.from_node, e.to_node]).filter(Boolean));
    const traversed = new Set();
    for (const e of allow) if (e.transitioned) traversed.add(e.from_node + "→" + e.to_node);
    const sig = JSON.stringify({ g: graph, v: [...visited].sort(), t: [...traversed].sort(),
      d: dev.map(d => ({ n: d.from_node, t: d.attempted_tool })) });
    if (sig !== lastDiagramSig) {
      lastDiagramSig = sig;
      const wrap = document.getElementById("diagram");
      wrap.classList.add("refreshing");
      const src = buildMermaidSource(graph, visited, traversed, dev);
      const id = "diagram-svg-" + (++renderSeq);
      try {
        const out = await mermaid.render(id, src);
        wrap.innerHTML = out.svg;
      } catch (err) {
        wrap.textContent = "mermaid render error: " + err.message;
      }
      requestAnimationFrame(() => wrap.classList.remove("refreshing"));
    }

    // Timeline
    const tbody = document.getElementById("timeline");
    const rowsHtml = events
      .filter(e => e.type === "allow" || e.type === "deviation")
      .map((e, i) => {
        const ts = e.ts ? e.ts.split("T")[1].slice(0, 12) : "";
        const fresh = (i >= lastEventCount && lastEventCount >= 0) ? " fresh" : "";
        if (e.type === "deviation") {
          return "<tr class=\\"dev" + fresh + "\\"><td>" + ts + "</td><td>" + escapeHtml(e.from_node ?? "") + "</td><td>✕ " + escapeHtml(e.attempted_tool ?? "") + "</td><td>retry " + e.retry + "/" + e.retry_limit + "</td></tr>";
        }
        const arrow = e.transitioned
          ? escapeHtml(e.from_node) + " → " + escapeHtml(e.to_node)
          : "— " + escapeHtml(e.from_node);
        return "<tr class=\\"" + fresh.trim() + "\\"><td>" + ts + "</td><td>" + escapeHtml(e.to_node ?? e.from_node ?? "") + "</td><td>✓ " + escapeHtml(e.tool ?? "") + "</td><td>" + arrow + "</td></tr>";
      })
      .join("");
    tbody.innerHTML = rowsHtml || "<tr><td colspan=\\"4\\" style=\\"color: var(--muted); font-style: italic; padding: 1.5rem;\\">waiting for first tool call…</td></tr>";
    lastEventCount = allow.length + dev.length;

    document.getElementById("lastUpdate").textContent = "last poll " + new Date().toLocaleTimeString();
  }

  function buildMermaidSource(graph, visitedNodes, traversedEdges, deviationEvents) {
    const devsByNode = new Map();
    for (const d of deviationEvents) {
      if (!devsByNode.has(d.from_node)) devsByNode.set(d.from_node, []);
      devsByNode.get(d.from_node).push(d.attempted_tool);
    }
    const lines = ["flowchart TD"];
    for (const n of graph.nodes) {
      const purpose = (n.purpose || "").replace(/"/g,"&quot;").replace(/\\n/g," ");
      const devs = devsByNode.get(n.id);
      const devSuffix = devs ? "<br/><b style='color:#7a2418;'>deviations: " + devs.length + "</b>" : "";
      const label = "<b>" + n.id + "</b><br/>" + purpose + "<br/><i>tools: " + shortTools(n.allowed_tools) + "</i>" + devSuffix;
      lines.push("  " + n.id + "[\\"" + label + "\\"]");
    }
    lines.push("  start((entry))");
    lines.push("  start --> " + graph.entry);
    for (const e of graph.edges) {
      const key = e.from + "→" + e.to;
      lines.push("  " + e.from + (traversedEdges.has(key) ? " ==> " : " --> ") + e.to);
    }
    let p = 0;
    for (const d of deviationEvents) {
      const tool = (d.attempted_tool || "unknown").replace(/^[a-z]+_/,"");
      lines.push("  devghost" + p + "([\\"✕ " + tool + "<br/>deviation\\"]):::devbox");
      lines.push("  " + d.from_node + " -.-> devghost" + p);
      p++;
    }
    lines.push("  classDef visited fill:#c5e3d1,stroke:#27613f,stroke-width:2px;");
    lines.push("  classDef devbox fill:#eec6bc,stroke:#7a2418,stroke-width:1.5px,stroke-dasharray:5 3;");
    lines.push("  classDef entryBadge fill:#eeeada,stroke:#1c3b5a,stroke-width:2px;");
    lines.push("  class start entryBadge;");
    const visitedList = [...visitedNodes].filter(n => graph.nodes.some(gn => gn.id === n));
    if (visitedList.length > 0) lines.push("  class " + visitedList.join(",") + " visited;");
    return lines.join("\\n");
  }

  function renderApprovals(pending) {
    const host = document.getElementById("approvals");
    if (pending.length === 0) { host.innerHTML = ""; return; }
    host.innerHTML = pending.map(p => {
      const paramsStr = p.params ? JSON.stringify(p.params, null, 2) : "(no params)";
      return "<div class=\\"approval-card\\" data-id=\\"" + escapeHtml(p.id) + "\\">" +
        "<h3>Awaiting approval · " + escapeHtml(p.tool) + "</h3>" +
        "<div class=\\"meta-row\\">node <span class=\\"mono\\">" + escapeHtml(p.node) + "</span> &nbsp;·&nbsp; id <span class=\\"mono\\">" + escapeHtml(p.id) + "</span></div>" +
        "<div class=\\"params\\">" + escapeHtml(paramsStr) + "</div>" +
        "<div class=\\"buttons\\">" +
          "<button class=\\"btn approve\\" onclick=\\"resolveApproval('" + p.id + "','approve',this)\\">Approve</button>" +
          "<button class=\\"btn deny\\" onclick=\\"resolveApproval('" + p.id + "','deny',this)\\">Deny</button>" +
        "</div>" +
      "</div>";
    }).join("");
  }

  async function resolveApproval(id, decision, btn) {
    const card = btn.closest(".approval-card");
    card.querySelectorAll("button").forEach(b => b.disabled = true);
    try {
      const res = await fetch("/resolve", {
        method: "POST",
        headers: { "content-type": "application/json" },
        body: JSON.stringify({ id, decision }),
      });
      if (!res.ok) {
        card.querySelectorAll("button").forEach(b => b.disabled = false);
        alert("Resolve failed: " + res.status);
      }
    } catch (err) {
      card.querySelectorAll("button").forEach(b => b.disabled = false);
      alert("Resolve failed: " + err.message);
    }
  }
  window.resolveApproval = resolveApproval;

  tick();
  setInterval(tick, 500);
</script>
</body>
</html>`;
}

function buildReplayMermaid(graph, visitedNodes, traversedEdges, deviationEvents) {
  const shortTools = (tools) =>
    tools.length > 0 ? tools.map((t) => t.replace(/^[a-z]+_/, "")).join(" / ") : "—";
  const deviationsByNode = new Map();
  for (const d of deviationEvents) {
    if (!deviationsByNode.has(d.from_node)) deviationsByNode.set(d.from_node, []);
    deviationsByNode.get(d.from_node).push(d.attempted_tool);
  }

  const lines = ["flowchart TD"];
  for (const n of graph.nodes) {
    const purpose = n.purpose.replace(/"/g, "&quot;").replace(/\n/g, " ");
    const devs = deviationsByNode.get(n.id);
    const devSuffix = devs
      ? `<br/><b style='color:#7a2418;'>deviations: ${devs.length}</b>`
      : "";
    const label = `<b>${n.id}</b><br/>${purpose}<br/><i>tools: ${shortTools(n.allowed_tools)}</i>${devSuffix}`;
    lines.push(`  ${n.id}["${label}"]`);
  }
  lines.push(`  start((entry))`);
  lines.push(`  start --> ${graph.entry}`);

  for (const e of graph.edges) {
    const key = `${e.from}→${e.to}`;
    if (traversedEdges.has(key)) {
      lines.push(`  ${e.from} ==> ${e.to}`);
    } else {
      lines.push(`  ${e.from} --> ${e.to}`);
    }
  }

  let phantomIdx = 0;
  for (const d of deviationEvents) {
    const phantom = `devghost${phantomIdx++}`;
    const tool = (d.attempted_tool || "unknown").replace(/^[a-z]+_/, "");
    lines.push(`  ${phantom}(["✕ ${tool}<br/>deviation"]):::devbox`);
    lines.push(`  ${d.from_node} -.-> ${phantom}`);
  }

  lines.push(`  classDef visited fill:#c5e3d1,stroke:#27613f,stroke-width:2px;`);
  lines.push(`  classDef devbox fill:#eec6bc,stroke:#7a2418,stroke-width:1.5px,stroke-dasharray:5 3;`);
  lines.push(`  classDef entryBadge fill:#eeeada,stroke:#1c3b5a,stroke-width:2px;`);
  lines.push(`  class start entryBadge;`);
  const visitedList = [...visitedNodes].filter((n) => graph.nodes.some((gn) => gn.id === n));
  if (visitedList.length > 0) {
    lines.push(`  class ${visitedList.join(",")} visited;`);
  }
  return lines.join("\n");
}

function writeReplayHtml(graph, events, mermaid, counts) {
  const outPath = path.join(os.tmpdir(), `betterclaw-replay-${Date.now()}.html`);
  const timelineRows = events
    .filter((e) => e.type === "allow" || e.type === "deviation")
    .map((e) => {
      const ts = e.ts?.split("T")[1]?.slice(0, 12) ?? "";
      if (e.type === "deviation") {
        return `<tr class="dev"><td>${ts}</td><td>${escapeHtml(
          e.from_node ?? "",
        )}</td><td>✕ ${escapeHtml(
          e.attempted_tool ?? "",
        )}</td><td>retry ${e.retry}/${e.retry_limit}</td></tr>`;
      }
      const arrow = e.transitioned
        ? `${escapeHtml(e.from_node)} → ${escapeHtml(e.to_node)}`
        : `— ${escapeHtml(e.from_node)}`;
      return `<tr><td>${ts}</td><td>${escapeHtml(
        e.to_node ?? e.from_node ?? "",
      )}</td><td>✓ ${escapeHtml(e.tool ?? "")}</td><td>${arrow}</td></tr>`;
    })
    .join("\n");

  const html = `<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>BetterClaw — Run replay</title>
  <style>${SHARED_CSS}</style>
  <script src="https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.min.js"></script>
</head>
<body>
  <p class="kicker">BetterClaw · Run replay</p>
  <h1 class="page-title">What the agent did</h1>
  <p class="label" style="margin: 0 0 1.25rem;">Post-hoc render of a completed agent turn</p>
  <hr class="rule"/>

  <div class="summary">
    <span class="chip allow">${counts.allowCount} allowed</span>
    <span class="chip deny">${counts.deviationCount} deviation${counts.deviationCount === 1 ? "" : "s"}</span>
    <span class="meta">entry ${escapeHtml(graph.entry)} · ${graph.nodes.length} nodes · ${graph.edges.length} edges · vertical ${escapeHtml(graph.vertical || "email")}</span>
  </div>

  <div class="layout">
    <div>
      <h2 class="section">Workflow graph</h2>
      <p class="label" style="margin-bottom:0.5rem;">Green = visited · bold edge = traversed · dashed rust = deviation attempt</p>
      <div class="mermaid-wrap"><pre class="mermaid">${mermaid}</pre></div>
    </div>
    <div>
      <h2 class="section">Timeline</h2>
      <p class="label" style="margin-bottom:0.5rem;">Chronological trace</p>
      <table>
        <thead><tr><th>time</th><th>node</th><th>tool</th><th>detail</th></tr></thead>
        <tbody>
${timelineRows}
        </tbody>
      </table>
    </div>
  </div>

  <p class="footer">generated ${new Date().toISOString()}</p>

  <script>
    ${MERMAID_INIT_JS}
    mermaid.run();
  </script>
</body>
</html>`;
  fs.writeFileSync(outPath, html);
  return outPath;
}

function preflightCheck() {
  // Per-user state dir is auto-created at module load (see BETTERCLAW_HOME).
  // The compile path doesn't require PLUGIN_ROOT to exist — that constant only
  // matters for source-clone dev workflows. npm-installed CLIs don't have it
  // and shouldn't need it.
  const claudeCheck = spawnSync("claude", ["--version"], winSpawnOpts({ encoding: "utf8" }));
  if (claudeCheck.status !== 0) {
    console.error(`error: \`claude\` CLI not found on PATH. Install: npm install -g @anthropic-ai/claude-code`);
    if (process.platform === "win32") {
      console.error(`note: on Windows, run BetterClaw from Git Bash (not PowerShell or CMD).`);
    }
    process.exit(2);
  }
}

function buildCompilePrompt(paragraph) {
  const connectorHints = COMMON_COWORK_CONNECTORS
    .map((c) => `- ${c.prefix}<action>  (e.g. ${c.actions_hint})`)
    .join("\n");

  return `You are a workflow compiler for the BetterClaw agent-guardrail system.

BetterClaw is a workflow-enforcement layer. It does NOT own or bundle tools. Tools come from the host environment: Anthropic Cowork connectors (Gmail, Google Calendar, Google Drive, Apollo.io, etc.) when running under Claude Desktop, or user-installed MCP servers when running under OpenClaw. Your job is to translate the user's paragraph into a workflow graph that gates calls to those host-provided tools.

SCHEMA (return exactly this shape, nothing else):
{
  "entry": "<node_id>",
  "max_reconsider_retries": 3,
  "requires_approval": ["<tool_name>", ...],
  "nodes": [
    { "id": "<id>", "purpose": "<human-readable sentence>", "allowed_tools": ["<concrete_tool_name>", ...] }
  ],
  "edges": [
    { "from": "<node_id>", "to": "<node_id>" }
  ]
}

TOOL NAMES — use concrete, host-provided names. Common Anthropic-connector patterns:
${connectorHints}

User-installed MCP servers expose their own tools as \`mcp__<server_name>__<action>\` (e.g. \`mcp__filesystem__read_file\`). Pick names that fit the user's paragraph; the actual availability is validated at runtime when the agent calls the tool. If the user clearly references an action (send email, schedule meeting, search contacts), pick the concrete tool name that performs it.

requires_approval lists tools that require human approval mid-run. Include a tool here if the paragraph implies manual review — phrases like "let me approve", "ask me first", "check with me" — especially around sending, deleting, posting, purchasing, or any irreversible action. Empty array [] if no approval needed.

CRITICAL — approval gate placement: when the user asks for approval before an irreversible action, requires_approval MUST contain the IRREVERSIBLE tool, NOT a preceding draft/preview tool. Drafts are reversible by definition (you can edit or delete them); sends are not. Examples:
- "let me approve before sending the email" → gate the SEND tool (e.g. mcp__claude_ai_Gmail__send_email), not the draft tool
- "check with me before posting" → gate the POST tool, not the compose tool
- "ask before purchasing" → gate the PURCHASE tool, not the cart tool

RULES:
1. Keep the graph small: 2 to 5 nodes.
2. Every node's allowed_tools must actually perform that node's purpose. If the node's purpose is to SEND, the tool must be a send action (e.g. send_email, send_message, post_message). If DELETE, the tool must be a delete action. Do NOT substitute a safer/more-conservative draft/preview tool for a node whose purpose is the irreversible action — runtime will surface unknown tool names with a clear error if you guess wrong, which is fine. EXCEPTION: pure-LLM-thinking nodes (summarize, classify, decide-which-branch, plan) may have allowed_tools: [] — these are analytical steps where the agent reasons over previously-fetched data without calling any external tool. The agent advances out of an empty-tools node by calling a tool from a reachable next node.
3. Node ids: snake_case and descriptive (e.g. "search_inbox", "draft_reply", "schedule_meeting"), NOT "node1".
4. The "purpose" field on each node must be a concrete human-readable sentence visible in the graph visualization.
5. Return edges are conditional. For BATCH workflows (the agent processes multiple items in one run — e.g. "triage 10 emails", "compare 3 products", "process each lead"), include a return edge from the last node back to the entry or a mid-flow node so the agent can pick up the next item. For SINGLE-EVENT workflows (the agent does one thing once — e.g. "send a single email", "schedule one meeting", "play music when I get home"), do NOT add a return edge to entry; the workflow is acyclic and ends at the final node.
6. Order nodes by causal dependency: search before read, read before draft, draft before send, etc.
7. If the paragraph references an action you cannot map to a plausible host-provided tool, emit ONE node with id "unrecognized_action" and allowed_tools: [] — at runtime the user will see a clear error pointing them to enable a connector or install an MCP server. Do NOT invent tool names that don't follow the conventions above.

CRITICAL: Output ONLY the JSON object. No markdown code fences. No explanation before or after.

USER PARAGRAPH:
${paragraph}

JSON:`;
}

function compileWithClaude(prompt) {
  console.log("Compiling with Claude (claude-cli, opus)...");
  // The prompt is multi-line user-derived content with potential shell
  // metacharacters. Pass via stdin (input option) instead of as an arg
  // so it never touches the shell's escaping rules. Works on Linux/macOS
  // and on Windows (where shell:true is needed for .cmd shim invocation).
  const result = spawnSync("claude", ["-p", "--output-format", "text"], winSpawnOpts({
    input: prompt,
    encoding: "utf8",
    maxBuffer: 10 * 1024 * 1024,
  }));
  if (result.status !== 0) {
    console.error("claude CLI failed:");
    console.error(result.stderr);
    if (IS_WINDOWS) {
      console.error("\nnote: on Windows, run BetterClaw from Git Bash. PowerShell and CMD have different shell quirks.");
    }
    process.exit(3);
  }
  const raw = result.stdout;
  // Extract the first JSON object from the output (Claude sometimes adds
  // explanation despite instructions).
  const jsonMatch = raw.match(/\{[\s\S]*\}/);
  if (!jsonMatch) {
    console.error("No JSON found in Claude response:");
    console.error(raw);
    process.exit(4);
  }
  try {
    return JSON.parse(jsonMatch[0]);
  } catch (err) {
    console.error(`Invalid JSON from compiler: ${err.message}`);
    console.error("\nRaw:");
    console.error(jsonMatch[0]);
    process.exit(5);
  }
}

async function renderAndConfirm(graph, paragraph) {
  const mermaid = buildMermaid(graph);
  const headless = !process.env.DISPLAY && !process.env.BROWSER;

  if (headless) {
    console.log("  " + dim("headless — Mermaid source:"));
    console.log(mermaid.split("\n").map((l) => "    " + gray(l)).join("\n"));
  } else {
    const htmlPath = writeHtml(graph, paragraph, mermaid);
    console.log(`  ${accent("→")} ${bold("Opened in browser:")} ${gray(htmlPath)}`);
    openInBrowser(htmlPath);
  }

  const rl = readline.createInterface({ input: process.stdin, output: process.stdout });
  const answer = await new Promise((resolve) =>
    rl.question("\n  " + bold("Approve this workflow?") + dim(" (y/N) "), (a) => {
      rl.close();
      resolve(a.trim().toLowerCase());
    }),
  );
  return answer === "y" || answer === "yes";
}

function buildMermaid(graph) {
  const lines = ["flowchart TD"];
  const shortTools = (tools) =>
    tools.length > 0 ? tools.map((t) => t.replace(/^gmail_/, "")).join(" / ") : "—";

  // Nodes: "id[purpose<br/>tools]"
  for (const n of graph.nodes) {
    const purpose = n.purpose.replace(/"/g, "&quot;").replace(/\n/g, " ");
    const label = `<b>${n.id}</b><br/>${purpose}<br/><i>tools: ${shortTools(n.allowed_tools)}</i>`;
    lines.push(`  ${n.id}["${label}"]`);
  }
  // Entry marker
  lines.push(`  start((entry))`);
  lines.push(`  start --> ${graph.entry}`);
  // Edges
  for (const e of graph.edges) {
    lines.push(`  ${e.from} --> ${e.to}`);
  }
  // Style entry node
  lines.push(`  classDef entryBadge fill:#eef,stroke:#36f,stroke-width:2px;`);
  lines.push(`  class start entryBadge;`);
  return lines.join("\n");
}

function writeHtml(graph, paragraph, mermaid) {
  const outPath = path.join(os.tmpdir(), `betterclaw-graph-${Date.now()}.html`);
  const approvals = (graph.requires_approval ?? []).map((t) => `<span class="mono">${escapeHtml(t)}</span>`).join(", ") || "(none)";
  const html = `<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>BetterClaw — Workflow preview</title>
  <style>${SHARED_CSS}
    .approve-instructions { margin-top: 1.5rem; font-size: 13px; color: var(--ink-soft); }
    kbd { background: var(--paper-edge); border: 1px solid var(--hairline); border-bottom-width: 2px; padding: 1px 6px; border-radius: 2px; font: 12px/1 ui-monospace, Menlo, monospace; }
  </style>
  <script src="https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.min.js"></script>
</head>
<body>
  <p class="kicker">BetterClaw · Workflow preview</p>
  <h1 class="page-title">How your paragraph compiled <em>(${escapeHtml(graph.vertical || "email")})</em></h1>
  <p class="label" style="margin: 0 0 1.25rem;">Review the nodes and the allowed tools. If anything's wrong, close this tab and answer <kbd>n</kbd> in the terminal.</p>
  <hr class="rule"/>

  <div class="paragraph-quote">${escapeHtml(paragraph)}</div>

  <h2 class="section">Compiled graph</h2>
  <p class="label" style="margin-bottom:0.5rem;">Nodes, transitions, per-node allowed tools</p>
  <div class="mermaid-wrap"><pre class="mermaid">${mermaid}</pre></div>

  <div class="summary" style="margin-top: 1.5rem;">
    <span class="chip">${graph.nodes.length} nodes</span>
    <span class="chip">${graph.edges.length} edges</span>
    <span class="chip">entry · <span class="mono" style="text-transform:none;">${escapeHtml(graph.entry)}</span></span>
    <span class="chip">retries · ${graph.max_reconsider_retries ?? 3}</span>
    <span class="chip ${(graph.requires_approval ?? []).length > 0 ? "pending" : ""}">approvals · ${approvals}</span>
  </div>

  <p class="approve-instructions">Approve in the terminal with <kbd>y</kbd> to write this graph as active.</p>
  <p class="footer">compiled ${new Date().toISOString()}</p>

  <script>
    ${MERMAID_INIT_JS}
    mermaid.run();
  </script>
</body>
</html>`;
  fs.writeFileSync(outPath, html);
  return outPath;
}

function escapeHtml(s) {
  return String(s)
    .replace(/&/g, "&amp;")
    .replace(/</g, "&lt;")
    .replace(/>/g, "&gt;")
    .replace(/"/g, "&quot;");
}

function validateGraph(graph) {
  const errors = [];

  if (typeof graph.entry !== "string") errors.push("entry must be a string");
  if (!Array.isArray(graph.nodes) || graph.nodes.length === 0)
    errors.push("nodes must be a non-empty array");
  if (!Array.isArray(graph.edges)) errors.push("edges must be an array");

  if (errors.length > 0) {
    console.error("Graph validation failed:");
    for (const e of errors) console.error("  -", e);
    process.exit(6);
  }

  const nodeIds = new Set(graph.nodes.map((n) => n.id));

  // Per ADR 0002 (v0.3+), BetterClaw doesn't own a tool registry — tools come
  // from the host environment (Cowork connectors, user MCP servers). Compile
  // validation only checks shape; runtime validation happens when the agent
  // actually calls the tool. Empty allowed_tools is a special sentinel
  // (paired with node id "unrecognized_action") that lets the compile complete
  // and surfaces a clear error when the agent runs.
  for (const n of graph.nodes) {
    if (typeof n.id !== "string") errors.push(`node missing id: ${JSON.stringify(n)}`);
    if (typeof n.purpose !== "string") errors.push(`node "${n.id}" missing purpose`);
    if (!Array.isArray(n.allowed_tools)) {
      errors.push(`node "${n.id}" allowed_tools must be an array`);
    }
    // Empty allowed_tools is permitted: it represents a pure-LLM-thinking
    // step (summarize, classify, decide-which-branch). The agent produces
    // text in that state and advances by calling a tool from a reachable
    // next node. Earlier validation restricted this to the
    // "unrecognized_action" sentinel only, but that was over-strict —
    // legitimate workflows have analytical steps with no tool call.
    for (const t of n.allowed_tools ?? []) {
      if (typeof t !== "string" || t.length === 0)
        errors.push(`node "${n.id}" has non-string tool entry: ${JSON.stringify(t)}`);
    }
  }

  if (!nodeIds.has(graph.entry)) errors.push(`entry "${graph.entry}" is not a node id`);

  for (const e of graph.edges) {
    if (!nodeIds.has(e.from)) errors.push(`edge from unknown node "${e.from}"`);
    if (!nodeIds.has(e.to)) errors.push(`edge to unknown node "${e.to}"`);
  }

  if (graph.requires_approval !== undefined) {
    if (!Array.isArray(graph.requires_approval)) {
      errors.push("requires_approval must be an array of tool names");
    } else {
      // Tools listed in requires_approval must appear in at least one node's
      // allowed_tools. Otherwise the gate is unreachable.
      const graphTools = new Set();
      for (const n of graph.nodes) {
        for (const t of n.allowed_tools ?? []) graphTools.add(t);
      }
      for (const t of graph.requires_approval) {
        if (!graphTools.has(t))
          errors.push(`requires_approval references "${t}" which appears in no node's allowed_tools`);
      }
    }
  }

  if (errors.length > 0) {
    console.error("Graph validation failed:");
    for (const e of errors) console.error("  -", e);
    console.error("\nGraph:");
    console.error(JSON.stringify(graph, null, 2));
    process.exit(7);
  }
}
