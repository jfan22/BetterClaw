// Common Anthropic-connector services (Cowork). The compile prompt hints at
// these so Claude can pick concrete tool names when the user's paragraph
// implies an action in one of these domains. List is informational; the
// actual available tools depend on which connectors the user has enabled in
// Claude.ai. Connectors verified in the Phase 0 spike.
const COMMON_COWORK_CONNECTORS = [
  { service: "Gmail", prefix: "mcp__claude_ai_Gmail__", actions_hint: "send_email, list_messages, get_message, search, draft_email" },
  { service: "Google_Calendar", prefix: "mcp__claude_ai_Google_Calendar__", actions_hint: "list_calendars, list_events, create_event, update_event, delete_event, suggest_time, respond_to_event" },
  { service: "Google_Drive", prefix: "mcp__claude_ai_Google_Drive__", actions_hint: "search, read, list" },
  { service: "Apollo_io", prefix: "mcp__claude_ai_Apollo_io__", actions_hint: "apollo_contacts_search, apollo_mixed_people_api_search, apollo_organizations_enrich, apollo_emailer_campaigns_search" },
];

const args = process.argv.slice(2);

if (args[0] === "--version" || args[0] === "-v") {
  const pkgPath = path.resolve(__dirname, "..", "package.json");
  try {
    const v = JSON.parse(fs.readFileSync(pkgPath, "utf8")).version;
    console.log(`${bold("betterclaw")} ${accent(v)}`);
  } catch {
    console.log(`${bold("betterclaw")} ${dim("(version unknown)")}`);
  }
  process.exit(0);
}

if (args.length === 0 || args[0] === "--help" || args[0] === "-h") {
  printHelp();
  process.exit(0);
}

if (args[0] === "--show") {
  if (!fs.existsSync(GRAPH_PATH)) {
    console.log(`No graph at ${GRAPH_PATH}`);
    process.exit(1);
  }
  console.log(fs.readFileSync(GRAPH_PATH, "utf8"));
  process.exit(0);
}

if (args[0] === "view" || args[0] === "--view") {
  const watch = args.includes("--watch") || args.includes("-w");
  if (watch) {
    await startWatchServer();
  } else {
    viewLastRun();
  }
  process.exit(0);
}

if (args[0] === "approve" || args[0] === "deny") {
  const decision = args[0];
  const id = args[1];
  if (!id) {
    console.error(`Usage: betterclaw ${decision} <id>`);
    process.exit(1);
  }
  await resolveApproval(id, decision);
  process.exit(0);
}

if (args[0] === "pending") {
  listPending();
  process.exit(0);
}

if (args[0] === "show") {
  const target = args[1];
  if (!target) {
    console.error("  " + deny("✗") + "  Usage: " + bold("betterclaw show <id>"));
    process.exit(1);
  }
  showApproval(target);
  process.exit(0);
}

if (args[0] === "doctor") {
  runDoctor();
  process.exit(0);
}

if (args[0] === "presets") {
  const sub = args[1];
  if (!sub) {
    listPresets();
  } else {
    installPreset(sub);
  }
  process.exit(0);
}

if (args[0] === "save") {
  if (!args[1]) {
    console.error("Usage: betterclaw save <name>");
    process.exit(1);
  }
  saveToLibrary(args[1]);
  process.exit(0);
}

if (args[0] === "load") {
  if (!args[1]) {
    console.error("Usage: betterclaw load <name>");
    process.exit(1);
  }
  loadFromLibrary(args[1]);
  process.exit(0);
}

if (args[0] === "list") {
  listLibrary();
  process.exit(0);
}

if (args[0] === "fork") {
  if (!args[1] || !args[2]) {
    console.error("Usage: betterclaw fork <url-or-gist-id> <new-name>");
    process.exit(1);
  }
  await forkFromUrl(args[1], args[2]);
  process.exit(0);
}

if (args[0] === "diff") {
  if (!args[1] || !args[2]) {
    console.error("Usage: betterclaw diff <a> <b>  (names from the library, or 'active')");
    process.exit(1);
  }
  diffGraphs(args[1], args[2]);
  process.exit(0);
}

if (args[0] === "publish") {
  if (!args[1]) {
    console.error("Usage: betterclaw publish <name>  [--to gist]");
    process.exit(1);
  }
  const dest = args[args.indexOf("--to") + 1] === "gist" ? "gist" : null;
  await publishToRemote(args[1], dest);
  process.exit(0);
}

if (args[0] === "mcp-daemon") {
  // Run the daemon in the foreground. --detach is equivalent to `betterclaw start`.
  if (args.includes("--detach")) {
    startDetachedDaemon();
    process.exit(process.exitCode ?? 0);
  }
  // --foreground --quiet is the mode used by startDetachedDaemon's spawned copy.
  const quiet = args.includes("--quiet");
  await runMcpDaemonForeground({ quiet });
  process.exit(0);
}

if (args[0] === "start") {
  // Per ADR 0002 (v0.3+), `betterclaw start` is for the opt-in Gmail MCP
  // fallback. If the user hasn't run `betterclaw connect gmail`, there's
  // nothing to start — refuse with a clear pointer.
  if (!isGmailFallbackEnabled()) {
    console.error(`  ${deny("✗")}  Gmail MCP fallback is not enabled. The daemon won't start.`);
    console.error(`     Most users don't need this — Cowork users get Gmail via Anthropic's`);
    console.error(`     verified connector with zero setup. To enable the OpenClaw fallback:`);
    console.error(`        ${accent("betterclaw connect gmail")}`);
    process.exit(1);
  }
  startDetachedDaemon();
  process.exit(process.exitCode ?? 0);
}

if (args[0] === "stop") {
  stopDaemon();
  process.exit(process.exitCode ?? 0);
}

if (args[0] === "connect") {
  if (args[1] !== "gmail") {
    console.error(`  ${deny("✗")}  Usage: betterclaw connect gmail`);
    console.error(`     Currently only "gmail" is supported. This is the OpenClaw fallback`);
    console.error(`     for users without Cowork. Cowork users get Gmail via Anthropic's`);
    console.error(`     verified connector — no \`betterclaw connect\` needed.`);
    process.exit(1);
  }
  connectGmail();
  process.exit(0);
}

if (args[0] === "disconnect") {
  if (args[1] !== "gmail") {
    console.error(`  ${deny("✗")}  Usage: betterclaw disconnect gmail`);
    process.exit(1);
  }
  disconnectGmail();
  process.exit(0);
}

if (args[0] === "status") {
  printDaemonStatus();
  process.exit(0);
}

if (args[0] === "hook") {
  const event = args[1];
  const allowed = ["pre-tool-call", "user-prompt-submit", "post-tool-call"];
  if (!allowed.includes(event)) {
    console.error(`Usage: betterclaw hook <${allowed.join("|")}>`);
    console.error(`Reads Cowork hook-event JSON from stdin, writes response JSON to stdout.`);
    console.error(`Invoked by the Cowork plugin shim at packages/plugin-cowork/bin/hook-shim.sh.`);
    process.exit(1);
  }
  await runHookCommand(event);
  process.exit(0);
}

if (args[0] === "run") {
  const task = args.slice(1).join(" ").trim();
  if (!task) {
    console.error("Usage: betterclaw run \"<task>\"");
    process.exit(1);
  }
  ensureDaemonRunning();
  maybeShowFeedbackCTA();
  // Exec openclaw agent with the task. Leave the daemon running after exit so
  // the next `betterclaw run` is instant.
  const result = spawnSync(
    "openclaw",
    ["agent", "--local", "--agent", "main", "-m", IS_WINDOWS ? winSafeArg(task) : task],
    winSpawnOpts({ stdio: "inherit" }),
  );
  process.exit(result.status ?? 0);
}

if (args[0] === "telemetry") {
  const sub = args[1];
  if (sub === "off") {
    writeTelemetryConfig({ enabled: false, firstRunNoticeShown: true });
    console.log(`  ${allow("✓")}  Telemetry disabled. No further events will be written to ${TELEMETRY_LOG_PATH}.`);
    process.exit(0);
  }
  if (sub === "on") {
    writeTelemetryConfig({ enabled: true, firstRunNoticeShown: true });
    console.log(`  ${allow("✓")}  Telemetry enabled. Events will be written to ${TELEMETRY_LOG_PATH}.`);
    process.exit(0);
  }
  if (sub === "dismiss-cta") {
    writeTelemetryConfig({ ctaDismissed: true });
    console.log(`  ${allow("✓")}  Feedback CTA dismissed. Thanks for using BetterClaw.`);
    process.exit(0);
  }
  if (sub === "dump") {
    telemetryDump();
    process.exit(0);
  }
  if (sub === "export") {
    const sinceIdx = args.indexOf("--since");
    const since = sinceIdx >= 0 ? args[sinceIdx + 1] : null;
    telemetryExport(since);
    process.exit(0);
  }
  if (sub === "path") {
    // Machine-readable: just print the log path. Useful for
    // `cat $(betterclaw telemetry path) | jq ...` pipelines.
    console.log(TELEMETRY_LOG_PATH);
    process.exit(0);
  }
  // Default: show status + short summary.
  telemetryStatus();
  process.exit(0);
}

const paragraph = args.join(" ").trim();
if (!paragraph) {
  console.error("Usage: betterclaw \"<paragraph>\"");
  process.exit(1);
}

preflightCheck();

console.log();
console.log("  " + ui.kicker("BetterClaw · Compile"));
console.log("  " + ui.hr());

const _hostId = detectHost();
console.log(`  ${dim("host")}           ${ui.chip(_hostId, "accent")}`);
console.log(`  ${dim("compiling via")}  ${accent("claude -p")} ${gray("(model=opus)")}`);
const prompt = buildCompilePrompt(paragraph);
const _compileStartMs = Date.now();
const graph = compileWithClaude(prompt);
const _compileDurationMs = Date.now() - _compileStartMs;
validateGraph(graph);

emitTelemetry("compile", {
  host: _hostId,
  duration_ms: _compileDurationMs,
  node_count: graph.nodes.length,
  edge_count: graph.edges.length,
  has_approval_gate: (graph.requires_approval?.length ?? 0) > 0,
});
maybeShowFirstRunNotice();
maybeShowFeedbackCTA();

const approvals = Array.isArray(graph.requires_approval) ? graph.requires_approval : [];
console.log();
console.log("  " + bold("Compiled graph"));
console.log(`  ${dim("entry           ")} ${graph.entry}`);
console.log(`  ${dim("nodes           ")} ${graph.nodes.length}  ${gray("(" + graph.nodes.map((n) => n.id).join(", ") + ")")}`);
console.log(`  ${dim("edges           ")} ${graph.edges.length}`);
console.log(`  ${dim("max retries     ")} ${graph.max_reconsider_retries ?? 3}`);
console.log(
  `  ${dim("requires approval")} ${
    approvals.length > 0
      ? approvals.map((t) => ui.chip(t, "pending")).join(" ")
      : gray("none — all tool calls autorun")
  }`,
);
console.log();

const approved = await renderAndConfirm(graph, paragraph);
if (!approved) {
  console.log("\nAborted — graph not written. Re-run with a different paragraph to try again.");
  process.exit(0);
}

fs.writeFileSync(GRAPH_PATH, JSON.stringify(graph, null, 2) + "\n");
fs.writeFileSync(PARAGRAPH_PATH, paragraph + "\n");
console.log(`  ${allow("✓")}  Written to ${gray(GRAPH_PATH)}`);
console.log();
console.log("  " + dim("Next:"));
console.log("    " + accent(`betterclaw run "<your task>"`));
console.log("  " + dim("The plugin picks up the new graph on the next agent turn."));
console.log();

// ---- helpers ----

// ---- presets ----

function listPresets() {
  console.log();
  console.log("  " + ui.kicker("BetterClaw · Presets"));
  console.log("  " + ui.hr());

  if (!fs.existsSync(PRESETS_DIR)) {
    console.log("  " + dim(`No presets directory at ${PRESETS_DIR}`));
    console.log();
    return;
  }
  const entries = fs
    .readdirSync(PRESETS_DIR)
    .filter((e) => fs.existsSync(path.join(PRESETS_DIR, e, "meta.json")))
    .sort();

  if (entries.length === 0) {
    console.log("  " + dim(`No presets found in ${PRESETS_DIR}`));
    console.log();
    return;
  }

  const metas = entries.map((name) => ({
    name,
    ...JSON.parse(fs.readFileSync(path.join(PRESETS_DIR, name, "meta.json"), "utf8")),
  }));
  const nameW = Math.max(4, ...metas.map((m) => m.name.length));
  for (const m of metas) {
    console.log("  " + bold(m.name.padEnd(nameW)) + "  " + gray((m.vertical || "").padEnd(10)) + "  " + m.description);
    if (m.requires && m.requires.length > 0) {
      console.log(
        "  " + " ".repeat(nameW) + "  " + " ".repeat(10) + "  " + pending("requires:") + " " + gray(m.requires.join(", ")),
      );
    }
  }
  console.log();
  console.log("  " + dim("Install: ") + accent("betterclaw presets <name>"));
  console.log();
}

function installPreset(name) {
  validateLibraryName(name);
  const srcDir = path.join(PRESETS_DIR, name);
  const graphPath = path.join(srcDir, "graph.json");
  if (!fs.existsSync(graphPath)) {
    console.error(`error: no preset named "${name}"`);
    console.error(`       Run \`betterclaw presets\` to see what's available.`);
    process.exit(1);
  }

  // Copy into the user library so it's available via `betterclaw load <name>`
  // later and shows up in `betterclaw list`.
  const libDir = libraryEntryDir(name);
  fs.mkdirSync(libDir, { recursive: true });
  fs.copyFileSync(graphPath, path.join(libDir, "graph.json"));

  const paraSrc = path.join(srcDir, "paragraph.md");
  if (fs.existsSync(paraSrc)) fs.copyFileSync(paraSrc, path.join(libDir, "paragraph.md"));

  const srcMeta = JSON.parse(fs.readFileSync(path.join(srcDir, "meta.json"), "utf8"));
  const graph = JSON.parse(fs.readFileSync(graphPath, "utf8"));
  const meta = {
    name,
    saved_at: new Date().toISOString(),
    source: "preset",
    description: srcMeta.description,
    vertical: graph.vertical,
    nodes: graph.nodes.length,
    edges: graph.edges.length,
    entry: graph.entry,
    requires_approval: graph.requires_approval ?? [],
  };
  fs.writeFileSync(path.join(libDir, "meta.json"), JSON.stringify(meta, null, 2) + "\n");

  // And load it as the active graph, same as `betterclaw load <name>`.
  fs.copyFileSync(graphPath, GRAPH_PATH);
  if (fs.existsSync(paraSrc)) fs.copyFileSync(paraSrc, PARAGRAPH_PATH);

  console.log();
  console.log(`  ${allow("✓")} ${bold("Installed preset")} ${accent(name)}  ${ui.chip(graph.vertical, "accent")}`);
  console.log(`    ${dim("summary:")} ${meta.nodes} nodes, ${meta.edges} edges, entry=${meta.entry}`);
  if (meta.requires_approval.length > 0) {
    console.log(`    ${dim("approvals:")} ${meta.requires_approval.map((t) => ui.chip(t, "pending")).join(" ")}`);
  }
  console.log();
  console.log("  " + dim("Try it:"));
  console.log("    " + accent(`betterclaw run "${srcMeta.example_agent_message || "<your task>"}"`));
  console.log();
}

function runDoctor() {
  const checks = [];

  // Node version
  const [maj] = process.versions.node.split(".").map(Number);
  checks.push({
    name: "Node >= 22",
    ok: maj >= 22,
    detail: `current: v${process.versions.node}`,
    fix: "nvm install 22 && nvm use 22 && nvm alias default 22",
  });

  // openclaw CLI on PATH
  const oc = spawnSync("openclaw", ["--version"], winSpawnOpts({ encoding: "utf8" }));
  checks.push({
    name: "openclaw CLI installed",
    ok: oc.status === 0,
    detail: oc.status === 0 ? oc.stdout.split("\n")[0] : "not found",
    fix: "npm install -g openclaw@latest",
  });

  // BetterClaw plugin loaded
  const inspect = spawnSync("openclaw", ["plugins", "inspect", "betterclaw"], winSpawnOpts({ encoding: "utf8" }));
  const pluginOk = inspect.status === 0 && /Status:\s*loaded/.test(inspect.stdout);
  checks.push({
    name: "BetterClaw plugin loaded",
    ok: pluginOk,
    detail: pluginOk
      ? "loaded"
      : inspect.status === 0
        ? "installed but not loaded — run `openclaw config set plugins.allow '[\"betterclaw\"]'`"
        : "not installed",
    fix: `openclaw plugins install ${PLUGIN_ROOT} --link && openclaw config set plugins.allow '["betterclaw"]'`,
  });

  // Gmail MCP daemon — only required if the user opted into the fallback
  const daemonStatus = readDaemonStatus();
  const gmailFallback = isGmailFallbackEnabled();
  checks.push({
    name: "Gmail MCP daemon (opt-in)",
    ok: gmailFallback ? daemonStatus.running : true,
    detail: !gmailFallback
      ? "fallback not enabled (this is fine — most users don't need it; Cowork has Gmail built-in)"
      : daemonStatus.running
        ? `pid=${daemonStatus.pid}, socket=${MCP_SOCKET_PATH}`
        : daemonStatus.staleFile
          ? `stale PID file (pid=${daemonStatus.pid} not alive)`
          : "fallback enabled but daemon not running",
    fix: gmailFallback ? "betterclaw start" : null,
    optional: !gmailFallback,
  });

  // Claude CLI auth profile
  const profilesPath = path.join(os.homedir(), ".openclaw", "agents", "main", "agent", "auth-profiles.json");
  let authOk = false;
  try {
    const profiles = JSON.parse(fs.readFileSync(profilesPath, "utf8"));
    authOk = JSON.stringify(profiles).includes("claude");
  } catch {}
  checks.push({
    name: "Claude CLI auth profile registered",
    ok: authOk,
    detail: authOk ? "present" : `missing ${profilesPath}`,
    fix: "openclaw models auth login --provider anthropic --method cli --set-default",
  });

  // Active graph
  const graphOk = fs.existsSync(GRAPH_PATH) && fs.statSync(GRAPH_PATH).size > 0;
  let graphSummary = null;
  if (graphOk) {
    try {
      const g = JSON.parse(fs.readFileSync(GRAPH_PATH, "utf8"));
      graphSummary = `${g.nodes?.length ?? 0} nodes, entry=${g.entry ?? "(unknown)"}`;
    } catch {}
  }
  checks.push({
    name: "active-graph.json present",
    ok: graphOk,
    detail: graphOk ? graphSummary : "no graph compiled yet",
    fix: `betterclaw "<your task>"`,
  });

  // Host environment (informational)
  checks.push({
    name: "Host environment",
    ok: true,
    detail: detectHost(),
    optional: true,
  });

  // Gmail OAuth credentials — only relevant if fallback was enabled
  const gmailCredOk = fs.existsSync(path.join(os.homedir(), ".gmail-mcp", "credentials.json"));
  checks.push({
    name: "Gmail OAuth credentials (only if fallback enabled)",
    ok: !gmailFallback || gmailCredOk,
    detail: !gmailFallback
      ? "fallback not enabled — credentials not required"
      : gmailCredOk
        ? "~/.gmail-mcp/credentials.json present"
        : "missing — run `npx @gongrzhe/server-gmail-autoauth-mcp auth`",
    fix: gmailFallback ? "npx @gongrzhe/server-gmail-autoauth-mcp auth" : null,
    optional: !gmailFallback,
  });

  // Stale day-1 gmail-mcp bundle — warn if both present (old conflict)
  const bundlePath = path.join(os.homedir(), ".openclaw", "extensions", "gmail-mcp");
  const bundlePresent = fs.existsSync(bundlePath);
  if (bundlePresent) {
    const bundleStatus = spawnSync("openclaw", ["plugins", "inspect", "gmail-mcp"], winSpawnOpts({ encoding: "utf8" }));
    const bundleLoaded = /Status:\s*loaded/.test(bundleStatus.stdout);
    checks.push({
      name: "Day-1 gmail-mcp bundle (should be disabled)",
      ok: !bundleLoaded,
      detail: bundleLoaded
        ? "LOADED — this will conflict with BetterClaw's Gmail fallback if enabled!"
        : "disabled (good)",
      fix: "openclaw plugins disable gmail-mcp",
    });
  }

  const pad = Math.max(...checks.map((c) => c.name.length));
  let allGreen = true;
  console.log();
  console.log("  " + ui.kicker("BetterClaw · Doctor"));
  console.log("  " + ui.hr());
  for (const check of checks) {
    let mark, colored;
    if (check.ok) {
      mark = allow("✓");
      colored = check.name;
    } else if (check.optional) {
      mark = dim("·");
      colored = dim(check.name);
    } else {
      mark = deny("✗");
      colored = check.name;
      allGreen = false;
    }
    console.log(`  ${mark}  ${colored.padEnd(pad + (NO_COLOR ? 0 : 10))}  ${gray(check.detail)}`);
    if (!check.ok) console.log(`     ${dim("fix:")} ${accent(check.fix)}`);
  }
  console.log();
  if (allGreen) {
    console.log("  " + allow("All checks passed."));
  } else {
    console.log("  " + deny("Some required checks failed.") + dim(" See `fix:` hints above."));
    console.log();
    process.exit(1);
  }
  console.log();
}

