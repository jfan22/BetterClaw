#!/usr/bin/env node
// betterclaw CLI — compile an English paragraph into a BetterClaw workflow
// graph and write it to the plugin's active-graph.json.
//
// Usage:
//   betterclaw "triage my inbox: flag investors, draft replies for customers"
//   betterclaw --show           # print current graph
//   betterclaw --help

import fs from "node:fs";
import http from "node:http";
import net from "node:net";
import os from "node:os";
import path from "node:path";
import readline from "node:readline";
import { spawnSync, spawn } from "node:child_process";
import { fileURLToPath } from "node:url";

const __filename = fileURLToPath(import.meta.url);
const __dirname = path.dirname(__filename);
// We're at packages/cli/bin/betterclaw. The plugin is at packages/plugin-openclaw/
// and presets live at the repo root (shared reference across packages).
// Repo root (only meaningful when running from a source clone — used to find
// bundled presets). On npm-installed CLIs, REPO_ROOT points at the npm node_modules
// dir which doesn't have presets/. Preset commands gracefully no-op there.
const REPO_ROOT = path.resolve(__dirname, "..", "..", "..");

// Per-user state lives in ~/.betterclaw, NOT inside the plugin install dir.
// This decouples the CLI's writes from where the plugin happens to be installed
// (which differs between source-clone, --link, and npm install) and lets the
// CLI run identically across all three. The plugin reads from the same paths
// (see workflow.mjs#resolveDefaultGraphPath etc).
//
// Override with BETTERCLAW_HOME env var if you want a different location
// (e.g. for tests or sandboxed environments).
const BETTERCLAW_HOME = process.env.BETTERCLAW_HOME || path.join(os.homedir(), ".betterclaw");
try { fs.mkdirSync(BETTERCLAW_HOME, { recursive: true }); } catch {}

const GRAPH_PATH = path.join(BETTERCLAW_HOME, "active-graph.json");
const PARAGRAPH_PATH = path.join(BETTERCLAW_HOME, "active-paragraph.md");
const RUN_LOG_PATH = path.join(BETTERCLAW_HOME, "run.jsonl");
const APPROVALS_DIR = path.join(BETTERCLAW_HOME, "approvals");

// PLUGIN_ROOT is only needed for source-clone development (to surface a
// `--link` install hint in `betterclaw doctor`). npm-installed CLI users
// never hit this path; the constant is computed best-effort and never
// required to exist.
const PLUGIN_ROOT = path.resolve(REPO_ROOT, "packages", "plugin-openclaw");

// Cross-platform spawn helper. Node's spawnSync on Windows can't invoke
// `.cmd` shims (the standard npm install format) without `shell: true`,
// even with the full path. This helper returns the right options to make
// spawnSync work for npm-installed binaries on every platform.
//
// SECURITY NOTE: on Windows, `shell: true` causes args to be interpreted
// by cmd.exe, which has its own escaping rules. Use `winSafeArgs(args)`
// to escape user-supplied content. For static args (version checks,
// fixed subcommands) the bare args are fine.
const IS_WINDOWS = process.platform === "win32";

function winSpawnOpts(extra = {}) {
  return IS_WINDOWS ? { shell: true, ...extra } : extra;
}

// Escape a single arg for cmd.exe. Wraps in double quotes and escapes
// internal quotes + ^ chars. Used for user-supplied prompt content on
// Windows to prevent shell-metacharacter injection.
function winSafeArg(s) {
  if (!IS_WINDOWS) return s;
  // Replace " with \" and wrap in "..."; escape ^ which is cmd's escape char.
  const escaped = String(s).replace(/(["^])/g, "^$1");
  return `"${escaped.replace(/"/g, '\\"')}"`;
}

// Cross-platform "open in default browser" (or default app for the URL/file).
// Detached so the browser window survives our process exit. Stdout/stderr
// silenced because none of these openers are our concern after launch.
//
// On Windows, we invoke powershell.exe with -EncodedCommand to call
// Start-Process. This is the same approach used by the popular `open` npm
// package and works reliably across calling shells (PowerShell, CMD, Git
// Bash, WSL) because:
//   1. powershell.exe is at a stable system path on every Windows install
//   2. Start-Process is the canonical Windows file-open primitive
//   3. -EncodedCommand (base64 UTF-16LE) sidesteps all shell-quoting
//      issues by passing the command opaquely — paths with spaces, quotes,
//      special chars all survive intact
//
// Earlier attempts (cmd /c start with various invocations) worked from
// some shells but not others due to PowerShell's child-process detachment
// quirks. Direct powershell.exe invocation removes the calling-shell
// dependency.
function openInBrowser(target) {
  try {
    if (process.platform === "darwin") {
      spawn("open", [target], { stdio: "ignore", detached: true }).unref();
    } else if (IS_WINDOWS) {
      const psCommand = `Start-Process -FilePath ${JSON.stringify(String(target))}`;
      const encoded = Buffer.from(psCommand, "utf16le").toString("base64");
      spawn("powershell.exe", [
        "-NoProfile",
        "-ExecutionPolicy", "Bypass",
        "-EncodedCommand", encoded,
      ], { stdio: "ignore", detached: true }).unref();
    } else {
      spawn("xdg-open", [target], { stdio: "ignore", detached: true }).unref();
    }
  } catch {
    // Browser-open is best-effort; if it fails we already printed the path.
  }
}
const LIBRARY_DIR = path.join(os.homedir(), ".betterclaw", "library");
const PRESETS_DIR = path.resolve(REPO_ROOT, "presets");

// Cross-turn history log. Unlike run.jsonl (per-turn, truncated on each
// plugin boot), this is append-only and survives across agent turns. The
// plugin's before_prompt_build hook reads from it to surface recent
// approvals back to the agent, so it can avoid re-drafting things the user
// already handled.
const HISTORY_PATH = path.join(os.homedir(), ".betterclaw", "history.jsonl");

// Gmail MCP proxy daemon. The daemon owns the @gongrzhe/server-gmail-autoauth-mcp
// subprocess and multiplexes JSON-RPC requests from the plugin (read-path) and
// the CLI's own approval dispatcher (write-path) over a Unix domain socket.
// Two reasons: (1) plugin code stays pure so OpenClaw's install-time safety
// scanner no longer requires --dangerously-force-unsafe-install, (2) one
// persistent child preserves Gmail OAuth state across agent turns.
const MCP_SOCKET_PATH = path.join(os.homedir(), ".betterclaw", "mcp.sock");
const MCP_PID_PATH = path.join(os.homedir(), ".betterclaw", "mcp.pid");
const MCP_LOG_PATH = path.join(os.homedir(), ".betterclaw", "mcp.log");

// Opt-in marker for the Gmail MCP fallback. Per ADR 0002 (v0.3+), the
// BetterClaw-bundled Gmail integration is opt-in for OpenClaw users without
// Cowork. Cowork users get Gmail via Anthropic's verified connector and don't
// need this. The marker is written by `betterclaw connect gmail` and removed
// by `betterclaw disconnect gmail`. ensureDaemonRunning() respects it.
const GMAIL_FALLBACK_MARKER_PATH = path.join(os.homedir(), ".betterclaw", "gmail-fallback-enabled");

function isGmailFallbackEnabled() {
  return fs.existsSync(GMAIL_FALLBACK_MARKER_PATH);
}

// Host detection. Informational — used to shape error messages and guidance,
// not to gate functionality. Returns one of:
//   "cowork"   — running under Anthropic Claude Code/Desktop (CLAUDE_PLUGIN_ROOT set)
//   "openclaw" — running under OpenClaw (OPENCLAW_* env vars or ~/.openclaw/ exists)
//   "manual"   — running standalone from a shell, no host integration
function detectHost() {
  if (process.env.CLAUDE_PLUGIN_ROOT || process.env.CLAUDE_PROJECT_DIR) return "cowork";
  for (const k of Object.keys(process.env)) {
    if (k.startsWith("OPENCLAW_")) return "openclaw";
  }
  if (fs.existsSync(path.join(os.homedir(), ".openclaw"))) return "openclaw";
  return "manual";
}

// Per-session workflow state for hook-model plugins (Cowork). Unlike the
// long-lived plugin VM of OpenClaw, shell-command hooks fire per-invocation
// with no in-memory state, so we persist current_node + reconsider_counter
// across hook calls here. Keyed by the host's session_id.
const COWORK_SESSIONS_PATH = path.join(os.homedir(), ".betterclaw", "cowork-sessions.json");
const COWORK_SESSION_TTL_MS = 60 * 60 * 1000; // 1h; prune on every write
const HOOK_HISTORY_MAX_ENTRIES = 8;
const HOOK_HISTORY_MAX_AGE_HOURS = 24;

// Local-only usage telemetry. Anonymous device UUID, no PII, append-only JSONL.
// The user reads their own log via `betterclaw telemetry dump` / `export`. No
// remote collector in V1 — we add one when we have design-partner volume. Plugin
// writes to the same file via a duplicated helper so this file stays standalone.
const IDENTITY_PATH = path.join(os.homedir(), ".betterclaw", "identity.json");
const TELEMETRY_CONFIG_PATH = path.join(os.homedir(), ".betterclaw", "telemetry.json");
const TELEMETRY_LOG_PATH = path.join(os.homedir(), ".betterclaw", "telemetry.jsonl");
const BETTERCLAW_VERSION = "0.3.6";

function loadIdentity() {
  if (!fs.existsSync(IDENTITY_PATH)) return null;
  try {
    return JSON.parse(fs.readFileSync(IDENTITY_PATH, "utf8"));
  } catch {
    return null;
  }
}

function ensureIdentity() {
  let id = loadIdentity();
  if (id && id.device_id) return id;
  try {
    fs.mkdirSync(path.dirname(IDENTITY_PATH), { recursive: true });
  } catch {}
  const fresh = {
    device_id: globalThis.crypto?.randomUUID?.() ?? (require("node:crypto").randomUUID()),
    first_seen: new Date().toISOString(),
    platform: process.platform,
    node_version: process.versions.node,
  };
  try {
    fs.writeFileSync(IDENTITY_PATH, JSON.stringify(fresh, null, 2) + "\n", { mode: 0o600 });
  } catch {}
  return fresh;
}

function loadTelemetryConfig() {
  // Env var override wins. Useful for CI, shared machines, one-shot testing.
  if (process.env.BETTERCLAW_TELEMETRY === "off") {
    return { enabled: false, source: "env" };
  }
  if (process.env.BETTERCLAW_TELEMETRY === "on") {
    return { enabled: true, source: "env" };
  }
  if (!fs.existsSync(TELEMETRY_CONFIG_PATH)) {
    return { enabled: true, source: "default" };
  }
  try {
    const cfg = JSON.parse(fs.readFileSync(TELEMETRY_CONFIG_PATH, "utf8"));
    return { enabled: cfg.enabled !== false, source: "file", ...cfg };
  } catch {
    return { enabled: true, source: "default" };
  }
}

function writeTelemetryConfig(partial) {
  try {
    fs.mkdirSync(path.dirname(TELEMETRY_CONFIG_PATH), { recursive: true });
  } catch {}
  const existing = (() => {
    if (!fs.existsSync(TELEMETRY_CONFIG_PATH)) return {};
    try {
      return JSON.parse(fs.readFileSync(TELEMETRY_CONFIG_PATH, "utf8"));
    } catch {
      return {};
    }
  })();
  const merged = { ...existing, ...partial };
  fs.writeFileSync(
    TELEMETRY_CONFIG_PATH,
    JSON.stringify(merged, null, 2) + "\n",
    { mode: 0o600 },
  );
}

function telemetryStatus() {
  const cfg = loadTelemetryConfig();
  const id = loadIdentity();
  const events = readTelemetryEvents();
  console.log();
  console.log("  " + ui.kicker("BetterClaw · Telemetry"));
  console.log("  " + ui.hr());
  if (cfg.enabled) {
    console.log(`  ${allow("●")}  Enabled       ${gray("(source: " + cfg.source + ")")}`);
  } else {
    console.log(`  ${dim("○")}  Disabled      ${gray("(source: " + cfg.source + ")")}`);
  }
  console.log(`  ${dim("device_id   ")}  ${id?.device_id ?? gray("(not yet generated)")}`);
  console.log(`  ${dim("first_seen  ")}  ${id?.first_seen ?? gray("—")}`);
  console.log(`  ${dim("events      ")}  ${events.length}`);
  console.log(`  ${dim("log         ")}  ${TELEMETRY_LOG_PATH}`);
  console.log();
  console.log("  " + dim("Commands:"));
  console.log("    " + accent("betterclaw telemetry dump") + gray("    — event summary by type / vertical / week"));
  console.log("    " + accent("betterclaw telemetry off") + gray("     — disable + stop writing"));
  console.log("    " + accent("betterclaw telemetry on") + gray("      — re-enable"));
  console.log("    " + accent("betterclaw telemetry export") + gray("  — dump JSONL to stdout (use --since YYYY-MM-DD)"));
  console.log();
}

function readTelemetryEvents() {
  if (!fs.existsSync(TELEMETRY_LOG_PATH)) return [];
  try {
    return fs.readFileSync(TELEMETRY_LOG_PATH, "utf8")
      .split("\n")
      .filter(Boolean)
      .map((line) => {
        try { return JSON.parse(line); } catch { return null; }
      })
      .filter(Boolean);
  } catch {
    return [];
  }
}

function telemetryDump() {
  const events = readTelemetryEvents();
  console.log();
  console.log("  " + ui.kicker("BetterClaw · Telemetry dump"));
  console.log("  " + ui.hr());
  if (events.length === 0) {
    console.log("  " + dim("No events yet."));
    console.log();
    return;
  }
  console.log(`  ${dim("total events      ")}  ${events.length}`);
  console.log(`  ${dim("first event       ")}  ${events[0].ts}`);
  console.log(`  ${dim("latest event      ")}  ${events[events.length - 1].ts}`);
  console.log();

  // Count by event type
  const byType = {};
  const byVertical = {};
  const byWeek = {};
  for (const e of events) {
    byType[e.event] = (byType[e.event] ?? 0) + 1;
    const v = e.properties?.vertical;
    if (v) byVertical[v] = (byVertical[v] ?? 0) + 1;
    const wk = e.ts.slice(0, 10); // ISO date
    byWeek[wk] = (byWeek[wk] ?? 0) + 1;
  }

  console.log("  " + bold("By event type"));
  for (const [k, v] of Object.entries(byType).sort((a, b) => b[1] - a[1])) {
    console.log(`    ${v.toString().padStart(5)}  ${k}`);
  }
  console.log();

  if (Object.keys(byVertical).length > 0) {
    console.log("  " + bold("By vertical"));
    for (const [k, v] of Object.entries(byVertical).sort((a, b) => b[1] - a[1])) {
      console.log(`    ${v.toString().padStart(5)}  ${k}`);
    }
    console.log();
  }

  console.log("  " + bold("By day (last 14)"));
  const days = Object.entries(byWeek).sort().slice(-14);
  for (const [k, v] of days) {
    console.log(`    ${k}  ${"█".repeat(Math.min(v, 60))} ${gray("(" + v + ")")}`);
  }
  console.log();
}

function telemetryExport(since) {
  const events = readTelemetryEvents();
  const filtered = since
    ? events.filter((e) => e.ts >= since)
    : events;
  for (const e of filtered) {
    process.stdout.write(JSON.stringify(e) + "\n");
  }
}

// Fire-and-forget. Never blocks, never throws. If disabled, silently no-ops.
function emitTelemetry(event, properties = {}, { source = "cli" } = {}) {
  const cfg = loadTelemetryConfig();
  if (!cfg.enabled) return;
  const id = ensureIdentity();
  const row = {
    ts: new Date().toISOString(),
    device_id: id.device_id,
    source,
    version: BETTERCLAW_VERSION,
    event,
    properties: properties || {},
  };
  try {
    fs.mkdirSync(path.dirname(TELEMETRY_LOG_PATH), { recursive: true });
    fs.appendFileSync(TELEMETRY_LOG_PATH, JSON.stringify(row) + "\n");
  } catch {
    // Telemetry must never break a real workflow. Swallow all errors.
  }
}

// Default feedback URL shown in the day-3 CTA. Override via
// `~/.betterclaw/telemetry.json` { "feedback_url": "..." } or the
// BETTERCLAW_FEEDBACK_URL env var. Maintainer should replace this with a real
// URL (cal.com, a mailto:, a typeform) before publishing to npm.
const DEFAULT_FEEDBACK_URL = "https://calendar.app.google/Lq7uHv8cpr7GfPJV7";

// Day-3 post-install CTA. Fires on `compile`, `run`, `start` — moments when
// the user has just asked BetterClaw to do something useful, not during
// inspection/debug commands. At most 3 showings per device, then auto-dismiss.
// Gated on: telemetry enabled, identity exists, ≥3 days since first_seen,
// AND user has actually exercised the product (≥2 compile events OR ≥1
// approve). The "actually exercised" gate prevents nagging someone who
// installed but bounced.
function maybeShowFeedbackCTA() {
  const cfg = loadTelemetryConfig();
  if (!cfg.enabled) return;
  if (cfg.ctaDismissed) return;
  if ((cfg.ctaShownCount ?? 0) >= 3) return;
  const id = loadIdentity();
  if (!id || !id.first_seen) return;

  const daysSinceInstall =
    (Date.now() - new Date(id.first_seen).getTime()) / (86400 * 1000);
  if (daysSinceInstall < 3) return;

  // Check the user has actually used the tool (not just run `doctor` once).
  let compiles = 0;
  let approves = 0;
  try {
    const lines = fs.readFileSync(TELEMETRY_LOG_PATH, "utf8").split("\n");
    for (const line of lines) {
      if (!line.trim()) continue;
      try {
        const evt = JSON.parse(line);
        if (evt.event === "compile") compiles++;
        else if (evt.event === "approve") approves++;
      } catch {}
    }
  } catch {
    return; // no log yet = definitely no usage yet
  }
  if (compiles < 2 && approves < 1) return;

  const url =
    process.env.BETTERCLAW_FEEDBACK_URL || cfg.feedback_url || DEFAULT_FEEDBACK_URL;
  const days = Math.floor(daysSinceInstall);

  console.log();
  console.log("  " + ui.kicker("BetterClaw · Would love your perspective"));
  console.log("  " + ui.hr());
  console.log(`  You've been using this for ${days} day${days === 1 ? "" : "s"}.`);
  console.log(`  15 min of honest feedback would shape where this goes next.`);
  console.log();
  console.log(`  ${accent(url)}`);
  console.log();
  console.log(`  ${dim("Dismiss: ")}${accent("betterclaw telemetry dismiss-cta")}`);
  console.log();

  writeTelemetryConfig({
    ctaShownCount: (cfg.ctaShownCount ?? 0) + 1,
    ctaFirstShown: cfg.ctaFirstShown || new Date().toISOString(),
  });
}

// First-run notice. Called from `betterclaw start` and from the bare-paragraph
// path. Prints once per device, then sets firstRunNoticeShown=true in the
// telemetry config so it doesn't nag.
function maybeShowFirstRunNotice() {
  const cfg = loadTelemetryConfig();
  if (cfg.firstRunNoticeShown) return;
  if (!cfg.enabled) {
    // Already off — no notice needed.
    writeTelemetryConfig({ firstRunNoticeShown: true });
    return;
  }
  console.log();
  console.log("  " + dim("BetterClaw writes anonymous usage metrics to"));
  console.log("  " + dim("  ~/.betterclaw/telemetry.jsonl (no PII, local-only)."));
  console.log("  " + dim("Opt out any time: ") + accent("betterclaw telemetry off"));
  console.log();
  writeTelemetryConfig({ firstRunNoticeShown: true });
}
function appendHistory(event) {
  try {
    fs.mkdirSync(path.dirname(HISTORY_PATH), { recursive: true });
    fs.appendFileSync(HISTORY_PATH, JSON.stringify(event) + "\n");
  } catch {}
}

// Terminal styling. Matches the HTML design language: dim for secondary,
// green=allow, red=deny, yellow=pending, cyan=accent/meta, bold for command
// names and page titles. Respects NO_COLOR and non-TTY (pipes get plain text).
const ANSI = {
  reset:   "\x1b[0m",
  bold:    "\x1b[1m",
  dim:     "\x1b[2m",
  italic:  "\x1b[3m",
  ink:     "\x1b[0m",
  dimgray: "\x1b[90m",
  accent:  "\x1b[36m",
  allow:   "\x1b[32m",
  deny:    "\x1b[31m",
  pending: "\x1b[33m",
};
const NO_COLOR = !process.stdout.isTTY || process.env.NO_COLOR;
const wrap = (code) => (text) => (NO_COLOR ? text : `${code}${text}${ANSI.reset}`);
const bold    = wrap(ANSI.bold);
const dim     = wrap(ANSI.dim);
const italic  = wrap(ANSI.italic);
const accent  = wrap(ANSI.accent);
const allow   = wrap(ANSI.allow);
const deny    = wrap(ANSI.deny);
const pending = wrap(ANSI.pending);
const gray    = wrap(ANSI.dimgray);

const ui = {
  // Small-caps-like kicker (dim uppercase) — matches HTML kicker line.
  kicker(text) { return dim(text.toUpperCase()); },
  // Big title: bold.
  title(text) { return bold(text); },
  // Section label: dim uppercase with a bit of space before it.
  section(text) { return "\n" + dim(text.toUpperCase()); },
  // Subtle hairline rule.
  hr(width = 56) { return dim("─".repeat(width)); },
  // Inline chip in [brackets] with optional color.
  chip(text, color) {
    const label = `[${text}]`;
    if (color === "allow")   return allow(label);
    if (color === "deny")    return deny(label);
    if (color === "pending") return pending(label);
    if (color === "accent")  return accent(label);
    return dim(label);
  },
};

// Shared design language for every HTML output. Editorial / auditor's journal:
// warm paper, ink, restrained palette, serif headers, mono for tool names and
// IDs. Hard edges, no fuzzy SaaS rounded-corners. The conceptual metaphor is
// "inspecting the agent's record" — everything is readable and auditable.
