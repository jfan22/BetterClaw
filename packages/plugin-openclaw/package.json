{
  "name": "@betterclaw-ai/plugin-openclaw",
  "version": "0.3.12",
  "description": "Workflow-enforcement layer for OpenClaw — gates AI agent tool calls against a declarative graph. Tools come from the host environment (Cowork connectors or user-installed MCP servers).",
  "license": "Apache-2.0",
  "author": "BetterClaw contributors",
  "homepage": "https://github.com/jfan22/BetterClaw",
  "repository": {
    "type": "git",
    "url": "https://github.com/jfan22/BetterClaw.git",
    "directory": "packages/plugin-openclaw"
  },
  "bugs": {
    "url": "https://github.com/jfan22/BetterClaw/issues"
  },
  "keywords": [
    "openclaw-plugin",
    "workflow-enforcement",
    "ai-agents",
    "approval-gate",
    "audit-log",
    "mcp"
  ],
  "type": "module",
  "files": [
    "index.mjs",
    "workflow.mjs",
    "enforcement.mjs",
    "history.mjs",
    "mcp-proxy-client.mjs",
    "telemetry.mjs",
    "vertical-email.mjs",
    "demo-shopping.mjs",
    "openclaw.plugin.json",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "openclaw": {
    "extensions": [
      "./index.mjs"
    ],
    "compat": {
      "pluginApi": ">=2026.4.24",
      "minGatewayVersion": "2026.4.24"
    },
    "build": {
      "openclawVersion": "2026.4.24",
      "pluginSdkVersion": "2026.4.24"
    }
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.0"
  },
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  }
}
